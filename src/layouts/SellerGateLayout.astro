---
// Temporary frontend gate only.
// Proper protection should later be handled with server-side auth,
// Cloudflare Access, Vercel middleware, Netlify password protection,
// or another real access control method.
import Layout from "./Layout.astro";

export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<Layout title={title} lang="en">
  <!-- Gate overlay — hidden after successful auth -->
  <div id="seller-gate" class="fixed inset-0 z-[9999] bg-box-bg flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <div class="inline-flex w-14 h-14 rounded-2xl bg-primary/10 items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-heading-1 mb-1">Seller Hub</h1>
        <p class="text-sm text-heading-3">Internal access for Flores Nexus Group representatives.</p>
      </div>

      <form id="gate-form" class="space-y-4">
        <div>
          <label for="gate-password" class="block text-sm font-semibold text-heading-2 mb-1.5">Access Code</label>
          <input
            type="password"
            id="gate-password"
            name="password"
            autocomplete="current-password"
            class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm"
            placeholder="Enter access code"
          />
        </div>
        <div id="gate-error" class="hidden text-sm text-red-500 text-center">
          Incorrect access code. Contact your Flores Nexus representative.
        </div>
        <button
          type="submit"
          class="w-full py-3 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300"
        >
          Access Seller Hub
        </button>
      </form>

      <p class="text-center text-xs text-heading-3 mt-6">
        Not a seller? <a href="/en" class="text-primary hover:underline">Return to main site</a>
      </p>
    </div>
  </div>

  <!-- Protected content (shown after auth) -->
  <div id="seller-protected" class="hidden">
    <slot />
  </div>
</Layout>

<script>
  // Temporary frontend gate only.
  // Replace with server-side auth before production use.
  const AUTH_KEY = "fn_seller_hub_2026";
  const TEMP_PASSWORD = "FNSeller2026";

  const gate = document.getElementById("seller-gate");
  const content = document.getElementById("seller-protected");
  const form = document.getElementById("gate-form");
  const errorEl = document.getElementById("gate-error");

  function isAuthorized(): boolean {
    return sessionStorage.getItem("seller_hub_auth") === AUTH_KEY;
  }

  function unlockHub(): void {
    sessionStorage.setItem("seller_hub_auth", AUTH_KEY);
    gate?.classList.add("hidden");
    content?.classList.remove("hidden");
  }

  if (isAuthorized()) {
    unlockHub();
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("gate-password") as HTMLInputElement;
    if (input.value === TEMP_PASSWORD) {
      errorEl?.classList.add("hidden");
      unlockHub();
    } else {
      errorEl?.classList.remove("hidden");
      input.value = "";
      input.focus();
    }
  });
</script>
