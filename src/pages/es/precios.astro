---
import Layout from "../../layouts/Layout.astro";
import Pricing from "../../components/sections/Pricing.astro";
import MiniCard from "../../components/sections/MiniCard.astro";
import LocalPresenceStarter from "../../components/sections/LocalPresenceStarter.astro";
import BusinessSystemCTA from "../../components/sections/BusinessSystemCTA.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
import Container from "../../components/shared/Container.astro";
---

<Layout
  title="Planes y Precios"
  description="Precios de Flores Nexus Group — Nexus Mini Card, Local Presence Starter, Starter Website, Professional Website y Business System."
  lang="es"
>
  <main class="pt-24 flex flex-col overflow-hidden">
    <section class="py-12">
      <Container>
        <div class="text-center max-w-2xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold text-heading-1 mb-4">Planes y Precios</h1>
          <p class="text-heading-3 text-lg">
            Páginas web mensuales simples y herramientas de presencia digital para negocios locales.
            Sin contratos a largo plazo. Precios claros.
          </p>
        </div>
      </Container>
    </section>

    <Pricing lang="es" />
    <MiniCard lang="es" />
    <LocalPresenceStarter lang="es" />
    <BusinessSystemCTA lang="es" />

    <!-- Delivery note -->
    <section class="py-6">
      <Container>
        <div class="max-w-2xl mx-auto text-center p-4 rounded-xl bg-primary/5 border border-primary/20">
          <p class="text-sm text-heading-2">
            <strong>La producción comienza solo después de recibir el pago y la información completa del cliente.</strong>
            La entrega estándar es de 3–5 días hábiles después de recibir el pago y la información completa.
          </p>
        </div>
      </Container>
    </section>

    <FinalCTA lang="es" />
  </main>
</Layout>
