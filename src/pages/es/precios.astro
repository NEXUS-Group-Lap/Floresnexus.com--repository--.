---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import Pricing from "../../components/sections/Pricing.astro";
import PlanComparisonTable from "../../components/sections/pricing/PlanComparisonTable.astro";
import PlanExamples from "../../components/sections/pricing/PlanExamples.astro";
---

<Layout
  title="Comparar Planes — Flores Nexus Group"
  description="Compara Nexus Card, Starter Website y Professional Website lado a lado. Ve funciones, límites y ejemplos de cada plan."
  lang="es"
>
  <main class="pt-24 flex flex-col overflow-hidden">
    <Pricing lang="es" />
    <PlanComparisonTable lang="es" />

    <div class="bg-gray-50 dark:bg-gray-900/30">
      <PlanExamples lang="es" />
    </div>

    <section class="py-16">
      <Container>
        <div class="text-center max-w-2xl mx-auto" data-reveal>
          <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">
            ¿Listo para <span class="text-primary dark:text-blue-400">empezar</span>?
          </h2>
          <p class="text-lg text-heading-3 mb-8">
            Elige el plan que se adapte a tu negocio y empieza hoy.
          </p>
          <a
            href="/es/empezar"
            class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 motion-button"
          >
            Comenzar Mi Sitio
          </a>
        </div>
      </Container>
    </section>
  </main>
</Layout>

<script is:inline>
(function () {
  var tabPlans = ["nexus-card", "starter", "professional"];
  var params = new URLSearchParams(window.location.search);
  var initialTab = tabPlans.includes(params.get("plan") || "") ? params.get("plan") : "starter";

  function switchExamplesTab(planId) {
    if (!tabPlans.includes(planId)) return;
    document.querySelectorAll("[data-examples-tab]").forEach(function (btn) {
      var active = btn.dataset.examplesTab === planId;
      btn.setAttribute("aria-selected", active ? "true" : "false");
      btn.classList.toggle("border-primary", active);
      btn.classList.toggle("text-primary", active);
      btn.classList.toggle("font-semibold", active);
      btn.classList.toggle("border-transparent", !active);
      btn.classList.toggle("text-heading-3", !active);
    });
    document.querySelectorAll("[data-examples-panel]").forEach(function (panel) {
      panel.classList.toggle("hidden", panel.dataset.examplesPanel !== planId);
    });
  }

  document.querySelectorAll("[data-examples-tab]").forEach(function (btn) {
    btn.addEventListener("click", function () { switchExamplesTab(btn.dataset.examplesTab); });
  });

  document.querySelectorAll('[role="tablist"]').forEach(function (tablist) {
    tablist.addEventListener("keydown", function (e) {
      var tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
      var idx = tabs.indexOf(document.activeElement);
      if (idx < 0) return;
      var next = idx;
      if (e.key === "ArrowRight") next = (idx + 1) % tabs.length;
      else if (e.key === "ArrowLeft") next = (idx - 1 + tabs.length) % tabs.length;
      else if (e.key === "Home") next = 0;
      else if (e.key === "End") next = tabs.length - 1;
      else return;
      e.preventDefault();
      tabs[next].focus();
      tabs[next].click();
    });
  });

  switchExamplesTab(initialTab);
})();
</script>
