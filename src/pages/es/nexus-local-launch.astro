                  <input type="checkbox" name="confirm_autorizacion_admin" id="confirm_autorizacion_admin" required class="w-5 h-5 accent-primary mt-0.5 flex-shrink-0" />
                  <span class="text-sm text-heading-2 leading-relaxed">
                    Autorizo a Flores Nexus Group LLC a ayudar con la configuración y administración básica de Google Maps y Apple Maps mientras el plan contratado esté activo.
                  </span>
                </label>

                <label class="flex items-start gap-3 cursor-pointer p-4 rounded-xl border border-box-border hover:border-primary/40 transition-colors">
                  <input type="checkbox" name="confirm_fotos" id="confirm_fotos" required class="w-5 h-5 accent-primary mt-0.5 flex-shrink-0" />
                  <span class="text-sm text-heading-2 leading-relaxed">
                    Autorizo a Flores Nexus Group LLC a utilizar fotos, capturas de pantalla, diseños, secciones del sitio web, Mini Card, logotipo, nombre comercial, imágenes del negocio, imágenes de productos, imágenes del local y material visual proporcionado por el cliente o creado durante el proyecto para fines de portafolio, demostración, promoción, publicidad, redes sociales, propuestas comerciales, ejemplos de trabajo y material de ventas de Flores Nexus Group LLC. Si deseo limitar el uso de alguna imagen, producto, persona, área privada, documento, precio, información sensible o material específico, debo notificarlo por escrito.
                  </span>
                </label>

                <label class="flex items-start gap-3 cursor-pointer p-4 rounded-xl border border-box-border hover:border-primary/40 transition-colors">
                  <input type="checkbox" name="confirm_precio" id="confirm_precio" required class="w-5 h-5 accent-primary mt-0.5 flex-shrink-0" />
                  <span class="text-sm text-heading-2 leading-relaxed">
                    Entiendo que este precio puede corresponder a una oferta de apertura, promoción inicial o paquete especial. Flores Nexus Group LLC puede modificar, actualizar o descontinuar precios de apertura, promociones, paquetes especiales, descuentos o beneficios iniciales para nuevos clientes, servicios futuros, renovaciones, cambios de plan o servicios adicionales.
                  </span>
                </label>

              </div>
            </div>

            <!-- Error message -->
            <div id="form-error" class="hidden rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 p-4 text-sm text-red-700 dark:text-red-300 text-center">
              Por favor complete todos los campos requeridos y marque todas las confirmaciones para continuar.
            </div>

            <!-- Submit button -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full py-5 rounded-full bg-primary text-white font-bold text-lg hover:bg-blue-800 transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="submit-text">Enviar Información del Negocio</span>
            </button>

            <p class="text-xs text-center text-heading-3 leading-relaxed">
              Después de enviar, verás el botón de pago para activar el servicio. La producción inicia después
              del pago y cuando Flores Nexus Group reciba la información completa del negocio.
            </p>
          </form>
        </div>
      </Container>
    </section>

  </main>
</Layout>


<script>
  // Accordion toggle
  document.querySelectorAll(".accordion-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = (btn as HTMLElement).dataset.target;
      const content = document.getElementById(targetId ?? "");
      const icon = btn.querySelector(".accordion-icon");
      const isOpen = btn.getAttribute("aria-expanded") === "true";

      btn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      content?.classList.toggle("hidden", isOpen);
      if (icon) icon.textContent = isOpen ? "+" : "−";
    });
  });

  // Form submission via fetch (Formspree AJAX)
  const form = document.getElementById("nll-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const submitText = document.getElementById("submit-text");
  const formError = document.getElementById("form-error");
  const formSuccess = document.getElementById("form-success");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Validate required checkboxes
      const required = ["confirm_terminos","confirm_resultados","confirm_tiempos","confirm_autorizacion_admin","confirm_fotos","confirm_precio"];
      const allChecked = required.every((id) => (document.getElementById(id) as HTMLInputElement)?.checked);

      if (!allChecked || !form.checkValidity()) {
        formError?.classList.remove("hidden");
        form.reportValidity();
        return;
      }

      formError?.classList.add("hidden");
      if (submitBtn) submitBtn.disabled = true;
      if (submitText) submitText.textContent = "Enviando...";

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: "POST",
          body: data,
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          form.classList.add("hidden");
          formSuccess?.classList.remove("hidden");
          formSuccess?.scrollIntoView({ behavior: "smooth", block: "start" });
        } else {
          if (submitBtn) submitBtn.disabled = false;
          if (submitText) submitText.textContent = "Enviar Información del Negocio";
          formError?.classList.remove("hidden");
          if (formError) formError.textContent = "Hubo un error al enviar. Por favor intente de nuevo.";
        }
      } catch {
        if (submitBtn) submitBtn.disabled = false;
        if (submitText) submitText.textContent = "Enviar Información del Negocio";
        formError?.classList.remove("hidden");
        if (formError) formError.textContent = "Error de conexión. Por favor intente de nuevo.";
      }
    });
  }
</script>
