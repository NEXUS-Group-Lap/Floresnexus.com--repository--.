---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";

const STRIPE_LINK = "https://buy.stripe.com/eVqeVf4DBgqYeW12eW9Ve03";
const FORMSPREE_ENDPOINT = "https://formspree.io/f/mdavzvqj";
const CUSTOM_PROPOSAL_LINK = "#";
---

<Layout
  title="Nexus Local Launch"
  description="Paquete de apertura para negocios locales. Mini Card administrada + Google Maps y Apple Maps. $150 inicial + $45/mes."
  lang="es"
>
  <main class="pt-24 pb-20">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section class="py-12 bg-gradient-to-br from-primary/5 to-transparent">
      <Container>
        <div class="max-w-3xl mx-auto text-center">
          <span class="inline-block mb-4 px-4 py-1.5 rounded-full text-xs font-semibold bg-primary/10 text-primary uppercase tracking-wider">
            Oferta de Apertura
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-heading-1 mb-4 leading-tight">
            Nexus Local Launch
          </h1>
          <p class="text-lg font-semibold text-heading-2 mb-3">
            Mini Card + Google Maps / Apple Maps Setup
          </p>
          <p class="text-heading-3 text-base md:text-lg mb-8 max-w-2xl mx-auto leading-relaxed">
            Un paquete de apertura para negocios locales que necesitan organizar su presencia digital básica,
            tener un link profesional administrado y conectar su información con Google Maps y Apple Maps.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="#formulario"
              class="px-8 py-4 rounded-full bg-primary text-white font-semibold text-base hover:bg-blue-800 transition-colors duration-200 text-center"
            >
              Completar información del negocio
            </a>
            <a
              href={STRIPE_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="px-8 py-4 rounded-full border-2 border-primary text-primary font-semibold text-base hover:bg-primary/5 transition-colors duration-200 text-center"
            >
              Pagar Nexus Local Launch
            </a>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── RESUMEN DEL PAQUETE ────────────────────────────────── -->
    <section class="py-10">
      <Container>
        <div class="max-w-2xl mx-auto">
          <div class="rounded-2xl border-2 border-primary/30 bg-box-bg shadow-lg overflow-hidden">
            <div class="bg-primary px-6 py-5 text-white text-center">
              <h2 class="text-2xl font-bold">Nexus Local Launch</h2>
              <p class="text-primary-100 text-sm mt-1 opacity-90">Oferta de apertura por tiempo limitado</p>
            </div>
            <div class="p-6 space-y-3">
              <div class="flex items-center justify-between py-2 border-b border-box-border">
                <span class="text-heading-2 font-medium">Activación inicial</span>
                <span class="text-heading-1 font-bold text-lg">$150</span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-box-border">
                <span class="text-heading-2 font-medium">Nexus Mini Card</span>
                <span class="text-heading-2">$25/mes</span>
              </div>
              <div class="flex items-center justify-between py-2 border-b border-box-border">
                <span class="text-heading-2 font-medium">Administración Google Maps / Apple Maps</span>
                <span class="text-heading-2">$20/mes</span>
              </div>
              <div class="flex items-center justify-between py-3 mt-1">
                <span class="text-heading-1 font-bold text-lg">Total mensual</span>
                <span class="text-primary font-bold text-2xl">$45/mes</span>
              </div>
              <a
                href={STRIPE_LINK}
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full text-center py-4 rounded-full bg-primary text-white font-bold text-base hover:bg-blue-800 transition-colors duration-200 mt-2"
              >
                Pagar Nexus Local Launch — $150 inicial + $45/mes
              </a>
              <p class="text-xs text-heading-3 text-center leading-relaxed mt-3 px-2">
                Este precio corresponde a una oferta de apertura por tiempo limitado. Flores Nexus Group LLC puede
                actualizar, modificar o descontinuar precios de apertura, promociones, paquetes especiales o
                beneficios iniciales para futuros clientes, renovaciones, cambios de plan o servicios adicionales.
              </p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── QUÉ INCLUYE LA MINI CARD ───────────────────────────── -->
    <section class="py-10">
      <Container>
        <div class="max-w-3xl mx-auto">
          <button
            class="accordion-toggle w-full text-left rounded-2xl border border-box-border bg-box-bg px-6 py-5 flex items-center justify-between hover:border-primary/40 transition-colors duration-200"
            data-target="minicard-content"
            aria-expanded="false"
          >
            <div>
              <h2 class="text-xl font-bold text-heading-1">¿Qué incluye la Nexus Mini Card?</h2>
              <p class="text-sm text-heading-3 mt-1">Presencia básica administrada por Flores Nexus Group</p>
            </div>
            <span class="accordion-icon text-primary text-2xl font-light ml-4 flex-shrink-0">+</span>
          </button>
          <div id="minicard-content" class="accordion-content hidden mt-1 rounded-2xl border border-box-border bg-box-bg px-6 py-6">
            <p class="text-heading-2 mb-5 leading-relaxed">
              La Nexus Mini Card es una tarjeta digital administrada por Flores Nexus Group. Está diseñada para
              negocios que necesitan una presencia básica, fácil de compartir y con información esencial.
            </p>
            <h3 class="font-bold text-heading-1 mb-3">Incluye:</h3>
            <ul class="space-y-2 mb-6">
              {[
                "Página básica administrada por Flores Nexus Group.",
                "Link administrado por Flores Nexus.",
                "Nombre del negocio.",
                "Teléfono principal.",
                "Botón para llamar.",
                "Botón para enviar mensaje o WhatsApp, si aplica.",
                "Dirección o área de servicio.",
                "Horarios básicos.",
                "Lista de 3 a 5 productos o servicios principales.",
                "Una imagen principal o fondo visual.",
                "Fotos básicas del negocio o productos, si el cliente las proporciona.",
                "Redes sociales, si existen.",
                "Botón para obtener direcciones.",
                "Diseño adaptado para celular.",
                "Carga inicial de información entregada por el cliente.",
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-heading-2">
                  <span class="text-primary mt-0.5 flex-shrink-0">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-4">
              <p class="text-sm text-amber-800 dark:text-amber-300 leading-relaxed font-medium">
                La Mini Card está pensada como una presencia básica, no como un sitio web completo. Su función principal
                es centralizar la información esencial del negocio y facilitar que el cliente pueda verla, compartirla
                y contactar al negocio.
              </p>
            </div>
            <h3 class="font-bold text-heading-1 mb-3 text-sm">Servicios disponibles por cotización o add-on:</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
              {[
                "Nuevas secciones",
                "Menú completo",
                "Catálogo de productos",
                "Galería extensa",
                "Página de promociones",
                "Formularios avanzados",
                "Booking o citas",
                "Pagos en línea",
                "Rediseño visual",
                "Cambios frecuentes post publicación",
                "Dominio personalizado del cliente",
              ].map((item) => (
                <li class="flex items-start gap-2 text-xs text-heading-3">
                  <span class="text-heading-3 mt-0.5 flex-shrink-0">—</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── GOOGLE MAPS / APPLE MAPS ───────────────────────────── -->
    <section class="py-2">
      <Container>
        <div class="max-w-3xl mx-auto">
          <button
            class="accordion-toggle w-full text-left rounded-2xl border border-box-border bg-box-bg px-6 py-5 flex items-center justify-between hover:border-primary/40 transition-colors duration-200"
            data-target="maps-content"
            aria-expanded="false"
          >
            <div>
              <h2 class="text-xl font-bold text-heading-1">Administración de Google Maps y Apple Maps</h2>
              <p class="text-sm text-heading-3 mt-1">Mantenimiento mensual básico de presencia en mapas</p>
            </div>
            <span class="accordion-icon text-primary text-2xl font-light ml-4 flex-shrink-0">+</span>
          </button>
          <div id="maps-content" class="accordion-content hidden mt-1 rounded-2xl border border-box-border bg-box-bg px-6 py-6">
            <p class="text-heading-2 mb-5 leading-relaxed">
              La administración de Google Maps y Apple Maps es un add-on mensual para mantener la información
              básica del negocio organizada y actualizada en las plataformas de mapas.
            </p>
            <h3 class="font-bold text-heading-1 mb-3">Incluye:</h3>
            <ul class="space-y-2 mb-6">
              {[
                "Revisión mensual básica de Google Business Profile.",
                "Revisión mensual básica de Apple Maps / Apple Business Connect.",
                "Actualización básica de nombre del negocio, teléfono, dirección, horarios, categoría, website o Mini Card, servicios principales y fotos enviadas por el cliente.",
                "Aviso mensual al cliente sobre interacciones relevantes.",
                "Respuesta básica o preparación de respuesta para preguntas públicas simples.",
                "Respuesta básica a reseñas usando tono profesional previamente autorizado por el cliente.",
                "Subida de hasta 2 fotos al mes si el cliente las proporciona.",
                "Actualización de horarios especiales cuando el cliente lo avise con anticipación.",
                "Conexión de Google Maps y Apple Maps con la Mini Card.",
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-heading-2">
                  <span class="text-primary mt-0.5 flex-shrink-0">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-4">
              <p class="text-sm text-amber-800 dark:text-amber-300 leading-relaxed font-medium">
                Este servicio está diseñado para mantenimiento básico de información y presencia en mapas. La
                administración se enfoca en que los datos del negocio estén correctos, visibles y conectados
                con su presencia digital.
              </p>
            </div>
            <h3 class="font-bold text-heading-1 mb-3 text-sm">Servicios disponibles por cotización o add-on:</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
              {[
                "Publicaciones frecuentes",
                "Manejo avanzado de reseñas",
                "Respuestas personalizadas extensas",
                "Campañas promocionales",
                "Fotografías profesionales recurrentes",
                "Estrategia avanzada de posicionamiento local",
                "Administración de redes sociales",
                "Anuncios pagados",
                "Reportes avanzados",
                "Actualizaciones ilimitadas",
                "Cambios urgentes fuera del ciclo mensual",
              ].map((item) => (
                <li class="flex items-start gap-2 text-xs text-heading-3">
                  <span class="text-heading-3 mt-0.5 flex-shrink-0">—</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── TIEMPOS ESTIMADOS ──────────────────────────────────── -->
    <section class="py-10">
      <Container>
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold text-heading-1 mb-6 text-center">Tiempos Estimados</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
            <div class="rounded-xl border border-box-border bg-box-bg p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">🗺️</span>
                <h3 class="font-bold text-heading-1">Google Maps</h3>
              </div>
              <p class="text-sm text-heading-2 leading-relaxed">
                Puede verificarse rápido, incluso el mismo día o aproximadamente en 1 día si la información
                está clara y Google permite una verificación rápida. Sin embargo, la revisión o verificación
                puede tomar varios días hábiles dependiendo de Google.
              </p>
            </div>
            <div class="rounded-xl border border-box-border bg-box-bg p-5">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">🍎</span>
                <h3 class="font-bold text-heading-1">Apple Maps</h3>
              </div>
              <p class="text-sm text-heading-2 leading-relaxed">
                Apple Maps / Apple Business Connect puede tomar hasta 5 días hábiles en revisar, verificar
                o aprobar información.
              </p>
            </div>
          </div>
          <div class="rounded-xl bg-primary/5 border border-primary/20 p-4 text-center">
            <p class="text-sm text-heading-2 leading-relaxed">
              <strong>Importante:</strong> Los tiempos dependen de Google y Apple. Flores Nexus Group ayuda
              con la configuración y seguimiento, pero la aprobación final depende de cada plataforma.
            </p>
          </div>
        </div>
      </Container>
    </section>

    <!-- ── AVISO DE RESULTADOS ────────────────────────────────── -->
    <section class="py-4">
      <Container>
        <div class="max-w-3xl mx-auto rounded-2xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 p-6">
          <p class="text-sm text-amber-900 dark:text-amber-200 leading-relaxed mb-3">
            Flores Nexus Group ayuda a organizar y administrar la presencia digital del negocio. Este servicio
            se enfoca en información clara, presentación profesional, conexión con mapas y facilidad de contacto.
          </p>
          <p class="text-sm font-semibold text-amber-900 dark:text-amber-200 leading-relaxed">
            Flores Nexus Group LLC no garantiza ventas, llamadas, clientes, reseñas, ingresos ni posición en
            Google. Los resultados comerciales dependen de múltiples factores externos y de cada plataforma.
          </p>
        </div>
      </Container>
    </section>

    <!-- ── FORMULARIO GUIADO ──────────────────────────────────── -->
    <section id="formulario" class="py-12">
      <Container>
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-heading-1 mb-3">Información del Negocio</h2>
            <p class="text-heading-3">Complete este formulario con el cliente. Toda la información se enviará a Flores Nexus Group.</p>
          </div>

          <!-- Success message (hidden by default) -->
          <div id="form-success" class="hidden rounded-2xl border border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-900/20 p-8 text-center">
            <div class="text-4xl mb-4">✅</div>
            <h3 class="text-2xl font-bold text-heading-1 mb-3">Información recibida.</h3>
            <p class="text-heading-2 mb-2 text-base leading-relaxed">
              El siguiente paso es completar el pago para activar el servicio.
            </p>
            <p class="text-sm text-heading-3 mb-6 leading-relaxed">
              La producción comienza después del pago y cuando Flores Nexus Group reciba la información completa
              del negocio. Al completar el pago, el cliente acepta los términos, condiciones, alcance del servicio
              y política de pagos de Flores Nexus Group LLC.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a
                href={STRIPE_LINK}
                target="_blank"
                rel="noopener noreferrer"
                class="px-8 py-4 rounded-full bg-primary text-white font-bold text-base hover:bg-blue-800 transition-colors duration-200 text-center"
              >
                Pagar Nexus Local Launch
              </a>
              <a
                href={CUSTOM_PROPOSAL_LINK}
                class="px-8 py-4 rounded-full border-2 border-primary text-primary font-semibold text-base hover:bg-primary/5 transition-colors duration-200 text-center"
              >
                Solicitar propuesta personalizada
              </a>
            </div>
          </div>

          <form
            id="nll-form"
            action={FORMSPREE_ENDPOINT}
            method="POST"
            class="space-y-6"
          >
            <input type="hidden" name="_subject" value="Nuevo formulario guiado - Nexus Local Launch" />

            <!-- SECCIÓN: Datos del vendedor -->
            <div class="rounded-2xl border border-box-border bg-box-bg overflow-hidden">
              <div class="bg-primary/10 dark:bg-primary/20 px-6 py-4 border-b border-box-border">
                <h3 class="font-bold text-heading-1 text-lg">Datos del Vendedor</h3>
              </div>
              <div class="p-6 space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Nombre del vendedor <span class="text-red-500">*</span></label>
                    <input type="text" name="vendedor_nombre" required class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="Nombre completo" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Código del representante</label>
                    <input type="text" name="vendedor_codigo" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="Ej. REP-001" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-heading-2 mb-1.5">Fecha de visita <span class="text-red-500">*</span></label>
                  <input type="date" name="vendedor_fecha" required class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-heading-2 mb-1.5">Tipo de contacto <span class="text-red-500">*</span></label>
                  <select name="vendedor_tipo_contacto" required class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm appearance-none cursor-pointer">
                    <option value="">Seleccionar...</option>
                    <option>Visita en persona</option>
                    <option>Llamada</option>
                    <option>Referido</option>
                    <option>Otro</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- SECCIÓN: Información del negocio -->
            <div class="rounded-2xl border border-box-border bg-box-bg overflow-hidden">
              <div class="bg-primary/10 dark:bg-primary/20 px-6 py-4 border-b border-box-border">
                <h3 class="font-bold text-heading-1 text-lg">Información del Negocio</h3>
              </div>
              <div class="p-6 space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Nombre exacto del negocio <span class="text-red-500">*</span></label>
                    <input type="text" name="negocio_nombre" required class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="Nombre oficial del negocio" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Nombre del dueño o contacto principal <span class="text-red-500">*</span></label>
                    <input type="text" name="negocio_contacto" required class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="Nombre completo" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Teléfono principal <span class="text-red-500">*</span></label>
                    <input type="tel" name="negocio_telefono" required class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="(555) 000-0000" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Email del negocio</label>
                    <input type="email" name="negocio_email" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="negocio@email.com" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">¿Acepta mensajes de texto?</label>
                    <select name="negocio_acepta_sms" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm">
                      <option value="">Seleccionar...</option>
                      <option>Sí</option>
                      <option>No</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">¿Usa WhatsApp?</label>
                    <select name="negocio_usa_whatsapp" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm">
                      <option value="">Seleccionar...</option>
                      <option>Sí</option>
                      <option>No</option>
                    </select>
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-heading-2 mb-1.5">Dirección del negocio</label>
                  <input type="text" name="negocio_direccion" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="Calle, número, suite" />
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                  <div class="sm:col-span-2">
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">Ciudad / Estado</label>
                    <input type="text" name="negocio_ciudad_estado" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="Ciudad, Estado" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">ZIP</label>
                    <input type="text" name="negocio_zip" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm" placeholder="00000" />
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-heading-2 mb-1.5">Horarios</label>
                  <textarea name="negocio_horarios" rows="2" class="form-input resize-none" placeholder="Ej. Lun-Vie 9am-6pm, Sáb 10am-3pm"></textarea>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">¿Tiene dirección física donde los clientes pueden visitar?</label>
                    <select name="negocio_tiene_fisica" class="w-full px-4 py-3 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary text-sm">
                      <option value="">Seleccionar...</option>
                      <option>Sí</option>
                      <option>No</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-heading-2 mb-1.5">¿Quiere mostrar la dirección públicamente?</label>
