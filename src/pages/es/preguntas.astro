---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
---

<Layout title="Preguntas Frecuentes" description="Preguntas frecuentes sobre los planes, precios, propiedad y soporte de Flores Nexus Group." lang="es">
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h1 class="text-4xl font-bold text-heading-1 mb-4">Preguntas Frecuentes</h1>
          <p class="text-heading-3 text-lg">Todo lo que necesitas saber sobre nuestro servicio de paginas web.</p>
        </div>

        <div class="space-y-4">
          {[
            {
              q: "Que cubre la mensualidad?",
              a: "Hosting, administracion tecnica y las actualizaciones incluidas en tu plan seleccionado mientras la suscripcion este activa.",
            },
            {
              q: "Que tipo de cambios puedo solicitar?",
              a: "Nexus Card incluye 0 actualizaciones mensuales. Starter incluye 1 actualizacion pequena al mes. Professional incluye 3 actualizaciones pequenas al mes. Las actualizaciones no se acumulan. Cambios adicionales se cobran por separado.",
            },
            {
              q: "Cuanto tiempo tarda?",
              a: "La entrega estandar es de 3-5 dias habiles despues del pago, aceptacion e informacion completa del negocio.",
            },
            {
              q: "Soy dueno del sitio web?",
              a: "Los planes mensuales son administrados por Flores Nexus. La transferencia de propiedad no esta incluida a menos que sea cotizada, aprobada y comprada por separado.",
            },
            {
              q: "Esto garantiza clientes?",
              a: "No. Flores Nexus no garantiza ventas, leads, llamadas, ingresos, ranking ni resultados comerciales. Proporcionamos una presencia profesional en linea que ayuda a las personas a encontrar, entender, verificar y contactar tu negocio mas facilmente.",
            },
            {
              q: "Necesito un logo?",
              a: "No. Puedes comenzar sin uno. El diseno de logo se puede cotizar como add-on.",
            },
            {
              q: "Puedo subir de plan despues?",
              a: "Si. Puedes subir de plan a medida que tu negocio crece. El credito de upgrade se calcula segun el setup realmente pagado. Un setup promocional de $0 genera $0 de credito.",
            },
            {
              q: "Esta incluido un segundo idioma?",
              a: "Cada plan incluye un idioma principal. Una segunda version completa en otro idioma esta disponible como add-on pagado.",
            },
          ].map((faq) => (
            <details class="group border border-box-border rounded-xl bg-box-bg overflow-hidden">
              <summary class="flex justify-between items-center p-5 cursor-pointer font-semibold text-heading-1 list-none hover:text-primary transition">
                {faq.q}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                </svg>
              </summary>
              <div class="px-5 pb-5 text-heading-3 text-sm leading-relaxed border-t border-box-border pt-4">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </Container>

    <FinalCTA lang="es" />
  </main>
</Layout>
