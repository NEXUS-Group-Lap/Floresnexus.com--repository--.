---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import { ONBOARDING_FORM_LINK } from "../../config/links";
---

<Layout title="Gracias" lang="es">
  <main class="pt-24 pb-20 min-h-screen flex items-center">
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <div class="w-20 h-20 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mx-auto mb-8">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>

        <h1 class="text-4xl font-bold text-heading-1 mb-4">¡Pago Recibido!</h1>
        <p class="text-heading-3 text-lg mb-8 leading-relaxed">
          Pago recibido. El siguiente paso es completar el formulario de onboarding con la información de tu negocio,
          servicios, fotos, número de teléfono, dirección o área de servicio y redes sociales.
          <strong class="text-heading-2">La producción empieza cuando el formulario esté completo.</strong>
        </p>

        <div class="rounded-2xl border border-box-border bg-box-bg p-8 mb-8 text-left">
          <h2 class="font-bold text-heading-1 text-lg mb-4">¿Qué sigue?</h2>
          <ol class="space-y-3">
            {[
              "Completa el formulario de onboarding con todos los detalles de tu negocio.",
              "Nuestro equipo revisa tu información.",
              "Construimos tu página web profesional.",
              "Tú revisas y apruebas antes del lanzamiento.",
              "¡Tu página entra en producción!",
            ].map((step, i) => (
              <li class="flex items-start gap-3 text-heading-2 text-sm">
                <span class="w-6 h-6 rounded-full bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 text-xs font-bold mt-0.5">
                  {i + 1}
                </span>
                {step}
              </li>
            ))}
          </ol>
        </div>

        <a
          href={ONBOARDING_FORM_LINK}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 text-lg"
        >
          Completar Formulario de Onboarding
        </a>

        <p class="text-xs text-heading-3 mt-6">
          ¿Preguntas? Contáctanos en{" "}
          <a href="mailto:floresnexusgroup@gmail.com" class="text-primary hover:underline">
            floresnexusgroup@gmail.com
          </a>
        </p>
      </div>
    </Container>
  </main>
</Layout>
