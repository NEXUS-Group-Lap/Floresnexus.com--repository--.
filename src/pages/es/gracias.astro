---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import { ONBOARDING_FORM_LINK } from "../../config/links";
---

<Layout title="Gracias" lang="es">
  <main class="pt-24 pb-20 min-h-screen flex items-center">
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <div class="w-20 h-20 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mx-auto mb-8">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>

        <h1 id="thank-you-title" class="text-4xl font-bold text-heading-1 mb-4">Pago Recibido</h1>
        <p id="thank-you-message" class="text-heading-3 text-lg mb-8 leading-relaxed">
          Pago recibido. El siguiente paso es completar el formulario de onboarding con la informaciĂłn de tu negocio,
          servicios, fotos, nĂşmero de telĂ©fono, direcciĂłn o Ăˇrea de servicio y redes sociales.
          <strong class="text-heading-2">La producciĂłn empieza cuando el formulario estĂ© completo.</strong>
        </p>

        <div class="rounded-2xl border border-box-border bg-box-bg p-8 mb-8 text-left">
          <h2 class="font-bold text-heading-1 text-lg mb-4">ÂżQuĂ© sigue?</h2>
          <ol class="space-y-3">
            {[
              "Completa el formulario de onboarding con todos los detalles de tu negocio.",
              "Nuestro equipo revisa tu informaciĂłn.",
              "Construimos tu pĂˇgina web profesional.",
              "TĂş revisas y apruebas antes del lanzamiento.",
              "Tu pĂˇgina entra en producciĂłn.",
            ].map((step, i) => (
              <li class="flex items-start gap-3 text-heading-2 text-sm">
                <span class="w-6 h-6 rounded-full bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 text-xs font-bold mt-0.5">
                  {i + 1}
                </span>
                {step}
              </li>
            ))}
          </ol>
        </div>

        <a
          href={ONBOARDING_FORM_LINK}
          class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 text-lg"
        >
          Completar Formulario de Onboarding
        </a>

        <p class="text-xs text-heading-3 mt-6">
          ÂżPreguntas? ContĂˇctanos en{" "}
          <a href="mailto:info@floresnexus.com" class="text-primary hover:underline">
            info@floresnexus.com
          </a>
        </p>
      </div>
    </Container>
  </main>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const type = params.get("type");
  const title = document.getElementById("thank-you-title");
  const message = document.getElementById("thank-you-message");

  if (type === "quote") {
    if (title) title.textContent = "Solicitud de Cotización Recibida";
    if (message) {
      const strong = document.createElement("strong");
      strong.className = "text-heading-2";
      strong.textContent = "No se cobra ningún pago de Stripe para Business System hasta que la cotización sea aprobada.";
      message.replaceChildren(
        document.createTextNode("Tu solicitud de cotización para Business System fue recibida. Un representante de Flores Nexus Group revisará el alcance del proyecto contigo. "),
        strong
      );
    }
  } else if (type === "solicitud") {
    if (title) title.textContent = "Solicitud Recibida";
    if (message) {
      message.textContent = "Gracias. Recibimos tu información. Nuestro equipo revisará tu solicitud y te contactará con el siguiente paso.";
    }
  }
</script>