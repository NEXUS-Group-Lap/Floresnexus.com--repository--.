---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
---

<Layout title="FAQ" description="Frequently asked questions about Flores Nexus Group website plans, pricing, ownership, and support." lang="en">
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h1 class="text-4xl font-bold text-heading-1 mb-4">Frequently Asked Questions</h1>
          <p class="text-heading-3 text-lg">Everything you need to know about our website service.</p>
        </div>

        <div class="space-y-4">
          {[
            {
              q: "What does the monthly fee cover?",
              a: "Hosting, technical management, and the updates included in your selected plan while your subscription is active.",
            },
            {
              q: "What kind of changes can I request?",
              a: "Nexus Card includes 0 monthly updates. Starter includes 1 small update per month. Professional includes 3 small updates per month. Updates do not accumulate. Extra changes are billed separately.",
            },
            {
              q: "How long does it take?",
              a: "Standard delivery is 3–5 business days after payment, acceptance, and complete business information.",
            },
            {
              q: "Do I own the website?",
              a: "Monthly plans are managed by Flores Nexus. Ownership transfer is not included unless separately quoted, approved, and purchased.",
            },
            {
              q: "Does this guarantee customers?",
              a: "No. Flores Nexus does not guarantee sales, leads, calls, revenue, ranking, or business results. We provide a professional online presence that helps people find, understand, verify, and contact your business more easily.",
            },
            {
              q: "Do I need a logo?",
              a: "No. You can start without one. Logo design can be quoted as an add-on.",
            },
            {
              q: "Can I upgrade later?",
              a: "Yes. You can upgrade as your business grows. Upgrade credit is based on the setup amount actually paid. Promotional $0 setup creates $0 setup credit.",
            },
            {
              q: "Is a second language included?",
              a: "Each plan includes one main language. A second full-language version is available as a paid add-on.",
            },
            {
              q: "Is hosting included?",
              a: "Yes. Hosting is included in all plans while the subscription is active. Flores Nexus manages the hosting, so you don't need to purchase or manage it separately.",
            },
            {
              q: "Does my website include a domain name?",
              a: "Nexus Card is published under a managed Flores Nexus route. Starter and Professional include one managed standard domain, subject to availability. Exact domain names are not guaranteed. Domains are administered by Flores Nexus while the subscription is active. Transfer requires a separate process.",
            },
          ].map((faq) => (
            <details class="group border border-box-border rounded-xl bg-box-bg overflow-hidden">
              <summary class="flex justify-between items-center p-5 cursor-pointer font-semibold text-heading-1 list-none hover:text-primary transition">
                {faq.q}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                </svg>
              </summary>
              <div class="px-5 pb-5 text-heading-3 text-sm leading-relaxed border-t border-box-border pt-4">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </Container>

    <FinalCTA lang="en" />
  </main>
</Layout>
