---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/sections/Hero.astro";
import WhatIsAWebsite from "../../components/sections/WhatIsAWebsite.astro";
import Comparison from "../../components/sections/Comparison.astro";
import WhatYouGet from "../../components/sections/WhatYouGet.astro";
import WebExamples from "../../components/sections/WebExamples.astro";
import HowItWorks from "../../components/sections/HowItWorks.astro";
import PromoLaunchOffer from "../../components/sections/PromoLaunchOffer.astro";
import Pricing from "../../components/sections/Pricing.astro";
import BusinessSystemCTA from "../../components/sections/BusinessSystemCTA.astro";
import FAQPreview from "../../components/sections/FAQPreview.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
---

