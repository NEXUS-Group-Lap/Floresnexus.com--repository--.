---

<Layout
  title="Websites for Local Businesses — Flores Nexus Group"
  description="Flores Nexus Group builds and manages websites for local businesses that do great work but need a clearer way to be found, trusted, and contacted online."
  lang="en"
>
  <main class="flex flex-col overflow-hidden">
    <Hero lang="en" />
    <PromoLaunchOffer lang="en" />
    <WhyFloresNexusExists lang="en" />
    <WhatWeDo lang="en" />
    <EverythingWeManage lang="en" />
    <WhoWeHelp lang="en" />
    <WebExamples lang="en" />
    <Comparison lang="en" />
    <Pricing lang="en" />
    <BusinessSystemCTA lang="en" />
    <div class="bg-gray-50 dark:bg-gray-900/30">
      <WhyFloresNexus lang="en" />
    </div>
    <HowItWorks lang="en" />
    <div class="bg-gray-50 dark:bg-gray-900/30">
      <FAQPreview lang="en" />
    </div>
    <FinalCTA lang="en" />
  </main>
</Layout>
