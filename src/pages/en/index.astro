  description="Flores Nexus Group builds and manages websites for local businesses. You give us the info. We handle the technical part."
  lang="en"
>
  <main class="flex flex-col overflow-hidden">
    <Hero lang="en" />
    <WhatIsAWebsite lang="en" />
    <Comparison lang="en" />
    <WhatYouGet lang="en" />
    <WebExamples lang="en" />
    <HowItWorks lang="en" />
    <PromoLaunchOffer lang="en" />
    <Pricing lang="en" />
    <BusinessSystemCTA lang="en" />
    <div class="bg-gray-50 dark:bg-gray-900/30">
      <FAQPreview lang="en" />
    </div>
    <FinalCTA lang="en" />
  </main>
</Layout>
