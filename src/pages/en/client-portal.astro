---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
---

<Layout
  title="Client Portal"
  description="Quick access for active Flores Nexus Group clients."
  lang="en"
>
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-xs font-semibold text-primary uppercase tracking-widest mb-2">Current Clients</p>
          <h1 class="text-4xl font-bold text-heading-1 mb-4">Client <span class="text-primary dark:text-blue-400">Portal</span></h1>
          <p class="text-heading-3 text-lg">
            Quick access to resources for active Flores Nexus Group clients.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
          <a
            href="mailto:info@floresnexus.com?subject=Change%20Request"
            class="rounded-2xl border border-box-border bg-box-bg p-6 text-center hover:border-primary/50 hover:shadow-md transition-all duration-300 group"
          >
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
              </svg>
            </div>
            <h3 class="font-bold text-heading-1 mb-1 text-sm group-hover:text-primary transition-colors">Request a Change</h3>
            <p class="text-xs text-heading-3">Submit a content update or correction.</p>
          </a>

          <a
            href="mailto:info@floresnexus.com?subject=Issue%20Report"
            class="rounded-2xl border border-box-border bg-box-bg p-6 text-center hover:border-primary/50 hover:shadow-md transition-all duration-300 group"
          >
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
              </svg>
            </div>
            <h3 class="font-bold text-heading-1 mb-1 text-sm group-hover:text-primary transition-colors">Report an Issue</h3>
            <p class="text-xs text-heading-3">Report a problem with your website.</p>
          </a>

          <a
            href="/en/service-scope"
            class="rounded-2xl border border-box-border bg-box-bg p-6 text-center hover:border-primary/50 hover:shadow-md transition-all duration-300 group"
          >
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
              </svg>
            </div>
            <h3 class="font-bold text-heading-1 mb-1 text-sm group-hover:text-primary transition-colors">View Service Scope</h3>
            <p class="text-xs text-heading-3">Understand what's included in your plan.</p>
          </a>
        </div>

        <p class="text-xs text-center text-heading-3">
          Questions? Contact us at{" "}
          <a href="mailto:info@floresnexus.com" class="text-primary hover:underline">info@floresnexus.com</a>
        </p>
      </div>
    </Container>
  </main>
</Layout>
