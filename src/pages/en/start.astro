---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import {
  STARTER_STRIPE_LINK,
  PROFESSIONAL_STRIPE_LINK,
  NEXUS_CARD_STRIPE_LINK,
  START_FORM_ENDPOINT,
} from "../../config/links";
import { promoConfig } from "../../data/plans";
---

<Layout
  title="Start Your Website"
  description="Start the process to get your professional website. Fill out this short form and continue to secure payment."
  lang="en"
>
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <h1 class="text-4xl font-bold text-heading-1 mb-3">Start Your <span class="text-primary dark:text-blue-400">Website</span></h1>
          <p class="text-heading-3 text-lg">
            This takes about 2 minutes. After this, you'll continue to secure payment with Stripe.
          </p>
          {promoConfig.active && (
            <div class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-full bg-[#E0EAFF] dark:bg-[#1e3a6e] text-[#1D4ED8] dark:text-blue-300 text-sm font-semibold">
              <span class="w-2 h-2 rounded-full bg-[#2454E6] animate-pulse"></span>
              {promoConfig.en.badge}: Setup $0 for Nexus Card & Starter
            </div>
          )}
        </div>

        <div class="rounded-2xl border border-box-border bg-box-bg p-8">
          <p class="text-xs text-heading-3 mb-6 text-center">Step 1 of 2 — Basic information before payment</p>

          <form
            id="start-form"
            class="space-y-5"
            data-nexus-card={NEXUS_CARD_STRIPE_LINK}
            data-starter={STARTER_STRIPE_LINK}
            data-professional={PROFESSIONAL_STRIPE_LINK}
            data-endpoint={START_FORM_ENDPOINT}
          >
            <!-- Honeypot anti-bot -->
            <div class="absolute -left-[9999px]" aria-hidden="true">
              <label for="website_url">Website</label>
              <input type="text" id="website_url" name="website_url" tabindex="-1" autocomplete="off" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="block text-sm font-semibold text-heading-2 mb-1.5">
                  First Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text" id="firstName" name="firstName" required
                  maxlength="50" autocomplete="given-name"
                  pattern="[A-Za-zÀ-ÿ\s\-']{1,50}"
                  class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                  placeholder="John"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-semibold text-heading-2 mb-1.5">
                  Last Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text" id="lastName" name="lastName" required
                  maxlength="50" autocomplete="family-name"
                  pattern="[A-Za-zÀ-ÿ\s\-']{1,50}"
                  class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                  placeholder="Smith"
                />
              </div>
            </div>

            <!-- Business Name -->
            <div>
              <label for="businessName" class="block text-sm font-semibold text-heading-2 mb-1.5">
                Business Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text" id="businessName" name="businessName" required
                maxlength="100" autocomplete="organization"
                class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                placeholder="Smith's Roofing & Repair"
              />
            </div>

            <!-- Phone + Email -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block text-sm font-semibold text-heading-2 mb-1.5">
                  Phone / WhatsApp <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel" id="phone" name="phone" required
                  maxlength="20" autocomplete="tel"
                  pattern="[\d\s\-\+\(\)]{7,20}"
                  title="Please enter a valid phone number"
                  class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                  placeholder="(555) 000-0000"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-heading-2 mb-1.5">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email" id="email" name="email" required autocomplete="email"
                  class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                  placeholder="john@business.com"
                />
              </div>
            </div>

            <!-- Language -->
            <div>
              <label for="mainLanguage" class="block text-sm font-semibold text-heading-2 mb-1.5">
                Main Language for Your Website <span class="text-red-500">*</span>
              </label>
              <select
                id="mainLanguage" name="mainLanguage" required
                class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
              >
                <option value="en">English</option>
                <option value="es">Spanish</option>
              </select>
              <p class="text-xs text-heading-3 mt-1">Each plan includes 1 language. A second language is a paid add-on.</p>
            </div>

            <!-- Plan + Billing -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="selectedPlan" class="block text-sm font-semibold text-heading-2 mb-1.5">
                  Plan <span class="text-red-500">*</span>
                </label>
                <select
                  id="selectedPlan" name="selectedPlan" required
                  class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                >
                  <option value="">Select a plan</option>
                  <option value="nexus-card">Nexus Card — $29/mo</option>
                  <option value="starter">Starter Website — $79/mo</option>
                  <option value="professional">Professional Website — $149/mo</option>
                  <option value="business-system">Business System — Request Quote</option>
                </select>
              </div>
              <div>
                <label for="billingType" class="block text-sm font-semibold text-heading-2 mb-1.5">
                  Billing <span class="text-red-500">*</span>
                </label>
                <select
                  id="billingType" name="billingType" required
                  class="w-full px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
                >
                  <option value="monthly">Monthly</option>
                  <option value="annual">Annual (prepay option)</option>
                </select>
              </div>
            </div>

            <!-- Plan confirmation -->
            <div id="selected-plan-confirmation" class="hidden rounded-xl border border-primary/20 bg-primary/5 p-4 text-sm text-heading-2 leading-relaxed">
              <span id="selected-plan-label" class="font-semibold text-heading-1"></span>
            </div>

            <!-- Business System notice -->
            <div id="business-quote-notice" class="hidden rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 p-4 text-sm text-amber-800 dark:text-amber-300 leading-relaxed">
              Business System requires a custom quote. By submitting this form, a representative will contact you. No charge until the quote is approved.
            </div>

            <div id="plan-error" class="hidden text-sm text-red-500 text-center">
              Please select a plan to continue.
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full py-3 rounded-full bg-primary text-white font-semibold transition-all duration-300 hover:bg-blue-800 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
            >
              <span id="submit-btn-text">Continue to Secure Payment</span>
            </button>

            <p class="text-xs text-center text-heading-3" id="submit-footer-note">
              Secure payment with Stripe. We never see your card information.
            </p>
          </form>
        </div>
      </div>
    </Container>
  </main>
</Layout>

<script>
  const form = document.getElementById("start-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const submitBtnText = document.getElementById("submit-btn-text");
  const submitFooterNote = document.getElementById("submit-footer-note");
  const planSelect = document.getElementById("selectedPlan") as HTMLSelectElement | null;
  const planError = document.getElementById("plan-error");
  const businessNotice = document.getElementById("business-quote-notice");
  const selectedPlanConfirmation = document.getElementById("selected-plan-confirmation");
  const selectedPlanLabel = document.getElementById("selected-plan-label");

  const planLabels: Record<string, string> = {
    "nexus-card": "Nexus Card — $0 setup (promo) + $29/month",
    "starter": "Starter Website — $0 setup (promo) + $79/month",
    "professional": "Professional Website — $699 setup + $149/month",
    "business-system": "Business System — Custom Quote",
  };

  const urlParams = new URLSearchParams(window.location.search);
  const planParam = urlParams.get("plan");
  if (planParam && planSelect && planLabels[planParam]) {
    planSelect.value = planParam;
    updatePlanDisplay(planParam);
  }

  function updatePlanDisplay(plan: string) {
    const isQuote = plan === "business-system";
    const hasPlan = Boolean(planLabels[plan]);
    if (businessNotice) businessNotice.classList.toggle("hidden", !isQuote);
    if (selectedPlanConfirmation) selectedPlanConfirmation.classList.toggle("hidden", !hasPlan);
    if (selectedPlanLabel) selectedPlanLabel.textContent = hasPlan ? planLabels[plan] : "";
    if (submitBtnText) submitBtnText.textContent = isQuote ? "Request Quote" : "Continue to Secure Payment";
    if (submitFooterNote) {
      submitFooterNote.textContent = isQuote
        ? "A representative will contact you. No charge until the quote is approved."
        : "Secure payment with Stripe. We never see your card information.";
    }
  }

  if (planSelect) {
    planSelect.addEventListener("change", () => updatePlanDisplay(planSelect.value));
  }

  let lastSubmitTime = 0;

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const honeypot = (document.getElementById("website_url") as HTMLInputElement)?.value;
      if (honeypot) return;

      const now = Date.now();
      if (now - lastSubmitTime < 5000) return;
      lastSubmitTime = now;

      const plan = planSelect?.value ?? "";

      if (!plan) {
        planError?.classList.remove("hidden");
        return;
      }
      planError?.classList.add("hidden");

      if (submitBtn) {
        submitBtn.disabled = true;
        if (submitBtnText) submitBtnText.textContent = "Submitting...";
      }

      const formData = new FormData(form);
      formData.delete("website_url");
      const endpoint = form.dataset.endpoint;

      if (endpoint && endpoint !== "#") {
        try {
          const res = await fetch(endpoint, {
            method: "POST",
            body: formData,
            headers: { Accept: "application/json" },
          });
          if (!res.ok) throw new Error("submit failed");
        } catch (_) {
          if (submitBtn) {
            submitBtn.disabled = false;
            if (submitBtnText) submitBtnText.textContent = "Continue to Secure Payment";
          }
          return;
        }
      }

      const links: Record<string, string> = {
        "nexus-card": form.dataset.nexusCard ?? "#",
        "starter": form.dataset.starter ?? "#",
        "professional": form.dataset.professional ?? "#",
        "business-system": "#",
      };

      const dest = links[plan];
      if (dest && dest !== "#") {
        const email = (document.getElementById("email") as HTMLInputElement)?.value;
        const url = new URL(dest);
        if (email) url.searchParams.set("prefilled_email", email);
        window.location.href = url.toString();
      } else if (plan === "business-system") {
        window.location.href = "/en/thank-you?type=quote&plan=business-system";
      } else {
        window.location.href = "/en/thank-you";
      }
    });
  }
</script>
