---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import AddOns from "../../components/sections/AddOns.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
---

<Layout title="Add-Ons & Extras" description="Optional extras you can add to your Flores Nexus website plan — second language, rush delivery, logo design, and more." lang="en">
  <main class="pt-24 pb-20">
    <section class="py-8 bg-gray-50 dark:bg-gray-900/30">
      <Container>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 max-w-4xl mx-auto">
          <p class="text-heading-2 text-sm font-medium text-center sm:text-left">
            Don't have a plan yet? Choose one first.
          </p>
          <a
            href="/en/pricing"
            class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-primary text-white text-sm font-semibold hover:bg-blue-800 transition-colors duration-200"
          >
            View Plans
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </Container>
    </section>
    <AddOns lang="en" />
    <FinalCTA lang="en" />
  </main>
</Layout>
