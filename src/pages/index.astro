---
import GatewayLayout from "../layouts/GatewayLayout.astro";
---

<GatewayLayout title="Flores Nexus Group">
  <noscript>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </noscript>
  <script is:inline>
    (function () {
      var langs = navigator.languages || [navigator.language || "en"];
      var isSpanish = langs.some(function (l) {
        return l.toLowerCase().startsWith("es");
      });
      window.location.replace(isSpanish ? "/es/" : "/en/");
    })();
  </script>
  <main class="flex-1 flex items-center justify-center px-4">
    <p class="text-heading-3 text-sm">Redirecting…</p>
  </main>
</GatewayLayout>
