---
import Layout from "../../layouts/SellerGateLayout.astro";
import Container from "../../components/shared/Container.astro";
---

<Layout title="Seller Hub — Commissions">
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="mb-2">
          <a href="/seller-hub" class="text-sm text-primary hover:underline">← Seller Hub</a>
        </div>
        <h1 class="text-4xl font-bold text-heading-1 mb-3 mt-4">Seller Commissions</h1>
        <p class="text-heading-3 text-lg mb-10">
          These are the approved commission rates for independent sales representatives of Flores Nexus Group.
          Commissions are not shown on public customer pricing pages.
        </p>

        <div class="overflow-hidden rounded-2xl border border-box-border">
          <table class="w-full">
            <thead class="bg-box-bg border-b border-box-border">
              <tr>
                <th class="p-4 text-left text-heading-2 font-semibold">Plan</th>
                <th class="p-4 text-left text-heading-2 font-semibold">Customer Pays</th>
                <th class="p-4 text-left text-heading-2 font-semibold text-primary">Your Commission</th>
              </tr>
            </thead>
            <tbody>
              {[
                {
                  plan: "Nexus Mini Card",
                  price: "$99 setup + $29/month",
                  commission: "$40 per monthly sale / $60 per annual sale",
                },
                {
                  plan: "Starter Website",
                  price: "$299 setup + $79/month",
                  commission: "$125 per sale",
                },
                {
                  plan: "Professional Website",
                  price: "$699 setup + $149/month",
                  commission: "$250 per sale",
                },
                {
                  plan: "Business System",
                  price: "$2,500+ setup + $399+/month",
                  commission: "10%–15% of setup after approval",
                },
              ].map((row, i) => (
                <tr class={`border-b border-box-border ${i % 2 === 0 ? "bg-box-bg/50" : ""}`}>
                  <td class="p-4 font-semibold text-heading-1">{row.plan}</td>
                  <td class="p-4 text-heading-3 text-sm">{row.price}</td>
                  <td class="p-4 font-bold text-primary">{row.commission}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="mt-8 space-y-4">
          <div class="p-5 rounded-xl border border-box-border bg-box-bg">
            <h3 class="font-bold text-heading-1 mb-2">How Commissions Work</h3>
            <ul class="space-y-2 text-sm text-heading-3">
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold">1.</span>
                You bring a qualified lead through the Start Your Website form or submit it via the Submit Lead page.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold">2.</span>
                The client completes payment through the Stripe link.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold">3.</span>
                Commission is attributed to your representative code and processed after payment clears.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold">4.</span>
                Business System commissions (10%–15%) are calculated after Flores Nexus Group reviews and approves the final quote.
              </li>
            </ul>
          </div>

          <div class="p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800">
            <p class="text-sm text-amber-800 dark:text-amber-300">
              <strong>Commission terms are subject to change.</strong> Always confirm current rates with Flores Nexus Group.
              Commissions must never be mentioned, shown, or explained to clients during the sales process.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </main>
</Layout>
