---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";

const cards = [
  {
    title: "Plans for Sellers",
    desc: "Full plan details, features, and positioning explained for seller conversations.",
    href: "/seller-hub/pricing",
    icon: `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>`,
  },
  {
    title: "Commissions",
    desc: "Your commission rates per plan and how payouts are structured.",
    href: "/seller-hub/commissions",
    icon: `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: "Sales Scripts",
    desc: "Conversation starters, objection handling, and closing scripts.",
    href: "/seller-hub/scripts",
    icon: `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>`,
  },
  {
    title: "Seller Rules",
    desc: "What you can and cannot promise. Read before selling.",
    href: "/seller-hub/rules",
    icon: `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: "Submit a Lead",
    desc: "Submit a qualified lead for tracking and commission attribution.",
    href: "/seller-hub/submit-lead",
    icon: `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>`,
  },
];
---

<Layout title="Seller Hub" lang="en">
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="mb-10">
          <span class="text-xs font-bold uppercase tracking-widest text-primary">Internal</span>
          <h1 class="text-4xl font-bold text-heading-1 mt-2 mb-3">Seller Hub</h1>
          <p class="text-heading-3 text-lg">Resources for Flores Nexus Group independent sales representatives.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cards.map((card) => (
            <a
              href={card.href}
              class="rounded-2xl border border-box-border bg-box-bg p-6 hover:border-primary hover:shadow-md transition-all duration-300 group"
            >
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mb-3">
                <Fragment set:html={card.icon} />
              </div>
              <h3 class="font-bold text-heading-1 text-lg mb-2 group-hover:text-primary transition">{card.title}</h3>
              <p class="text-sm text-heading-3">{card.desc}</p>
            </a>
          ))}
        </div>

        <div class="mt-10 p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800">
          <p class="text-sm text-amber-800 dark:text-amber-300">
            <strong>Reminder:</strong> You are an independent sales representative of Flores Nexus Group, not a W2 employee.
            Review the Seller Rules before any client conversation.
          </p>
        </div>
      </div>
    </Container>
  </main>
</Layout>
