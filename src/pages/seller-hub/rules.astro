---
import Layout from "../../layouts/SellerGateLayout.astro";
import Container from "../../components/shared/Container.astro";
---

<Layout title="Seller Hub — Rules">
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-3xl mx-auto">
        <div class="mb-2">
          <a href="/seller-hub" class="text-sm text-primary hover:underline">← Seller Hub</a>
        </div>
        <h1 class="text-4xl font-bold text-heading-1 mb-3 mt-4">Seller Rules</h1>
        <p class="text-heading-3 text-lg mb-10">
          Read and follow these rules before every client conversation. Violating these rules can result in removal from the seller program.
        </p>

        <div class="space-y-6">
          <div class="rounded-2xl border-2 border-red-300 dark:border-red-800 bg-red-50 dark:bg-red-900/20 p-6">
            <h2 class="font-bold text-red-700 dark:text-red-400 text-xl mb-4">You CANNOT Promise These</h2>
            <ul class="space-y-2">
              {[
                "Sales, leads, calls, or revenue from the website",
                "Google ranking or advanced SEO results",
                "Unlimited edits or changes",
                "Unlimited calls or open-ended support",
                "Social media management (not in base plans)",
                "Ad campaign management",
                "Ownership transfer of the domain or website",
                "Delivery faster than 24–72 hours without complete client information",
                "Any result guarantee of any kind",
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-red-700 dark:text-red-300">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-2xl border border-green-300 dark:border-green-800 bg-green-50 dark:bg-green-900/20 p-6">
            <h2 class="font-bold text-green-700 dark:text-green-400 text-xl mb-4">You CAN Say These</h2>
            <ul class="space-y-2">
              {[
                "We build and manage a professional website for your business",
                "Clients can make it easier for customers to contact you",
                "We provide basic website structure and contact visibility",
                "Site is ready in 24–72 hours after payment and complete client information are received",
                "Updates depend on the selected plan",
                "Hosting is included while the subscription is active",
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-green-700 dark:text-green-300">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-2xl border border-box-border bg-box-bg p-6">
            <h2 class="font-bold text-heading-1 text-xl mb-4">Role Clarity</h2>
            <ul class="space-y-3 text-sm text-heading-2">
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold mt-0.5">→</span>
                You are an <strong>independent sales representative</strong>, not a W2 employee of Flores Nexus Group.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold mt-0.5">→</span>
                Do not represent yourself as an employee, staff member, or part of the Flores Nexus Group internal team.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold mt-0.5">→</span>
                Do not make commitments on behalf of Flores Nexus Group beyond what is described on the public website.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold mt-0.5">→</span>
                Never share commission amounts, internal pricing structures, or seller hub content with clients.
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary font-bold mt-0.5">→</span>
                Always direct the client to complete the Start Your Website form. Do not collect payment yourself.
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </main>
</Layout>
