---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
---

<Layout title="Seller Hub — Plans" lang="en">
  <main class="pt-24 pb-20">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="mb-2">
          <a href="/seller-hub" class="text-sm text-primary hover:underline">← Seller Hub</a>
        </div>
        <h1 class="text-4xl font-bold text-heading-1 mb-3 mt-4">Plans Explained for Sellers</h1>
        <p class="text-heading-3 text-lg mb-10">Use this page to understand each plan so you can explain it clearly to clients.</p>

        <div class="space-y-8">
          {[
            {
              name: "Nexus Mini Card",
              setup: "$99",
              monthly: "$29/month",
              annual: "$299/year",
              badge: "Entry-level / Digital business card only",
              pitch: "Perfect for business owners who just need a professional shareable link — not a full website.",
              includes: [
                "Business name & phone",
                "Call / Text / WhatsApp button",
                "Service area & hours",
                "3–5 services listed",
                "One image or background",
                "Social links",
                "Mobile-friendly design",
                "Hosted on Flores Nexus managed link",
              ],
              important: "This is NOT a full website. After launch, no edits are included except corrections of Flores Nexus errors. Ownership stays with Flores Nexus Group.",
            },
            {
              name: "Starter Website",
              setup: "$299",
              monthly: "$79/month",
              annual: "—",
              badge: "One-page website",
              pitch: "Best for small service businesses that need a simple, clean, and professional online presence.",
              includes: [
                "One-page website",
                "Services section",
                "Call/text button",
                "Google Maps or service area",
                "Social links",
                "Mobile-friendly design",
                "Hosting included",
                "One pre-launch revision",
              ],
              important: "Does NOT include unlimited edits, advanced SEO, support calls, marketing, or social media management.",
            },
            {
              name: "Professional Website",
              setup: "$699",
              monthly: "$149/month",
              annual: "—",
              badge: "Recommended — Up to 5 pages",
              pitch: "Best for service businesses that need a complete, professional presentation online. This is the plan to lead with.",
              includes: [
                "Up to 5 pages: Home, Services, About, Gallery, Contact",
                "Basic contact form",
                "Google Maps or service area",
                "Basic copywriting",
                "Mobile-friendly design",
                "Hosting included",
                "One small update per month",
              ],
              important: "Small update = one photo swap, one text correction, phone/hours update, or one link update. New pages, CRM, booking, and redesigns are NOT included.",
            },
            {
              name: "Business System",
              setup: "$2,500+",
              monthly: "$399+/month",
              annual: "Custom",
              badge: "Custom quote only — DO NOT use Stripe checkout",
              pitch: "For advanced clients who need booking, payments, CRM, automations, or multiple locations. Always route to Request Quote.",
              includes: [
                "Advanced quote forms",
                "Booking systems",
                "Online payments",
                "CRM or email integration",
                "Email automation",
                "Landing pages",
                "Analytics",
                "Multiple locations",
                "External integrations",
              ],
              important: "NEVER offer a fixed price for this plan. Always say: 'This requires a custom quote from our team.' Never use a direct Stripe payment link for this plan.",
            },
          ].map((plan) => (
            <div class="rounded-2xl border border-box-border bg-box-bg p-6">
              <div class="flex flex-wrap justify-between items-start gap-3 mb-4">
                <div>
                  <h2 class="text-2xl font-bold text-heading-1">{plan.name}</h2>
                  <span class="text-sm text-primary font-medium">{plan.badge}</span>
                </div>
                <div class="text-right">
                  <p class="text-xl font-bold text-heading-1">{plan.setup} <span class="text-sm font-normal text-heading-3">setup</span></p>
                  <p class="text-primary font-semibold">{plan.monthly}</p>
                  {plan.annual !== "—" && <p class="text-xs text-heading-3">{plan.annual} annual option</p>}
                </div>
              </div>

              <div class="bg-primary/5 rounded-xl p-4 mb-4">
                <p class="text-sm font-semibold text-heading-2">Seller pitch:</p>
                <p class="text-sm text-heading-3 mt-1 italic">"{plan.pitch}"</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <p class="text-xs font-bold uppercase tracking-wide text-heading-3 mb-2">Includes</p>
                  <ul class="space-y-1">
                    {plan.includes.map((item) => (
                      <li class="flex items-start gap-2 text-sm text-heading-2">
                        <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-4">
                  <p class="text-xs font-bold uppercase tracking-wide text-amber-700 dark:text-amber-400 mb-2">Important for sellers</p>
                  <p class="text-sm text-amber-800 dark:text-amber-300">{plan.important}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </main>
</Layout>
