---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Why Flores Nexus Group",
    subtitle: "We handle everything so you can focus on running your business.",
    features: [
      {
        title: "Built and Managed by Us",
        desc: "We handle the technical side.",
      },
      {
        title: "Designed for Phones",
        desc: "The experience adapts to mobile devices.",
      },
      {
        title: "Clear, Predictable Pricing",
        desc: "Setup fee and monthly subscription based on your plan.",
      },
    ],
  },
  es: {
    title: "Por Qué Flores Nexus Group",
    subtitle: "Nos encargamos de todo para que tú puedas enfocarte en tu negocio.",
    features: [
      {
        title: "Construido y Administrado por Nosotros",
        desc: "Nos encargamos de la parte técnica.",
      },
      {
        title: "Diseñado para Teléfonos",
        desc: "La experiencia se adapta a dispositivos móviles.",
      },
      {
        title: "Precio Claro y Predecible",
        desc: "Configuración inicial y mensualidad según el plan.",
      },
    ],
  },
}[lang];

const featureIcons = [
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852z"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 15h3"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6" data-stagger>
      {t.features.map((feature, i) => (
        <div class="p-6 rounded-2xl border border-box-border bg-box-bg hover:border-primary/50 hover:shadow-md transition-all duration-300 motion-card">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
            <Fragment set:html={featureIcons[i]} />
          </div>
          <h3 class="font-bold text-heading-1 text-lg mb-2">{feature.title}</h3>
          <p class="text-heading-3 text-sm leading-relaxed">{feature.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
