---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Why Flores Nexus Group",
    subtitle: "We handle everything so you can focus on running your business.",
    positioning: "Built for you. Managed for you. Without agency prices.",
    features: [
      {
        title: "We Build It",
        desc: "You provide your business information and we build your professional website. No technical skills required.",
      },
      {
        title: "We Host It",
        desc: "Your website is hosted and maintained by us for as long as your subscription is active. Nothing to manage on your end.",
      },
      {
        title: "Mobile-First Design",
        desc: "Every website we deliver is designed for mobile devices first, so your customers can find and contact you easily.",
      },
      {
        title: "Clear Contact Options",
        desc: "Call, text, WhatsApp, and contact form buttons built in so customers can reach you the way they prefer.",
      },
      {
        title: "Simple Monthly Pricing",
        desc: "No surprise bills, no hourly rates. One setup fee and a predictable monthly subscription.",
      },
      {
        title: "Local Service Area",
        desc: "Google Maps integration or service area display so customers know you serve their location.",
      },
    ],
  },
  es: {
    title: "Por Que Flores Nexus Group",
    subtitle: "Nos encargamos de todo para que tu puedas enfocarte en tu negocio.",
    positioning: "Hechas por nosotros. Administradas por nosotros. Sin precios de agencia.",
    features: [
      {
        title: "Nosotros la Construimos",
        desc: "Tu nos das la informacion de tu negocio y nosotros construimos tu pagina profesional. No necesitas conocimientos tecnicos.",
      },
      {
        title: "Nosotros la Alojamos",
        desc: "Tu pagina esta alojada y mantenida por nosotros mientras tu suscripcion este activa. No tienes que manejar nada.",
      },
      {
        title: "Diseno Mobile-First",
        desc: "Cada pagina que entregamos esta disenada primero para dispositivos moviles, para que tus clientes te encuentren facilmente.",
      },
      {
        title: "Opciones de Contacto Claras",
        desc: "Botones de llamada, texto, WhatsApp y formulario de contacto integrados para que los clientes te contacten como prefieran.",
      },
      {
        title: "Precios Mensuales Simples",
        desc: "Sin facturas sorpresa, sin tarifas por hora. Un costo inicial y una suscripcion mensual predecible.",
      },
      {
        title: "Area de Servicio Local",
        desc: "Integracion con Google Maps o visualizacion del area de servicio para que los clientes sepan que los cubres.",
      },
    ],
  },
}[lang];

const featureIcons = [
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a4.5 4.5 0 01-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 11-3.586-3.586l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 016.336-4.486l-3.276 3.276a3.004 3.004 0 002.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852z"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 15h3"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  `<svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto mb-4">{t.subtitle}</p>
      <p class="text-primary font-semibold text-lg shine-text">{t.positioning}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
      {t.features.map((feature, i) => (
        <div class="p-6 rounded-2xl border border-box-border bg-box-bg hover:border-primary/50 hover:shadow-md transition-all duration-300 motion-card">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
            <Fragment set:html={featureIcons[i]} />
          </div>
          <h3 class="font-bold text-heading-1 text-lg mb-2">{feature.title}</h3>
          <p class="text-heading-3 text-sm leading-relaxed">{feature.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
