---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Agency vs. Flores Nexus Group",
    subtitle: "Get a professional website without the agency overhead.",
    agencyLabel: "Traditional Agency",
    fngLabel: "Flores Nexus Group",
    rows: [
      { label: "Setup cost", agency: "$5,000 – $30,000+", fng: "$99 – $699" },
      { label: "Monthly cost", agency: "$500 – $3,000+", fng: "$29 – $149/month" },
      { label: "Time to launch", agency: "6 – 12 weeks", fng: "3–5 business days after complete info" },
      { label: "Who manages it", agency: "You coordinate everything", fng: "We handle it" },
      { label: "Hosting", agency: "Extra or included in high retainer", fng: "Included" },
      { label: "Updates", agency: "Hourly rate or monthly retainer", fng: "1–3 per month by plan, extra billed separately" },
      { label: "Contract", agency: "Long-term contracts typical", fng: "Simple monthly subscription" },
      { label: "Target customer", agency: "Medium to large businesses", fng: "Local service businesses" },
      { label: "Public directory listing", agencyNegative: "Not included", fng: "Included for active clients" },
    ],
  },
  es: {
    title: "Agencia vs. Flores Nexus Group",
    subtitle: "Obtén una página web profesional sin los costos de una agencia.",
    agencyLabel: "Agencia Tradicional",
    fngLabel: "Flores Nexus Group",
    rows: [
      { label: "Costo inicial", agency: "$5,000 – $30,000+", fng: "$99 – $699" },
      { label: "Costo mensual", agency: "$500 – $3,000+", fng: "$29 – $149/mes" },
      { label: "Tiempo de lanzamiento", agency: "6 – 12 semanas", fng: "3–5 días hábiles con info completa" },
      { label: "¿Quién lo administra?", agency: "Tú coordinas todo", fng: "Nosotros lo manejamos" },
      { label: "Hosting", agency: "Costo extra o en retainer alto", fng: "Incluido" },
      { label: "Actualizaciones", agency: "Tarifa por hora o retainer mensual", fng: "1–3 al mes según plan, extra se cotiza aparte" },
      { label: "Contrato", agency: "Contratos a largo plazo típicos", fng: "Suscripción mensual simple" },
      { label: "Cliente objetivo", agency: "Negocios medianos y grandes", fng: "Negocios locales de servicios" },
      { label: "Listado en directorio público", agencyNegative: "No incluido", fng: "Incluido para clientes activos" },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-box-border motion-card" data-reveal="scale">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-box-bg border-b border-box-border">
            <th class="p-4 text-left text-heading-3 font-medium w-1/3"></th>
            <th class="p-4 text-center text-heading-2 font-semibold w-1/3">
              {t.agencyLabel}
            </th>
            <th class="p-4 text-center font-semibold w-1/3 bg-primary/5 text-primary">
              {t.fngLabel}
            </th>
          </tr>
        </thead>
        <tbody data-stagger>
          {t.rows.map((row, i) => (
            <tr class={`border-b border-box-border ${i % 2 === 0 ? "bg-box-bg" : ""}`}>
              <td class="p-4 font-medium text-heading-2">{row.label}</td>
              <td class="p-4 text-center text-heading-3">
                <span class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                  {row.agencyNegative ?? row.agency}
                </span>
              </td>
              <td class="p-4 text-center bg-primary/5 font-medium text-heading-1">
                <span class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {row.fng}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Container>
</section>
