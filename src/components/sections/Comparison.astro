---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Why Not Just Use Facebook?",
    subtitle: "You can stay on social media only. But here's what you're missing.",
    col1Label: "Only Facebook / WhatsApp",
    col2Label: "With Flores Nexus",
    rows: [
      { label: "Can customers find you easily?", col1: "Hard — depends on what Facebook shows", col2: "Yes, you have your own place on the internet" },
      { label: "Does it look professional?", col1: "Informal — looks like every other page", col2: "Professional — designed for your business" },
      { label: "Do you control your info?", col1: "Facebook decides what people see", col2: "It's your space, you decide what's there" },
      { label: "How much does it cost?", col1: "\"Free\" — but you lose customers who can't find you", col2: "From $29/month" },
      { label: "Who maintains it?", col1: "You (if you have time)", col2: "We do — you don't touch anything technical" },
      { label: "Is it always available?", col1: "Only if Facebook wants", col2: "Always — your page is always active" },
      { label: "Can you customize it?", col1: "Limited to what Facebook allows", col2: "Yes, designed for your business" },
      { label: "Do you need to know technology?", col1: "You need to learn some things", col2: "No — we handle everything" },
    ],
  },
  es: {
    title: "¿Por Qué No Solo Usar Facebook?",
    subtitle: "Puedes quedarte solo con redes sociales. Pero esto es lo que te pierdes.",
    col1Label: "Solo Facebook / WhatsApp",
    col2Label: "Con Flores Nexus",
    rows: [
      { label: "¿Te encuentran fácil?", col1: "Difícil — depende de lo que Facebook muestre", col2: "Sí, tienes tu propio lugar en internet" },
      { label: "¿Se ve profesional?", col1: "Informal — se ve como cualquier otra página", col2: "Profesional — diseñado para tu negocio" },
      { label: "¿Controlas tu información?", col1: "Facebook decide qué ven las personas", col2: "Es tu espacio, tú decides qué hay" },
      { label: "¿Cuánto cuesta?", col1: "\"Gratis\" — pero pierdes clientes que no te encuentran", col2: "Desde $29/mes" },
      { label: "¿Quién lo mantiene?", col1: "Tú (si tienes tiempo)", col2: "Nosotros — tú no tocas nada técnico" },
      { label: "¿Está siempre disponible?", col1: "Solo si Facebook quiere", col2: "Siempre — tu página está siempre activa" },
      { label: "¿Puedes personalizarlo?", col1: "Limitado a lo que Facebook permite", col2: "Sí, diseñado para tu negocio" },
      { label: "¿Necesitas saber de tecnología?", col1: "Necesitas aprender algunas cosas", col2: "No — nosotros hacemos todo" },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-box-border motion-card" data-reveal="scale">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-box-bg border-b border-box-border">
            <th class="p-4 text-left text-heading-3 font-medium w-1/3"></th>
            <th class="p-4 text-center text-heading-2 font-semibold w-1/3">
              {t.col1Label}
            </th>
            <th class="p-4 text-center font-semibold w-1/3 bg-primary/5 text-primary">
              {t.col2Label}
            </th>
          </tr>
        </thead>
        <tbody data-stagger>
          {t.rows.map((row, i) => (
            <tr class={`border-b border-box-border ${i % 2 === 0 ? "bg-box-bg" : ""}`}>
              <td class="p-4 font-medium text-heading-2">{row.label}</td>
              <td class="p-4 text-center text-heading-3">
                <span class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-red-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                  {row.col1}
                </span>
              </td>
              <td class="p-4 text-center bg-primary/5 font-medium text-heading-1">
                <span class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {row.col2}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Container>
</section>
