---
import Container from "../shared/Container.astro";
import { promoConfig } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const promo = promoConfig[lang];

const t = {
  en: {
    title: "Ready to put your business on the internet?",
    subtitle: "You don't need to know technology. We take care of everything.",
    cta1: "View Plans",
    cta1Href: "/en/pricing",
    cta2: promoConfig.active ? "Start Now — Setup $0" : "Get Started",
    cta2Href: "/en/start",
  },
  es: {
    title: "¿Listo para poner tu negocio en internet?",
    subtitle: "No necesitas saber de tecnología. Nosotros nos encargamos de todo.",
    cta1: "Ver Planes",
    cta1Href: "/es/precios",
    cta2: promoConfig.active ? "Empezar Ahora — Inicial $0" : "Comenzar",
    cta2Href: "/es/empezar",
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center max-w-2xl mx-auto" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">{t.title}</h2>
      <p class="text-lg text-heading-3 mb-8">{t.subtitle}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-stagger>
        <a
          href={t.cta1Href}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full border-2 border-box-border text-heading-2 font-semibold hover:border-primary hover:text-primary transition-all duration-300 motion-button"
        >
          {t.cta1}
        </a>
        <a
          href={t.cta2Href}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-green-600 text-white font-semibold hover:bg-green-700 transition-all duration-300 motion-button"
        >
          {t.cta2}
        </a>
      </div>
    </div>
  </Container>
</section>
