---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Choose the right solution for your business",
    subtitle: "Start with a simple option and expand your presence when you need to.",
    cta1: "View Plans",
    cta1Href: "/en/pricing",
    cta2: "Get Started",
    cta2Href: "/en/start",
  },
  es: {
    title: "Elige la solución adecuada para tu negocio",
    subtitle: "Empieza con una opción simple y amplía tu presencia cuando lo necesites.",
    cta1: "Ver Planes",
    cta1Href: "/es/precios",
    cta2: "Comenzar",
    cta2Href: "/es/empezar",
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center max-w-2xl mx-auto" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">{t.title}</h2>
      <p class="text-lg text-heading-3 mb-8">{t.subtitle}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-stagger>
        <a
          href={t.cta1Href}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full border-2 border-box-border text-heading-2 font-semibold hover:border-primary hover:text-primary transition-all duration-300 motion-button"
        >
          {t.cta1}
        </a>
        <a
          href={t.cta2Href}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 motion-button"
        >
          {t.cta2}
        </a>
      </div>
    </div>
  </Container>
</section>
