---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Your local business deserves to look professional online.",
    subtitle: "Without agency prices.",
    cta1: "Start My Website",
    cta1Href: "/en/start",
    cta2: "View Plans",
    cta2Href: "/en/pricing",
    quote: "Request Quote",
    quoteHref: "/en/start",
    quoteNote: "Need something more advanced? Start with a quote request.",
  },
  es: {
    title: "Tu negocio merece verse profesional en internet.",
    subtitle: "Sin precios de agencia.",
    cta1: "Empezar Mi Página",
    cta1Href: "/es/empezar",
    cta2: "Ver Planes",
    cta2Href: "/es/precios",
    quote: "Solicitar Cotización",
    quoteHref: "/es/empezar",
    quoteNote: "¿Necesitas algo más avanzado? Empieza con una solicitud de cotización.",
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center max-w-2xl mx-auto" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">{t.title}</h2>
      <p class="text-2xl font-semibold text-primary mb-8 shine-text">{t.subtitle}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6" data-stagger>
        <a
          href={t.cta1Href}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 motion-button"
        >
          {t.cta1}
        </a>
        <a
          href={t.cta2Href}
          class="inline-flex items-center justify-center px-8 py-3 rounded-full border-2 border-box-border text-heading-2 font-semibold hover:border-primary hover:text-primary transition-all duration-300 motion-button"
        >
          {t.cta2}
        </a>
      </div>

      <p class="text-sm text-heading-3">
        {t.quoteNote}{" "}
        <a href={t.quoteHref} class="text-primary hover:underline font-medium">{t.quote}</a>
      </p>
    </div>
  </Container>
</section>
