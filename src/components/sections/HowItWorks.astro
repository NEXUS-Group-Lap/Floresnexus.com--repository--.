---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "How It Works",
    subtitle: "5 simple steps. You give us the info. We do the rest.",
    steps: [
      { number: "1", title: "Choose a plan", time: "2 min", desc: "Pick the plan that fits your business." },
      { number: "2", title: "Send your business info", time: "15–30 min", desc: "Complete the form and pay. Then send photos, services, hours, and location." },
      { number: "3", title: "We create your page", time: "3–5 days", desc: "3–5 business days after payment and complete info." },
      { number: "4", title: "We publish it online", time: "Same day", desc: "Your business is now on the internet." },
      { number: "5", title: "We keep it active for you", time: "Ongoing", desc: "We keep your page active while your plan is active." },
    ],
  },
  es: {
    title: "Cómo Funciona",
    subtitle: "5 pasos simples. Tú nos das la información. Nosotros hacemos el resto.",
    steps: [
      { number: "1", title: "Elige un plan", time: "2 min", desc: "Selecciona el plan que se adapte a tu negocio." },
      { number: "2", title: "Envía la información de tu negocio", time: "15–30 min", desc: "Completa el formulario y paga. Luego envía fotos, servicios, horario y ubicación." },
      { number: "3", title: "Creamos tu página", time: "3–5 días", desc: "3–5 días hábiles después del pago y la información completa." },
      { number: "4", title: "La publicamos en internet", time: "Mismo día", desc: "Tu negocio ya está en internet." },
      { number: "5", title: "La mantenemos activa por ti", time: "Continuo", desc: "Mantenemos tu página activa mientras tu plan esté activo." },
    ],
  },
}[lang];
---

<section class="py-16" id={lang === "en" ? "how-it-works" : "como-funciona"}>
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">
        {lang === "en"
          ? <Fragment>How It <span class="text-primary dark:text-blue-400">Works</span></Fragment>
          : <Fragment>Cómo <span class="text-primary dark:text-blue-400">Funciona</span></Fragment>
        }
      </h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="max-w-3xl mx-auto space-y-4" data-stagger>
      {t.steps.map((step, i) => (
        <div class="flex items-start gap-4 p-5 rounded-2xl border border-box-border bg-box-bg hover:border-primary/50 transition-all motion-card">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center">
              <span class="text-white font-bold text-sm">{step.number}</span>
            </div>
            {i < t.steps.length - 1 && (
              <div class="w-0.5 h-4 bg-primary/20 mt-2"></div>
            )}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-1">
              <h3 class="font-bold text-heading-1 text-base">{step.title}</h3>
              <span class="inline-block px-2 py-0.5 rounded-full bg-primary/10 text-primary text-xs font-semibold">
                {step.time}
              </span>
            </div>
            <p class="text-heading-3 text-sm leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
