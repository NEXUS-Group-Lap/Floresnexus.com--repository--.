---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "This Is How It Works",
    subtitle: "It's easier than you think. Your total time: less than 1 hour. We do the rest.",
    steps: [
      { number: "1", title: "Choose a plan", time: "2 min", desc: "Pick the plan that fits your business." },
      { number: "2", title: "Fill out the short form", time: "1 min", desc: "Name, business, phone, email, and plan." },
      { number: "3", title: "Complete payment", time: "1 min", desc: "Secure payment through Stripe. We never see your card." },
      { number: "4", title: "Send us your business info", time: "15–30 min", desc: "What you sell, where you are, photos if you have them. Without complete info, the clock doesn't start." },
      { number: "5", title: "We build your site", time: "3–5 days", desc: "3–5 business days AFTER we have everything." },
      { number: "6", title: "You review it", time: "5 min", desc: "We show you the result and you tell us if you want changes (1 or 2 rounds depending on your plan)." },
      { number: "7", title: "We publish it", time: "Same day", desc: "Your business is now on the internet. We keep it running." },
    ],
  },
  es: {
    title: "Así Funciona",
    subtitle: "Es más fácil de lo que crees. Tu tiempo total: menos de 1 hora. Nosotros hacemos el resto.",
    steps: [
      { number: "1", title: "Elige tu plan", time: "2 min", desc: "Selecciona el plan que se adapte a tu negocio." },
      { number: "2", title: "Llena el formulario corto", time: "1 min", desc: "Nombre, negocio, teléfono, email y plan." },
      { number: "3", title: "Realiza el pago", time: "1 min", desc: "Pago seguro con Stripe. Nunca vemos tu tarjeta." },
      { number: "4", title: "Danos la información de tu negocio", time: "15–30 min", desc: "Qué vendes, dónde estás, fotos si tienes. Sin info completa, el reloj no corre." },
      { number: "5", title: "Nosotros creamos tu espacio", time: "3–5 días", desc: "3–5 días hábiles DESPUÉS de tener toda tu info." },
      { number: "6", title: "Lo revisas", time: "5 min", desc: "Te lo mostramos y nos dices si quieres cambiar algo (1 o 2 rondas según tu plan)." },
      { number: "7", title: "Lo publicamos", time: "Mismo día", desc: "Tu negocio ya está en internet. Nosotros lo mantenemos." },
    ],
  },
}[lang];
---

<section class="py-16" id={lang === "en" ? "how-it-works" : "como-funciona"}>
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="max-w-3xl mx-auto space-y-4" data-stagger>
      {t.steps.map((step, i) => (
        <div class="flex items-start gap-4 p-5 rounded-2xl border border-box-border bg-box-bg hover:border-primary/50 transition-all motion-card">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center">
              <span class="text-white font-bold text-sm">{step.number}</span>
            </div>
            {i < t.steps.length - 1 && (
              <div class="w-0.5 h-4 bg-primary/20 mt-2"></div>
            )}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-1">
              <h3 class="font-bold text-heading-1 text-base">{step.title}</h3>
              <span class="inline-block px-2 py-0.5 rounded-full bg-primary/10 text-primary text-xs font-semibold">
                {step.time}
              </span>
            </div>
            <p class="text-heading-3 text-sm leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
