---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "How It Works",
    subtitle: "From choosing a plan to launching your website — here's the simple process.",
    note: "Standard delivery is 3–5 business days after payment and after we receive all the necessary information.",
    steps: [
      {
        number: "01",
        title: "Choose a Solution",
        desc: "Select the plan that fits your business.",
      },
      {
        number: "02",
        title: "Send Your Information and Pay",
        desc: "Fill out the form and use the official checkout.",
      },
      {
        number: "03",
        title: "We Adapt, Review, and Publish",
        desc: "We build the site, send it for review, and publish after receiving complete information.",
      },
    ],
  },
  es: {
    title: "Cómo Funciona",
    subtitle: "Desde elegir un plan hasta el lanzamiento de tu página — aquí está el proceso simple.",
    note: "La entrega estándar es de 3–5 días hábiles después del pago y de recibir toda la información necesaria.",
    steps: [
      {
        number: "01",
        title: "Elige una Solución",
        desc: "Selecciona el plan adecuado para tu negocio.",
      },
      {
        number: "02",
        title: "Envía tu Información y Realiza el Pago",
        desc: "Completa el formulario y utiliza el checkout oficial.",
      },
      {
        number: "03",
        title: "Adaptamos, Revisamos y Publicamos",
        desc: "Construimos el sitio, enviamos revisión y publicamos después de recibir la información completa.",
      },
    ],
  },
}[lang];
---

<section class="py-16" id={lang === "en" ? "how-it-works" : "como-funciona"}>
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6" data-stagger>
      {t.steps.map((step, i) => (
        <div class="relative p-6 rounded-2xl border border-box-border bg-box-bg hover:border-primary/50 transition-all motion-card">
          <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center mb-4">
            <span class="text-white font-bold text-sm">{step.number}</span>
          </div>
          <h3 class="font-bold text-heading-1 text-lg mb-2">{step.title}</h3>
          <p class="text-heading-3 text-sm leading-relaxed">{step.desc}</p>
          {i < t.steps.length - 1 && (
            <div class="hidden lg:block absolute top-1/2 -right-3 w-6 h-0.5 bg-primary/30 z-10 draw-line"></div>
          )}
        </div>
      ))}
    </div>

    <div class="mt-8 p-4 rounded-xl bg-primary/5 border border-primary/20 text-center max-w-2xl mx-auto motion-card" data-reveal="scale">
      <p class="text-sm text-heading-2 font-medium">
        {t.note}
      </p>
    </div>
  </Container>
</section>
