---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "What Flores Nexus Group Is Not",
    subtitle: "Understanding the scope of this service helps set clear expectations before and after purchase.",
    items: [
      "Not a guaranteed sales or lead generation service — business results depend on market demand, reputation, and service quality.",
      "Not an unlimited support or unlimited edits agency — changes follow the scope defined per plan.",
      "Not a social media management service in base plans — available as a separate quote.",
      "Not an advanced SEO campaign service unless separately quoted.",
      "Not a guarantee of Google ranking or search visibility.",
      "Not an automatic ownership transfer service — files, code, design, and domain remain managed by Flores Nexus Group unless separately purchased or approved in writing.",
      "Not a traditional agency — a managed Website-as-a-Service provider for local service businesses.",
    ],
  },
  es: {
    title: "Lo Que Flores Nexus Group No Es",
    subtitle: "Entender el alcance del servicio ayuda a establecer expectativas claras antes y después de la compra.",
    items: [
      "No es un servicio que garantice ventas o leads — los resultados dependen de la demanda del mercado, reputación y calidad del servicio.",
      "No es una agencia de soporte ilimitado ni ediciones ilimitadas — los cambios siguen el alcance definido por plan.",
      "No incluye manejo de redes sociales en los planes base — disponible mediante cotización separada.",
      "No incluye campañas avanzadas de SEO salvo cotización separada.",
      "No garantiza ranking en Google ni visibilidad en búsquedas.",
      "No incluye transferencia automática de propiedad — archivos, código, diseño y dominio permanecen administrados por Flores Nexus Group salvo compra o aprobación por escrito.",
      "No es una agencia tradicional — es un proveedor de Website-as-a-Service para negocios locales.",
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-8" data-reveal>
        <h2 class="text-2xl md:text-3xl font-bold text-heading-1 mb-3">{t.title}</h2>
        <p class="text-heading-3">{t.subtitle}</p>
      </div>

      <div class="rounded-2xl border border-box-border bg-box-bg p-6 md:p-8 motion-card" data-reveal="scale">
        <ul class="space-y-3" data-stagger>
          {t.items.map((item) => (
            <li class="flex items-start gap-3 text-heading-2 text-sm">
              <svg class="w-5 h-5 text-heading-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</section>
