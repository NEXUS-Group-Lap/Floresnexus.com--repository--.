---
import Container from "../shared/Container.astro";
import { plans } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;
const plan = plans["local-presence"];
const copy = plan[lang];

const t = {
  en: {
    badge: "Launch Offer",
    phaseNote: "Phase 1 launch offer. Details may be adjusted as this option grows.",
    promo: "Initial Google Business Profile and Apple Business Connect setup is included during the launch promotion.",
    includesLabel: "Includes",
    setupLabel: "setup",
    monthLabel: "/month",
  },
  es: {
    badge: "Oferta de lanzamiento",
    phaseNote: "Oferta de lanzamiento de Fase 1. Los detalles pueden ajustarse conforme esta opción crece.",
    promo: "La configuración inicial de Google Business Profile y Apple Business Connect está incluida durante la promoción de lanzamiento.",
    includesLabel: "Incluye",
    setupLabel: "inicial",
    monthLabel: "/mes",
  },
}[lang];
---

<section class="py-10" id="local-presence">
  <Container>
    <div class="rounded-2xl border-2 border-primary/30 bg-box-bg overflow-hidden max-w-4xl mx-auto motion-card" data-reveal="scale">
      <div class="flex flex-col md:flex-row">
        <!-- Left info column -->
        <div class="md:w-2/5 bg-gradient-to-br from-primary/10 to-blue-400/5 p-8 flex flex-col justify-between" data-reveal="left">
          <div>
            <span class="text-xs font-semibold text-primary uppercase tracking-widest mb-3 block">
              {t.badge}
            </span>
            <h3 class="text-2xl font-bold text-heading-1 mb-2">{copy.name}</h3>
            <p class="text-heading-3 text-sm mb-3 leading-relaxed">{copy.tagline}</p>

            <div class="mb-4">
              <p class="text-2xl font-bold text-heading-1">{plan.setup} {t.setupLabel}</p>
              <p class="text-primary font-semibold">{plan.monthly}{t.monthLabel}</p>
            </div>

            <div class="flex flex-col gap-2">
              <a
                href={plan.startForm[lang]}
                class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 text-sm motion-button"
              >
                {copy.cta}
              </a>
              <a
                href={plan.detailsHref[lang]}
                class="inline-flex items-center justify-center px-6 py-3 rounded-full border-2 border-box-border text-heading-2 font-semibold hover:border-primary hover:text-primary transition-all duration-300 text-sm motion-button"
              >
                {copy.detailsCta}
              </a>
            </div>
          </div>
        </div>

        <!-- Right details column -->
        <div class="md:w-3/5 p-8" data-reveal="right">
          <h4 class="font-semibold text-heading-1 mb-4 text-sm uppercase tracking-wide">
            {t.includesLabel}
          </h4>
          <ul class="space-y-2 mb-6" data-stagger>
            {copy.includes?.map((item) => (
              <li class="flex items-start gap-2 text-sm text-heading-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <div class="border-t border-box-border pt-4 space-y-1">
            <p class="text-xs text-heading-3 leading-relaxed italic">{t.promo}</p>
            <p class="text-xs text-heading-3 leading-relaxed">{t.phaseNote}</p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
