---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Want to Grow? Upgrade Anytime",
    subtitle: "Move to a bigger plan when your business needs it.",
    setupLabel: "Setup difference",
    monthlyLabel: "New monthly",
    promoTag: "Promo",
    note: "A promotional $0 setup does NOT create upgrade credit. For example, Nexus Card promo → Professional pays the full $699 setup.",
    noteLabel: "Important:",
    upgrades: [
      { from: "Nexus Card", to: "Starter", setup: "$200", monthly: "$79/mo", promo: false },
      { from: "Nexus Card", to: "Professional", setup: "$600", monthly: "$149/mo", promo: false },
      { from: "Starter", to: "Professional", setup: "$400", monthly: "$149/mo", promo: false },
      { from: "Nexus Card", to: "Professional", setup: "$699", monthly: "$149/mo", promo: true },
      { from: "Starter", to: "Professional", setup: "$699", monthly: "$149/mo", promo: true },
    ],
  },
  es: {
    title: "¿Quieres Crecer? Sube de Plan Cuando Quieras",
    subtitle: "Cambia a un plan más grande cuando tu negocio lo necesite.",
    setupLabel: "Diferencia inicial",
    monthlyLabel: "Nueva mensualidad",
    promoTag: "Promo",
    note: "Un setup promocional de $0 NO genera crédito de upgrade. Por ejemplo, Nexus Card promo → Professional paga los $699 completos.",
    noteLabel: "Importante:",
    upgrades: [
      { from: "Nexus Card", to: "Starter", setup: "$200", monthly: "$79/mes", promo: false },
      { from: "Nexus Card", to: "Professional", setup: "$600", monthly: "$149/mes", promo: false },
      { from: "Starter", to: "Professional", setup: "$400", monthly: "$149/mes", promo: false },
      { from: "Nexus Card", to: "Professional", setup: "$699", monthly: "$149/mes", promo: true },
      { from: "Starter", to: "Professional", setup: "$699", monthly: "$149/mes", promo: true },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid gap-3 max-w-3xl mx-auto" data-stagger>
      {t.upgrades.map((row) => (
        <div class="rounded-xl border border-box-border bg-box-bg p-4 sm:p-5 motion-card flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
          <div class="flex items-center gap-2.5 sm:min-w-[220px]">
            <span class="text-sm font-semibold text-heading-2">{row.from}</span>
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            <span class="text-sm font-bold text-heading-1">{row.to}</span>
            {row.promo && (
              <span class="text-[10px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded-full bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">
                {t.promoTag}
              </span>
            )}
          </div>
          <div class="flex items-center gap-4 sm:gap-6 sm:ml-auto">
            <div>
              <p class="text-[10px] uppercase tracking-wide text-heading-3 mb-0.5">{t.setupLabel}</p>
              <p class="text-sm font-bold text-primary">{row.setup}</p>
            </div>
            <div class="w-px h-8 bg-box-border hidden sm:block"></div>
            <div>
              <p class="text-[10px] uppercase tracking-wide text-heading-3 mb-0.5">{t.monthlyLabel}</p>
              <p class="text-sm font-semibold text-heading-1">{row.monthly}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-2xl mx-auto mt-6">
      <div class="inline-flex items-start gap-2 px-5 py-3 rounded-xl border border-yellow-500/30 bg-yellow-50 dark:bg-yellow-900/10 text-left">
        <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm text-heading-2">
          <span class="font-semibold">{t.noteLabel}</span> {t.note}
        </p>
      </div>
    </div>
  </Container>
</section>
