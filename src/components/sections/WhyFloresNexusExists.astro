---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;

const t = {
  en: {
    title: "Why Flores Nexus Exists",
    p1: "Many local businesses do great work. But their customers can't find them because they only exist on social media or by word of mouth.",
    p2: "A website gives your business one clear place to show what you do, where you are, and how to contact you.",
    p3: "Flores Nexus creates websites for local businesses. Simple, clear, and at a fair price.",
  },
  es: {
    title: "Por Qué Existe Flores Nexus",
    p1: "Muchos negocios locales hacen un gran trabajo. Pero sus clientes no los encuentran porque solo existen en redes sociales o por recomendación.",
    p2: "Una página web le da a tu negocio un lugar claro para mostrar qué haces, dónde estás y cómo contactarte.",
    p3: "Flores Nexus crea páginas web para negocios locales. Simple, claro y a un precio justo.",
  },
}[lang];
---

<section class="py-16 lg:py-24">
  <Container>
    <div class="max-w-3xl mx-auto text-center" data-reveal>
      <h2 class="text-3xl sm:text-4xl font-bold text-heading-1 mb-8" data-reveal>
        {t.title}
      </h2>
      <p class="text-lg text-heading-2 leading-relaxed mb-6" data-reveal style="--reveal-delay: 80ms">
        {t.p1}
      </p>
      <p class="text-lg text-heading-2 leading-relaxed mb-6" data-reveal style="--reveal-delay: 160ms">
        {t.p2}
      </p>
      <p class="text-lg text-heading-2 leading-relaxed font-medium" data-reveal style="--reveal-delay: 240ms">
        {t.p3}
      </p>
    </div>
  </Container>
</section>
