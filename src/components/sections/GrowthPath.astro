---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;

const t = {
  en: {
    title: "Your Site Can Grow With You",
    subtitle: "Start with what your business needs today. Upgrade when your business needs more space, more content, or more functionality.",
    steps: ["Nexus Card", "Starter Website", "Professional Website", "Business System"],
    note: "Upgrade credit is based on the setup amount actually paid. Promotional $0 setup creates $0 setup credit.",
    noteLabel: "Important:",
  },
  es: {
    title: "Tu Sitio Puede Crecer Contigo",
    subtitle: "Empieza con lo que tu negocio necesita hoy. Sube de plan cuando necesites más espacio, más contenido o más funciones.",
    steps: ["Nexus Card", "Starter Website", "Professional Website", "Business System"],
    note: "El crédito de upgrade se calcula según el setup realmente pagado. Un setup promocional de $0 genera $0 de crédito de setup.",
    noteLabel: "Importante:",
  },
}[lang];
---

<section class="py-16 lg:py-24">
  <Container>
    <div class="max-w-3xl mx-auto text-center" data-reveal>
      <h2 class="text-3xl sm:text-4xl font-bold text-heading-1 mb-4">
        {t.title}
      </h2>
      <p class="text-lg text-heading-2 mb-10 leading-relaxed">
        {t.subtitle}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-0 mb-10" data-stagger>
        {t.steps.map((step, i) => (
          <div class="flex items-center gap-3">
            <div class="px-4 py-2.5 rounded-xl border border-box-border bg-box-bg text-sm font-semibold text-heading-1 whitespace-nowrap">
              {step}
            </div>
            {i < t.steps.length - 1 && (
              <svg class="w-5 h-5 text-primary flex-shrink-0 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
              <svg class="w-5 h-5 text-primary flex-shrink-0 sm:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </div>
        ))}
      </div>

      <div class="inline-flex items-start gap-2 px-5 py-3 rounded-xl border border-yellow-500/30 bg-yellow-50 dark:bg-yellow-900/10 text-left">
        <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm text-heading-2">
          <span class="font-semibold">{t.noteLabel}</span> {t.note}
        </p>
      </div>
    </div>
  </Container>
</section>
