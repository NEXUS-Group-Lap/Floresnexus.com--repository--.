---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Common Questions",
    viewAll: "View All FAQs",
    viewAllHref: "/en/faq",
    faqs: [
      {
        q: "What does the monthly fee cover?",
        a: "Hosting, technical management, and the updates included in your selected plan while your subscription is active.",
      },
      {
        q: "What kind of changes can I request?",
        a: "Nexus Card includes 0 monthly updates. Starter includes 1 small update per month. Professional includes 3 small updates per month. Updates do not accumulate. Extra changes are billed separately.",
      },
      {
        q: "How long does it take?",
        a: "Standard delivery is 3–5 business days after payment, acceptance, and complete business information.",
      },
      {
        q: "Does this guarantee customers?",
        a: "No. Flores Nexus does not guarantee sales, leads, calls, revenue, ranking, or business results. We provide a professional online presence that helps people find, understand, verify, and contact your business more easily.",
      },
    ],
  },
  es: {
    title: "Preguntas Frecuentes",
    viewAll: "Ver Todas las Preguntas",
    viewAllHref: "/es/preguntas",
    faqs: [
      {
        q: "¿Qué cubre la mensualidad?",
        a: "Hosting, administración técnica y las actualizaciones incluidas en tu plan seleccionado mientras la suscripción esté activa.",
      },
      {
        q: "¿Qué tipo de cambios puedo solicitar?",
        a: "Nexus Card incluye 0 actualizaciones mensuales. Starter incluye 1 actualización pequeña al mes. Professional incluye 3 actualizaciones pequeñas al mes. Las actualizaciones no se acumulan. Cambios adicionales se cobran por separado.",
      },
      {
        q: "¿Cuánto tiempo tarda?",
        a: "La entrega estándar es de 3–5 días hábiles después del pago, aceptación e información completa del negocio.",
      },
      {
        q: "¿Esto garantiza clientes?",
        a: "No. Flores Nexus no garantiza ventas, leads, llamadas, ingresos, ranking ni resultados comerciales. Proporcionamos una presencia profesional en línea que ayuda a las personas a encontrar, entender, verificar y contactar tu negocio más fácilmente.",
      },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1">{t.title}</h2>
      <a
        href={t.viewAllHref}
        class="text-primary font-semibold hover:underline flex items-center gap-1 text-sm flex-shrink-0 motion-button rounded-full px-3 py-2"
      >
        {t.viewAll}
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>

    <div class="space-y-4 max-w-3xl" data-stagger>
      {t.faqs.map((faq) => (
        <details class="group border border-box-border rounded-xl bg-box-bg overflow-hidden motion-card">
          <summary class="flex justify-between items-center p-5 cursor-pointer font-semibold text-heading-1 list-none hover:text-primary transition">
            {faq.q}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
            </svg>
          </summary>
          <div class="px-5 pb-5 text-heading-3 text-sm leading-relaxed border-t border-box-border pt-4">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </Container>
</section>
