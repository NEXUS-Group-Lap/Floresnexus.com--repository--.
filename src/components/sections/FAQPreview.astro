---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Common Questions",
    viewAll: "View All FAQs",
    viewAllHref: "/en/faq",
    faqs: [
      {
        q: "What does the monthly fee cover?",
        a: "The monthly fee covers hosting, maintenance, and the updates included with your plan while your subscription is active.",
      },
      {
        q: "What kind of changes can I request?",
        a: "Changes depend on the plan. Professional Website includes up to 3 small updates per month, non-accumulative. Starter Website includes 1 small update per month, non-accumulative. Other changes are billed separately through the Change Request Form.",
      },
      {
        q: "How does the domain work?",
        a: "We search for the best available standard domain for your business — .com, .co, or .net. We cannot guarantee an exact domain name as it may already be taken or require a premium purchase. The site and domain remain managed by Flores Nexus Group while your subscription is active. If no standard option is acceptable, we will discuss alternatives with you before launch.",
      },
      {
        q: "When does production start?",
        a: "Production starts after we receive payment and your complete business information through the corresponding form.",
      },
    ],
  },
  es: {
    title: "Preguntas Frecuentes",
    viewAll: "Ver Todas las Preguntas",
    viewAllHref: "/es/preguntas",
    faqs: [
      {
        q: "¿Qué cubre la mensualidad?",
        a: "La mensualidad cubre el hosting, el mantenimiento y las actualizaciones incluidas según tu plan mientras la suscripción esté activa.",
      },
      {
        q: "¿Qué tipo de cambios puedo solicitar?",
        a: "Los cambios dependen del plan. Professional Website incluye hasta 3 actualizaciones pequeñas al mes, no acumulables. Starter Website incluye 1 actualización pequeña al mes, no acumulable. Otros cambios se cobran por separado a través del Formulario de Solicitud de Cambio.",
      },
      {
        q: "¿Cómo funciona el dominio?",
        a: "Buscamos el mejor dominio estándar disponible para tu negocio — .com, .co o .net. No podemos garantizar el nombre exacto, ya que puede estar tomado o requerir un costo premium. El sitio y el dominio permanecen administrados por Flores Nexus Group mientras la suscripción esté activa. Si ninguna opción estándar es aceptable, lo discutiremos contigo antes del lanzamiento.",
      },
      {
        q: "¿Cuándo comienza la producción?",
        a: "La producción comienza después de recibir el pago y toda la información completa del negocio a través del formulario correspondiente.",
      },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1">{t.title}</h2>
      <a
        href={t.viewAllHref}
        class="text-primary font-semibold hover:underline flex items-center gap-1 text-sm flex-shrink-0 motion-button rounded-full px-3 py-2"
      >
        {t.viewAll}
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>

    <div class="space-y-4 max-w-3xl" data-stagger>
      {t.faqs.map((faq) => (
        <details class="group border border-box-border rounded-xl bg-box-bg overflow-hidden motion-card">
          <summary class="flex justify-between items-center p-5 cursor-pointer font-semibold text-heading-1 list-none hover:text-primary transition">
            {faq.q}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
            </svg>
          </summary>
          <div class="px-5 pb-5 text-heading-3 text-sm leading-relaxed border-t border-box-border pt-4">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </Container>
</section>
