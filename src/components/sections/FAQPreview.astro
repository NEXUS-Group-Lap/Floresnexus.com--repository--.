---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Common Questions",
    viewAll: "View All Questions",
    viewAllHref: "/en/faq",
    faqs: [
      {
        q: "Do I need to know about technology?",
        a: "No. We handle all the technical parts. You just give us your business info.",
      },
      {
        q: "Does this guarantee me more sales?",
        a: "No. A website helps present your business. But it does not guarantee sales.",
      },
      {
        q: "When will my page be ready?",
        a: "3–5 business days after payment and complete info. Without complete info, the clock doesn't start.",
      },
      {
        q: "Can I request changes?",
        a: "Yes, depending on your plan. Nexus Card: 0 changes. Starter: 1 small change per month. Professional: up to 3 small changes per month.",
      },
    ],
  },
  es: {
    title: "Preguntas Frecuentes",
    viewAll: "Ver Todas las Preguntas",
    viewAllHref: "/es/preguntas",
    faqs: [
      {
        q: "¿Tengo que saber de tecnología?",
        a: "No. Nosotros hacemos toda la parte técnica. Tú solo nos das la información de tu negocio.",
      },
      {
        q: "¿Esto me garantiza más ventas?",
        a: "No. Una página web ayuda a presentar tu negocio. Pero no garantiza ventas.",
      },
      {
        q: "¿Cuándo estará lista mi página?",
        a: "En 3–5 días hábiles después del pago y la información completa. Sin información completa, el reloj no corre.",
      },
      {
        q: "¿Puedo pedir cambios?",
        a: "Sí, según el plan. Nexus Card: 0 cambios. Starter: 1 cambio pequeño al mes. Professional: hasta 3 cambios pequeños al mes.",
      },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-3" data-stagger>
      {t.faqs.map((faq) => (
        <details class="rounded-xl border border-box-border bg-box-bg overflow-hidden motion-card group">
          <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-heading-1 font-semibold text-sm hover:bg-primary/5 transition-colors list-none">
            {faq.q}
            <svg class="w-5 h-5 text-heading-3 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-5 pb-4 text-heading-3 text-sm leading-relaxed border-t border-box-border pt-3">
            {faq.a}
          </div>
        </details>
      ))}
    </div>

    <div class="text-center mt-8" data-reveal>
      <a href={t.viewAllHref} class="inline-flex items-center gap-2 text-primary font-semibold hover:underline text-sm">
        {t.viewAll} →
      </a>
    </div>
  </Container>
</section>
