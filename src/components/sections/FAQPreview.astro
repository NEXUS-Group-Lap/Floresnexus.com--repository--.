---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Common Questions",
    viewAll: "View All Questions",
    viewAllHref: "/en/faq",
    faqs: [
      {
        q: "Do I need to know anything about computers?",
        a: "No. We do everything technical. You just give us your business information.",
      },
      {
        q: "Can I cancel whenever I want?",
        a: "Yes, with no penalty. Just let us know and we stop charging the next month. No minimum contract.",
      },
      {
        q: "Do you guarantee I'll get more customers?",
        a: "No. We give you a professional space on the internet so people can find you and contact you. Whether you sell more depends on your product, your service, and your effort.",
      },
      {
        q: "How long does it take to have my site ready?",
        a: "3-5 business days AFTER you give us all your complete information. If you don't send everything, the clock doesn't start.",
      },
    ],
  },
  es: {
    title: "Preguntas Frecuentes",
    viewAll: "Ver Todas las Preguntas",
    viewAllHref: "/es/preguntas",
    faqs: [
      {
        q: "¿Necesito saber de computación?",
        a: "No. Nosotros hacemos todo lo técnico. Tú solo nos das la información de tu negocio.",
      },
      {
        q: "¿Puedo cancelar cuando quiera?",
        a: "Sí, sin penalización. Solo nos avisas y dejamos de cobrar el siguiente mes. No hay contrato mínimo.",
      },
      {
        q: "¿Prometen que voy a vender más?",
        a: "No. Nosotros te damos un espacio profesional en internet para que te encuentren y contacten. Que vendas más depende de tu producto, tu atención al cliente y tu esfuerzo.",
      },
      {
        q: "¿Cuánto tiempo toma tener mi sitio listo?",
        a: "3-5 días hábiles DESPUÉS de que nos des toda tu información completa. Si no nos mandas todo, el reloj no corre.",
      },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-3" data-stagger>
      {t.faqs.map((faq) => (
        <details class="rounded-xl border border-box-border bg-box-bg overflow-hidden motion-card group">
          <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-heading-1 font-semibold text-sm hover:bg-primary/5 transition-colors list-none">
            {faq.q}
            <svg class="w-5 h-5 text-heading-3 flex-shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-5 pb-4 text-heading-3 text-sm leading-relaxed border-t border-box-border pt-3">
            {faq.a}
          </div>
        </details>
      ))}
    </div>

    <div class="text-center mt-8" data-reveal>
      <a href={t.viewAllHref} class="inline-flex items-center gap-2 text-primary font-semibold hover:underline text-sm">
        {t.viewAll} →
      </a>
    </div>
  </Container>
</section>
