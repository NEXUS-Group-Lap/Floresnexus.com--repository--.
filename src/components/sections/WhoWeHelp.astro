---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Who We Help",
    subtitle: "We create websites for local service businesses of all kinds.",
    industries: [
      "Landscaping", "Cleaning Services", "Restaurants",
      "Barber Shops", "Beauty Salons", "Contractors",
      "Handyman", "Local Shops", "Family Businesses",
    ],
    closing: "We also work with other types of local businesses.",
  },
  es: {
    title: "A Quiénes Ayudamos",
    subtitle: "Creamos páginas web para negocios locales de todo tipo.",
    industries: [
      "Landscaping", "Limpieza", "Restaurantes",
      "Barberías", "Salones de Belleza", "Contratistas",
      "Handyman", "Comercios Locales", "Negocios Familiares",
    ],
    closing: "También trabajamos con otros tipos de negocios locales.",
  },
}[lang];

const doubled = [...t.industries, ...t.industries];
---

<section class="py-16" id={lang === "en" ? "industries" : "industrias"}>
  <Container>
    <div class="text-center mb-8" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>
  </Container>

  <div class="relative overflow-hidden py-2">
    <div class="marquee-track flex gap-3">
      {doubled.map((name) => (
        <span class="flex-shrink-0 px-4 py-2.5 rounded-full border border-box-border bg-box-bg text-sm font-semibold text-heading-2 whitespace-nowrap select-none">
          {name}
        </span>
      ))}
    </div>
  </div>

  <Container>
    <p class="text-center text-sm text-heading-3 mt-6" data-reveal>{t.closing}</p>
  </Container>
</section>

<style>
  .marquee-track {
    width: max-content;
    animation: marquee-scroll 26s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; flex-wrap: wrap; width: 100%; padding: 0 1rem; }
  }
</style>
