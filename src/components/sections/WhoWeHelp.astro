---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Who We Help",
    subtitle: "We build websites for local service businesses across every industry.",
    industries: [
      "Roofing", "Cleaning", "Lawn Care", "Handyman", "Barbers",
      "Food Trucks", "Mobile Mechanics", "Local Contractors",
      "Small Service Businesses", "Painters", "Pressure Washing", "Photographers",
    ],
  },
  es: {
    title: "A Quiénes Ayudamos",
    subtitle: "Construimos páginas web para negocios locales de servicios en todas las industrias.",
    industries: [
      "Roofing", "Limpieza", "Jardinería", "Handyman", "Barberos",
      "Food Trucks", "Mecánicos Móviles", "Contratistas Locales",
      "Negocios de Servicios", "Pintores", "Pressure Washing", "Fotógrafos",
    ],
  },
}[lang];

const doubled = [...t.industries, ...t.industries];
---

<section class="py-14" id={lang === "en" ? "services" : "servicios"}>
  <Container>
    <div class="text-center mb-8" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>
  </Container>

  <div class="relative overflow-hidden py-2">
    <div class="marquee-track flex gap-3">
      {doubled.map((name) => (
        <span class="flex-shrink-0 px-4 py-2.5 rounded-full border border-box-border bg-box-bg text-sm font-semibold text-heading-2 whitespace-nowrap select-none">
          {name}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    width: max-content;
    animation: marquee-scroll 26s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; flex-wrap: wrap; width: 100%; padding: 0 1rem; }
  }
</style>
