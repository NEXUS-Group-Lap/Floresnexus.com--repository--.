---
import Container from "../shared/Container.astro";
import { CONTACT_EMAIL } from "../../config/links";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const ADDON_FORM_ENDPOINT = "https://formspree.io/f/mnjknelk";

const t = {
  en: {
    title: "Extras You Can Add",
    subtitle: "These are optional. Add them when you need them.",
    note: "Add-ons are NOT included in the Launch Offer (PROMO-01). They are quoted and paid separately.",
    priceLabel: "Price",
    requestBtn: "Request",
    modalTitle: "Request an Add-On",
    modalDesc: "Tell us which extra you need. We'll review your request and send you a payment link.",
    nameLabel: "Your Name",
    emailLabel: "Email",
    addonLabel: "Add-On",
    planLabel: "Your Current Plan",
    notesLabel: "Notes (optional)",
    notesPlaceholder: "Any details about what you need…",
    submitBtn: "Send Request",
    submittingBtn: "Sending…",
    successMsg: "Request sent! We'll follow up within 1 business day.",
    errorMsg: "Something went wrong. Please try again or email us.",
    cancelBtn: "Cancel",
    planOptions: ["Nexus Card", "Starter Website", "Professional Website", "Business System", "Not a client yet"],
    addons: [
      { name: "Second language — Nexus Card", price: "$49 + $9/month (or $99/year)", forWho: "If your customers speak another language" },
      { name: "Second language — Starter", price: "$149 + $19/month (or $199/year)", forWho: "If your customers speak another language" },
      { name: "Second language — Professional", price: "$349 + $39/month (or $399/year)", forWho: "If your customers speak another language" },
      { name: "Google Maps & Apple Maps setup", price: "$50 (one-time)", forWho: "So customers can find you on maps" },
      { name: "Professional business email", price: "$75 (one-time)", forWho: "To look more professional (e.g. info@yourbusiness.com)" },
      { name: "Extra small change", price: "$29 each", forWho: "If you need more changes than your plan includes" },
      { name: "Monthly pack of 3 extra changes", price: "$49/month", forWho: "Starter/Professional only" },
      { name: "Additional page (Professional only)", price: "$149 each", forWho: "Maximum 2 additional pages" },
      { name: "External tool connection", price: "$99 per tool", forWho: "Button, link, or standard embed" },
      { name: "Rush delivery", price: "$99 / $149 / $349", forWho: "If you need your site faster (subject to availability)" },
      { name: "Domain change", price: "$75 + domain cost", forWho: "If you want to change your web address" },
      { name: "Additional domain", price: "$35 + annual cost", forWho: "Redirects to your main address" },
      { name: "Domain transfer assistance", price: "$75 + fees", forWho: "Transfer of the domain (not the site)" },
      { name: "Full site ownership transfer", price: "Custom quote", forWho: "Separate service — not a plan upgrade" },
      { name: "Logo design", price: "Custom quote", forWho: "Not unlimited branding — scoped design" },
    ],
  },
  es: {
    title: "Extras Que Puedes Agregar",
    subtitle: "Son opcionales. Agrégalos cuando los necesites.",
    note: "Los extras NO están incluidos en la Oferta de Lanzamiento (PROMO-01). Se cotizan y pagan por separado.",
    priceLabel: "Precio",
    requestBtn: "Solicitar",
    modalTitle: "Solicitar un Extra",
    modalDesc: "Dinos qué extra necesitas. Revisaremos tu solicitud y te enviaremos un enlace de pago.",
    nameLabel: "Tu Nombre",
    emailLabel: "Correo Electrónico",
    addonLabel: "Extra",
    planLabel: "Tu Plan Actual",
    notesLabel: "Notas (opcional)",
    notesPlaceholder: "Detalles sobre lo que necesitas…",
    submitBtn: "Enviar Solicitud",
    submittingBtn: "Enviando…",
    successMsg: "¡Solicitud enviada! Te contactaremos en 1 día hábil.",
    errorMsg: "Algo salió mal. Intenta de nuevo o escríbenos por correo.",
    cancelBtn: "Cancelar",
    planOptions: ["Nexus Card", "Starter Website", "Professional Website", "Business System", "Aún no soy cliente"],
    addons: [
      { name: "Segundo idioma — Nexus Card", price: "$49 + $9/mes (o $99/año)", forWho: "Si tus clientes hablan otro idioma" },
      { name: "Segundo idioma — Starter", price: "$149 + $19/mes (o $199/año)", forWho: "Si tus clientes hablan otro idioma" },
      { name: "Segundo idioma — Professional", price: "$349 + $39/mes (o $399/año)", forWho: "Si tus clientes hablan otro idioma" },
      { name: "Configuración de Google Maps y Apple Maps", price: "$50 (único)", forWho: "Para que te encuentren en mapas" },
      { name: "Correo profesional del negocio", price: "$75 (único)", forWho: "Para verte más profesional (ej: info@tunegocio.com)" },
      { name: "Cambio pequeño extra", price: "$29 c/u", forWho: "Si necesitas más cambios de los incluidos" },
      { name: "Paquete mensual de 3 cambios extra", price: "$49/mes", forWho: "Solo Starter/Professional" },
      { name: "Página adicional (solo Professional)", price: "$149 c/u", forWho: "Máximo 2 páginas adicionales" },
      { name: "Conexión con herramienta externa", price: "$99/herramienta", forWho: "Botón, enlace o embed estándar" },
      { name: "Entrega rápida", price: "$99 / $149 / $349", forWho: "Si necesitas tu sitio antes de tiempo (sujeto a disponibilidad)" },
      { name: "Cambio de dirección web", price: "$75 + costo del dominio", forWho: "Si quieres cambiar tu dirección en internet" },
      { name: "Dirección web adicional", price: "$35 + costo anual", forWho: "Redirección a dirección principal" },
      { name: "Asistencia para transferencia de dominio", price: "$75 + fees", forWho: "Transferencia del dominio (no del sitio)" },
      { name: "Transferencia de propiedad del sitio", price: "Cotización", forWho: "Servicio separado, no es upgrade de plan" },
      { name: "Diseño de logo", price: "Cotización", forWho: "No es branding ilimitado — diseño con alcance definido" },
    ],
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">
        {lang === "en"
          ? <Fragment><span class="text-primary dark:text-blue-400">Extras</span> You Can Add</Fragment>
          : <Fragment><span class="text-primary dark:text-blue-400">Extras</span> Que Puedes Agregar</Fragment>
        }
      </h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="max-w-4xl mx-auto space-y-3" data-stagger>
      {t.addons.map((addon, i) => (
        <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 p-4 rounded-xl border border-box-border bg-box-bg motion-card">
          <div class="flex-1 min-w-0">
            <p class="font-medium text-heading-1 text-sm">{addon.name}</p>
            <p class="text-xs text-heading-3 mt-0.5">{addon.forWho}</p>
          </div>
          <p class="text-primary font-semibold text-sm whitespace-nowrap">{addon.price}</p>
          <button
            type="button"
            data-addon-request={addon.name}
            class="inline-flex items-center justify-center px-4 py-2 rounded-full border-2 border-primary text-primary text-xs font-semibold hover:bg-primary hover:text-white transition-colors duration-200 cursor-pointer whitespace-nowrap flex-shrink-0"
          >
            {t.requestBtn}
          </button>
        </div>
      ))}
    </div>

    <p class="text-center text-xs text-heading-3 mt-6 max-w-2xl mx-auto italic">{t.note}</p>
  </Container>

  <!-- Request Modal -->
  <div
    id="addon-modal"
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="addon-modal-title"
  >
    <div class="w-full max-w-md rounded-2xl border border-box-border bg-[rgb(var(--color-bg))] shadow-2xl p-6 sm:p-8 relative">
      <button
        type="button"
        id="addon-modal-close"
        class="absolute top-4 right-4 text-heading-3 hover:text-heading-1 transition-colors cursor-pointer"
        aria-label="Close"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <h3 id="addon-modal-title" class="text-lg font-bold text-heading-1 mb-1">{t.modalTitle}</h3>
      <p class="text-xs text-heading-3 mb-6">{t.modalDesc}</p>

      <form id="addon-form" class="space-y-4" data-endpoint={ADDON_FORM_ENDPOINT}>
        <input type="hidden" name="_subject" value="Add-On Request" />
        <input type="hidden" name="formType" value="addon-request" />
        <input type="hidden" name="language" value={lang} />

        <div>
          <label for="addon-name" class="block text-xs font-semibold text-heading-2 mb-1">{t.nameLabel}</label>
          <input
            type="text" id="addon-name" name="name" required maxlength="80"
            class="w-full px-3 py-2 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
          />
        </div>

        <div>
          <label for="addon-email" class="block text-xs font-semibold text-heading-2 mb-1">{t.emailLabel}</label>
          <input
            type="email" id="addon-email" name="email" required
            class="w-full px-3 py-2 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
          />
        </div>

        <div>
          <label for="addon-selected" class="block text-xs font-semibold text-heading-2 mb-1">{t.addonLabel}</label>
          <input
            type="text" id="addon-selected" name="addon" required readonly
            class="w-full px-3 py-2 rounded-xl border border-box-border bg-box-bg text-heading-1 text-sm cursor-default"
          />
        </div>

        <div>
          <label for="addon-plan" class="block text-xs font-semibold text-heading-2 mb-1">{t.planLabel}</label>
          <select
            id="addon-plan" name="currentPlan" required
            class="w-full px-3 py-2 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm"
          >
            <option value="">—</option>
            {t.planOptions.map((opt) => <option value={opt}>{opt}</option>)}
          </select>
        </div>

        <div>
          <label for="addon-notes" class="block text-xs font-semibold text-heading-2 mb-1">{t.notesLabel}</label>
          <textarea
            id="addon-notes" name="notes" rows="2" maxlength="500"
            class="w-full px-3 py-2 rounded-xl border border-box-border bg-box-bg text-heading-1 focus:outline-none focus:border-primary focus:ring-3 focus:ring-primary/25 text-sm resize-none"
            placeholder={t.notesPlaceholder}
          ></textarea>
        </div>

        <div class="flex gap-3 pt-2">
          <button
            type="submit"
            id="addon-submit"
            class="flex-1 py-2.5 rounded-full bg-primary text-white font-semibold text-sm hover:bg-blue-800 transition-colors duration-200 cursor-pointer"
          >
            {t.submitBtn}
          </button>
          <button
            type="button"
            id="addon-cancel"
            class="px-5 py-2.5 rounded-full border-2 border-box-border text-heading-2 font-semibold text-sm hover:border-primary hover:text-primary transition-colors duration-200 cursor-pointer"
          >
            {t.cancelBtn}
          </button>
        </div>
      </form>

      <div id="addon-success" class="hidden text-center py-8">
        <svg class="w-12 h-12 text-green-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-heading-1 font-semibold text-sm">{t.successMsg}</p>
      </div>

      <div id="addon-error" class="hidden text-center py-4">
        <p class="text-red-500 text-sm font-medium" role="alert">{t.errorMsg}</p>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ submitLabel: t.submitBtn, submittingLabel: t.submittingBtn }}>
(function () {
  var modal = document.getElementById("addon-modal");
  var form = document.getElementById("addon-form");
  var addonField = document.getElementById("addon-selected");
  var submitBtn = document.getElementById("addon-submit");
  var successDiv = document.getElementById("addon-success");
  var errorDiv = document.getElementById("addon-error");

  var lastFocused = null;

  function openModal(addonName) {
    lastFocused = document.activeElement;
    addonField.value = addonName;
    form.classList.remove("hidden");
    successDiv.classList.add("hidden");
    errorDiv.classList.add("hidden");
    submitBtn.disabled = false;
    submitBtn.textContent = submitLabel;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    document.getElementById("addon-name").focus();
  }

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
    if (lastFocused) lastFocused.focus();
  }

  modal.addEventListener("keydown", function (e) {
    if (e.key !== "Tab") return;
    var focusable = modal.querySelectorAll('input, select, textarea, button, [tabindex]:not([tabindex="-1"])');
    if (!focusable.length) return;
    var first = focusable[0];
    var last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });

  document.querySelectorAll("[data-addon-request]").forEach(function (btn) {
    btn.addEventListener("click", function () {
      openModal(btn.dataset.addonRequest);
    });
  });

  document.getElementById("addon-modal-close").addEventListener("click", closeModal);
  document.getElementById("addon-cancel").addEventListener("click", closeModal);

  modal.addEventListener("click", function (e) {
    if (e.target === modal) closeModal();
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
  });

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = submittingLabel;
    errorDiv.classList.add("hidden");

    var data = new FormData(form);
    fetch(form.dataset.endpoint, {
      method: "POST",
      body: data,
      headers: { Accept: "application/json" },
    })
      .then(function (res) {
        if (res.ok) {
          form.classList.add("hidden");
          successDiv.classList.remove("hidden");
          form.reset();
        } else {
          throw new Error("fail");
        }
      })
      .catch(function () {
        errorDiv.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      });
  });
})();
</script>
