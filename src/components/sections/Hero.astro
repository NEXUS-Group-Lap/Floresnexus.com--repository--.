---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;

const t = {
  en: {
    headline: "Simple monthly websites for local businesses",
    subheadline:
      "Get a professional online presence built for you, managed for you, and launched without agency prices.",
    support:
      "Built for local service businesses that need a clean website, clear contact options, and a professional way to present their services.",
    cta1: "View Plans",
    cta1Href: "/en/pricing",
    cta2: "Start My Website",
    cta2Href: "/en/start",
    badge: "Website-as-a-Service",
  },
  es: {
    headline: "Páginas web mensuales para negocios locales",
    subheadline:
      "Obtén una presencia profesional en internet, hecha por nosotros, administrada por nosotros y sin precios de agencia.",
    support:
      "Diseñadas para negocios locales que necesitan una página clara, botones de contacto y una forma profesional de presentar sus servicios.",
    cta1: "Ver Planes",
    cta1Href: "/es/precios",
    cta2: "Empezar Mi Página",
    cta2Href: "/es/empezar",
    badge: "Página web como servicio",
  },
}[lang];
---

<section class="relative pt-32 lg:pt-40 pb-20">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <span
      class="absolute -top-10 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full bg-gradient-to-br from-primary/20 to-blue-400/10 blur-3xl float-slow"
    ></span>
    <span
      class="absolute top-32 -right-20 w-64 h-64 rounded-full bg-primary/10 blur-3xl float-medium"
    ></span>
    <span
      class="absolute top-40 -left-20 w-48 h-48 rounded-3xl bg-primary/10 blur-2xl rotate-12 float-tilt"
    ></span>
  </div>

  <Container>
    <div class="relative text-center max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-box-border bg-box-bg text-sm text-heading-3 mb-6 motion-card" data-reveal="scale">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        {t.badge}
      </div>

      <!-- Headline -->
      <h1
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-heading-1 leading-tight mb-6"
        data-reveal
        style="--reveal-delay: 80ms"
      >
        {t.headline.split(" ").slice(0, 3).join(" ")}
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-blue-500 to-primary shine-text"
        >
          {t.headline.split(" ").slice(3, 5).join(" ")}
        </span>
        {t.headline.split(" ").slice(5).join(" ")}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-heading-2 mb-4 max-w-3xl mx-auto leading-relaxed" data-reveal style="--reveal-delay: 160ms">
        {t.subheadline}
      </p>

      <!-- Support line -->
      <p class="text-heading-3 mb-10 max-w-2xl mx-auto" data-reveal style="--reveal-delay: 220ms">
        {t.support}
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center" data-stagger>
        <BtnLink
          href={t.cta1Href}
          text={t.cta1}
          variant="primary"
          className="min-w-44 text-center motion-button"
        />
        <BtnLink
          href={t.cta2Href}
          text={t.cta2}
          variant="secondary"
          className="min-w-44 text-center motion-button"
        />
      </div>

      <!-- Trust indicators -->
      <div class="mt-12 flex flex-wrap justify-center gap-6 text-sm text-heading-3" data-stagger>
        <span class="flex items-center gap-2 motion-card px-3 py-2 rounded-full">
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {lang === "en" ? "Built for you" : "Hecho por nosotros"}
        </span>
        <span class="flex items-center gap-2 motion-card px-3 py-2 rounded-full">
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {lang === "en" ? "Managed for you" : "Administrado por nosotros"}
        </span>
        <span class="flex items-center gap-2 motion-card px-3 py-2 rounded-full">
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {lang === "en" ? "Without agency prices" : "Sin precios de agencia"}
        </span>
      </div>
    </div>
  </Container>
</section>
