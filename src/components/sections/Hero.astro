---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;

const t = {
  en: {
    headline1: "We build and manage your",
    headline2: "business website",
    subheadline:
      "Websites and local presence solutions for small businesses. We handle the design, publishing, hosting, and maintenance.",
    support:
      "Start with what your business needs today and expand when you need more.",
    cta1: "View Plans",
    cta1Href: "/en/pricing",
    cta2: "View Examples",
    cta2Href: "/en#examples",
    badge: "Managed websites for local businesses",
    indicators: ["From $99 setup", "3–5 business days", "EN/ES support"],
    floatingLive: "3–5 business days",
    floatingAfter: "After payment and complete info",
  },
  es: {
    headline1: "Creamos y administramos la",
    headline2: "presencia web de tu negocio",
    subheadline:
      "Sitios web y soluciones de presencia local para negocios pequeños. Nosotros nos encargamos del diseño, publicación, alojamiento y mantenimiento.",
    support:
      "Empieza con la solución que tu negocio necesita hoy y amplíala cuando necesites más.",
    cta1: "Ver Planes",
    cta1Href: "/es/precios",
    cta2: "Ver Ejemplos",
    cta2Href: "/es#ejemplos",
    badge: "Sitios web administrados para negocios locales",
    indicators: ["Desde $99 inicial", "3–5 días hábiles", "Atención EN/ES"],
    floatingLive: "3–5 días hábiles",
    floatingAfter: "Después del pago e info completa",
  },
}[lang];
---

<section class="relative pt-28 lg:pt-36 pb-16 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <span class="absolute -top-10 left-1/4 w-96 h-96 rounded-full bg-gradient-to-br from-primary/20 to-blue-400/10 blur-3xl float-slow"></span>
    <span class="absolute top-32 -right-20 w-64 h-64 rounded-full bg-primary/10 blur-3xl float-medium"></span>
    <span class="absolute bottom-0 -left-20 w-48 h-48 rounded-3xl bg-primary/10 blur-2xl rotate-12 float-tilt"></span>
  </div>

  <Container>
    <div class="relative flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <div class="flex-1 text-center lg:text-left" data-reveal>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-box-border bg-box-bg text-sm text-heading-3 mb-6 motion-card" data-reveal="scale">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          {t.badge}
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-bold text-heading-1 leading-tight mb-6" data-reveal style="--reveal-delay: 80ms">
          {t.headline1}{" "}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-blue-500 to-primary shine-text">
            {t.headline2}
          </span>
        </h1>

        <p class="text-lg md:text-xl text-heading-2 mb-3 leading-relaxed max-w-xl mx-auto lg:mx-0" data-reveal style="--reveal-delay: 160ms">
          {t.subheadline}
        </p>

        <p class="text-heading-3 mb-8 max-w-lg mx-auto lg:mx-0" data-reveal style="--reveal-delay: 220ms">
          {t.support}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center mb-10" data-stagger>
          <BtnLink href={t.cta1Href} text={t.cta1} variant="primary" className="min-w-44 text-center motion-button" />
          <BtnLink href={t.cta2Href} text={t.cta2} variant="secondary" className="min-w-44 text-center motion-button" />
        </div>

        <div class="flex flex-wrap justify-center lg:justify-start gap-3" data-stagger>
          {t.indicators.map((item) => (
            <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border border-box-border bg-box-bg text-xs font-semibold text-heading-2">
              <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {item}
            </span>
          ))}
        </div>
      </div>

      <div class="flex-1 relative w-full max-w-lg mx-auto lg:mx-0" data-reveal="right">
        <div class="relative rounded-3xl overflow-hidden aspect-[4/3] shadow-2xl shadow-primary/20 border border-box-border">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-blue-400/15 to-primary/5"></div>
          <img
            src="/images/image1.webp"
            alt={lang === "en" ? "Business professional" : "Profesional de negocios"}
            class="absolute inset-0 w-full h-full object-cover"
            onerror="this.style.display='none'"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-4 pb-14">
            <div class="space-y-1.5">
              <div class="h-1.5 bg-white/25 rounded-full w-3/4"></div>
              <div class="h-1 bg-white/15 rounded-full w-1/2"></div>
            </div>
          </div>
        </div>

        <div class="absolute -top-4 -right-4 bg-box-bg border border-box-border rounded-2xl p-3 shadow-xl backdrop-blur-sm w-36 motion-card" data-reveal="scale">
          <div class="flex gap-1 mb-2">
            <span class="w-2 h-2 rounded-full bg-red-400/70"></span>
            <span class="w-2 h-2 rounded-full bg-yellow-400/70"></span>
            <span class="w-2 h-2 rounded-full bg-green-400/70"></span>
          </div>
          <div class="space-y-1.5">
            <div class="h-2 bg-primary/40 rounded-full w-full"></div>
            <div class="h-1.5 bg-box-border rounded-full w-3/4"></div>
            <div class="h-1.5 bg-box-border rounded-full w-full"></div>
            <div class="h-6 bg-primary/80 rounded-lg w-full mt-2"></div>
          </div>
        </div>

        <div class="absolute -bottom-4 -left-4 bg-box-bg border border-box-border rounded-2xl p-3 shadow-xl backdrop-blur-sm motion-card" data-reveal="scale">
          <div class="flex items-center gap-2.5">
            <div class="w-9 h-9 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-heading-1 whitespace-nowrap">{t.floatingLive}</p>
              <p class="text-xs text-heading-3 whitespace-nowrap">{t.floatingAfter}</p>
            </div>
          </div>
        </div>

        <div class="absolute -z-10 -bottom-8 -right-8 w-48 h-48 rounded-full bg-primary/10 blur-3xl"></div>
        <div class="absolute -z-10 -top-6 -left-6 w-32 h-32 rounded-full bg-blue-400/10 blur-2xl"></div>
      </div>
    </div>
  </Container>
</section>
