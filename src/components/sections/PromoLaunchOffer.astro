---
import Container from "../shared/Container.astro";
import BtnLink from "../shared/BtnLink.astro";
import { promoConfig } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;
const promo = promoConfig[lang];
const isActive = promoConfig.active;
---

{isActive && (
  <section class="py-12 lg:py-16">
    <Container>
      <div class="max-w-2xl mx-auto text-center p-8 rounded-2xl border border-green-500/20 bg-green-500/5" data-reveal>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 text-green-700 dark:text-green-400 text-xs font-semibold mb-4">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          {promo.badge}
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold text-heading-1 mb-2">
          {promo.title}
        </h2>
        <p class="text-lg font-semibold text-heading-2 mb-2">
          {promo.subtitle}
        </p>
        <p class="text-sm text-heading-3 mb-2">
          {promo.note}
        </p>
        <p class="text-xs text-heading-3 mb-6">
          {promo.disclaimer}
        </p>
        <BtnLink href={promo.ctaHref} text={promo.cta} variant="primary" className="min-w-48 text-center" />
      </div>
    </Container>
  </section>
)}
