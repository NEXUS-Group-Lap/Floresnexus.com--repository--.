---
import Container from "../shared/Container.astro";
import SquishyPricingCards from "../ui/SquishyPricingCards";
import { plans, planOrder } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Simple, Transparent Pricing",
    subtitle: "Choose the plan that fits your business. Subscription cancellation follows the Terms of Service.",
    growthMessage: "Start with the plan that fits your business today. Upgrade when your business needs more.",
    setupLabel: "setup",
    monthLabel: "/month",
    recommendedBadge: "Recommended",
    seeAll: "See all features",
    footerNote: "Hosting included while subscription is active. Standard domain subject to availability, administered by Flores Nexus Group. Premium domains, ownership transfers, additional changes, advanced SEO, and external integrations may require additional charges. Full terms apply.",
  },
  es: {
    title: "Precios Simples y Transparentes",
    subtitle: "Elige el plan que se adapte a tu negocio. La cancelación de la suscripción sigue los Términos del Servicio.",
    growthMessage: "Empieza con el plan que se adapte a tu negocio hoy. Actualiza cuando tu negocio necesite más.",
    setupLabel: "inicial",
    monthLabel: "/mes",
    recommendedBadge: "Recomendado",
    seeAll: "Ver todas las funciones",
    footerNote: "Hosting incluido mientras la suscripción esté activa. Dominio estándar sujeto a disponibilidad, administrado por Flores Nexus Group. Dominios premium, transferencias de propiedad, cambios adicionales, SEO avanzado e integraciones externas pueden requerir cargos adicionales. Aplican términos completos.",
  },
}[lang];

const pricingPlans = planOrder.map((id) => {
  const plan = plans[id];
  const copy = plan[lang];
  return {
    id: plan.id,
    name: copy.name,
    tagline: copy.tagline,
    setup: plan.setup,
    monthly: plan.monthly,
    setupLabel: t.setupLabel,
    monthLabel: t.monthLabel,
    cta: copy.cta,
    ctaHref: plan.startForm[lang],
    detailsCta: copy.detailsCta,
    detailsHref: plan.detailsHref[lang],
    features: copy.homeFeatures.slice(0, 4),
    seeAllLabel: t.seeAll,
    isRecommended: plan.id === "professional",
    recommendedLabel: plan.id === "professional" ? t.recommendedBadge : undefined,
  };
});
---

<section class="py-16" id={lang === "en" ? "pricing" : "planes"}>
  <Container>
    <div class="text-center mb-4" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <p class="text-center text-primary font-semibold text-base max-w-xl mx-auto mb-10" data-reveal="scale">
      {t.growthMessage}
    </p>
  </Container>

  <Container>
    <SquishyPricingCards client:visible plans={pricingPlans} />
    <p class="text-center text-xs text-heading-3 mt-8 max-w-2xl mx-auto italic">{t.footerNote}</p>
  </Container>
</section>
