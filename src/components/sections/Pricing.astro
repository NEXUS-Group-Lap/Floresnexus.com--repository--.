---
import Container from "../shared/Container.astro";
import SquishyPricingCards from "../ui/SquishyPricingCards";
import { plans, planOrder, promoConfig } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Simple, Transparent Pricing",
    subtitle: "Choose the plan that fits your business today. No hidden fees.",
    growthMessage: "Start with what you need. Move up when your business grows.",
    setupLabel: "setup",
    monthLabel: "/month",
    recommendedBadge: "Recommended",
    seeAll: "See all features",
    footerNote: "We keep your site online while your subscription is active. Your own web address is subject to availability and managed by Flores Nexus Group. Premium addresses, extra changes, and advanced features may have additional costs. Full terms apply.",
  },
  es: {
    title: "Precios Simples y Transparentes",
    subtitle: "Elige el plan que se adapte a tu negocio hoy. Sin costos ocultos.",
    growthMessage: "Empieza con lo que necesitas. Sube de plan cuando tu negocio crezca.",
    setupLabel: "inicial",
    monthLabel: "/mes",
    recommendedBadge: "Recomendado",
    seeAll: "Ver todo lo que incluye",
    footerNote: "Mantenemos tu sitio en internet mientras tu suscripción esté activa. Tu dirección web está sujeta a disponibilidad y es administrada por Flores Nexus Group. Direcciones premium, cambios extra y funciones avanzadas pueden tener costos adicionales. Aplican términos completos.",
  },
}[lang];

const pricingPlans = planOrder.map((id) => {
  const plan = plans[id];
  const copy = plan[lang];
  const isPromoEligible = promoConfig.active && plan.promoEligible;
  return {
    id: plan.id,
    name: copy.name,
    tagline: copy.tagline,
    setup: plan.setup,
    monthly: plan.monthly,
    setupLabel: t.setupLabel,
    monthLabel: t.monthLabel,
    cta: copy.cta,
    ctaHref: plan.startForm[lang],
    detailsCta: copy.detailsCta,
    detailsHref: plan.detailsHref[lang],
    features: copy.homeFeatures.slice(0, 4),
    seeAllLabel: t.seeAll,
    isRecommended: plan.id === "professional",
    recommendedLabel: plan.id === "professional" ? t.recommendedBadge : undefined,
    promoEligible: isPromoEligible,
    promoSetup: isPromoEligible ? promoConfig.promoSetup : undefined,
    promoBadge: isPromoEligible ? promoConfig[lang].badge : undefined,
  };
});
---

<section class="py-16" id={lang === "en" ? "pricing" : "planes"}>
  <Container>
    <div class="text-center mb-4" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <p class="text-center text-primary font-semibold text-base max-w-xl mx-auto mb-10" data-reveal="scale">
      {t.growthMessage}
    </p>
  </Container>

  <Container>
    <SquishyPricingCards client:visible plans={pricingPlans} />
    <p class="text-center text-xs text-heading-3 mt-8 max-w-2xl mx-auto italic">{t.footerNote}</p>
  </Container>
</section>
