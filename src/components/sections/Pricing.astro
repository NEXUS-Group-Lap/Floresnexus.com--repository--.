---
import Container from "../shared/Container.astro";
import PricingCards from "../ui/PricingCards";
import { plans, planOrder, promoConfig } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Simple, Clear Pricing",
    subtitle: "Choose the plan that fits your business. No hidden fees.",
    growthMessage: "Start with what you need. Move up when you're ready.",
    footerNote: "We keep your page active while your plan is active. Web addresses are subject to availability and managed by Flores Nexus Group. Extras and additional changes may have separate costs. Full terms apply.",
    labels: {
      monthly: "Monthly",
      annual: "Annual",
      annualToggleBadge: "(Prepay)",
      perMonth: "month",
      perYear: "year",
      billedMonthly: "Billed Monthly",
      billedAnnually: "Billed Annually (Prepay)",
      setupLabel: "setup",
    },
    recommendedLabel: "Recommended",
  },
  es: {
    title: "Precios Simples y Claros",
    subtitle: "Elige el plan que se adapte a tu negocio. Sin costos ocultos.",
    growthMessage: "Empieza con lo que necesitas. Sube de plan cuando estés listo.",
    footerNote: "Mantenemos tu página activa mientras tu plan esté activo. Las direcciones web están sujetas a disponibilidad y son administradas por Flores Nexus Group. Los extras y cambios adicionales pueden tener costos aparte. Aplican términos completos.",
    labels: {
      monthly: "Mensual",
      annual: "Anual",
      annualToggleBadge: "(Prepago)",
      perMonth: "mes",
      perYear: "año",
      billedMonthly: "Cobro Mensual",
      billedAnnually: "Cobro Anual (Prepago)",
      setupLabel: "inicial",
    },
    recommendedLabel: "Recomendado",
  },
}[lang];

function parsePrice(s: string | undefined): number {
  if (!s) return 0;
  return parseInt(s.replace(/[^0-9]/g, ""), 10) || 0;
}

const pricingPlans = planOrder.map((id) => {
  const plan = plans[id];
  const copy = plan[lang];
  const isPromoEligible = promoConfig.active && plan.promoEligible;
  return {
    name: copy.name,
    monthlyPrice: parsePrice(plan.monthly),
    annualPrice: parsePrice(plan.annualPrice),
    setup: plan.setup,
    features: copy.homeFeatures,
    description: copy.tagline,
    buttonText: copy.cta,
    href: plan.startForm[lang],
    detailsCta: copy.detailsCta,
    detailsHref: plan.detailsHref[lang],
    isPopular: plan.id === "professional",
    popularLabel: plan.id === "professional" ? t.recommendedLabel : undefined,
    promoEligible: isPromoEligible,
    promoSetup: isPromoEligible ? promoConfig.promoSetup : undefined,
    promoBadge: isPromoEligible ? promoConfig[lang].badge : undefined,
    annualSavings: plan.annualSavings?.[lang],
  };
});
---

<section class="py-16" id={lang === "en" ? "pricing" : "planes"}>
  <Container>
    <div class="text-center mb-4" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">
        {lang === "en"
          ? <Fragment>Simple, <span class="text-primary dark:text-blue-400">Clear</span> Pricing</Fragment>
          : <Fragment>Precios Simples y <span class="text-primary dark:text-blue-400">Claros</span></Fragment>
        }
      </h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <p class="text-center text-primary font-semibold text-base max-w-xl mx-auto mb-10" data-reveal="scale">
      {t.growthMessage}
    </p>
  </Container>

  <Container>
    <PricingCards client:visible plans={pricingPlans} labels={t.labels} />
    <p class="text-center text-xs text-heading-3 mt-8 max-w-2xl mx-auto italic">{t.footerNote}</p>
  </Container>
</section>
