---
import Container from "../../shared/Container.astro";
import { plans } from "../../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;
const plan = plans["local-presence"];

const t = {
  en: {
    heading: "Need help with Google and Apple Maps first?",
    description:
      "Local Presence Starter combines a managed Mini Card with initial assistance organizing your Google Business Profile and Apple Business Connect information.",
    price: "$150 setup + $45/month",
    comparison1: "Mini Card = your business information in one managed link.",
    comparison2: "Local Presence Starter = the Mini Card plus initial Google and Apple business profile assistance.",
    notIncludesNote:
      "Does not include ongoing SEO, guaranteed rankings, guaranteed leads, social media management, or unlimited Maps administration.",
    cta: "Start Local Presence",
    detailsCta: "View Details",
    includes: [
      "Managed Mini Card",
      "Google Business Profile initial review or setup assistance",
      "Apple Business Connect initial review or setup assistance",
      "Business hours and contact information",
      "Call and directions buttons",
      "Local profile information review",
    ],
  },
  es: {
    heading: "¿Primero necesitas ayuda con Google y Apple Maps?",
    description:
      "Local Presence Starter combina una Mini Card administrada con asistencia inicial para organizar tu Google Business Profile y Apple Business Connect.",
    price: "$150 inicial + $45/mes",
    comparison1: "Mini Card = la información de tu negocio en un enlace administrado.",
    comparison2:
      "Local Presence Starter = la Mini Card más asistencia inicial con tu perfil de Google y Apple.",
    notIncludesNote:
      "No incluye SEO continuo, posicionamiento garantizado, prospectos garantizados, manejo de redes sociales ni administración ilimitada de Maps.",
    cta: "Comenzar con Presencia Local",
    detailsCta: "Ver Detalles",
    includes: [
      "Mini Card administrada",
      "Revisión o configuración inicial de Google Business Profile",
      "Revisión o configuración inicial de Apple Business Connect",
      "Horario e información de contacto",
      "Botones para llamar y obtener direcciones",
      "Revisión de información del perfil local",
    ],
  },
}[lang];
---

<section class="py-8" id="local-presence-strip">
  <Container>
    <div
      class="rounded-2xl border border-primary/30 bg-gradient-to-r from-primary/5 to-blue-400/5 dark:from-primary/10 dark:to-blue-400/5 p-6 md:p-8 max-w-4xl mx-auto motion-card"
      data-reveal="scale"
    >
      <!-- Header row -->
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
        <div class="flex-1">
          <p class="text-xs font-bold text-primary uppercase tracking-widest mb-2">
            {lang === "en" ? "Complementary offer" : "Oferta complementaria"}
          </p>
          <h2 class="text-xl md:text-2xl font-bold text-heading-1 mb-2">{t.heading}</h2>
          <p class="text-sm text-heading-3 leading-relaxed max-w-xl mb-3">{t.description}</p>
          <p class="text-base font-semibold text-primary">{t.price}</p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col gap-2 shrink-0 md:w-48">
          <a
            href={plan.startForm[lang]}
            data-plan-cta="local-presence"
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-full bg-primary text-white font-semibold text-sm hover:bg-blue-800 transition-all duration-200 text-center motion-button"
            onclick="event.stopPropagation()"
          >
            {t.cta}
          </a>
          <a
            href={plan.detailsHref[lang]}
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-full border-2 border-box-border text-heading-2 font-semibold text-sm hover:border-primary hover:text-primary transition-all duration-200 text-center motion-button"
          >
            {t.detailsCta}
          </a>
        </div>
      </div>

      <!-- Comparison + includes row -->
      <div class="grid md:grid-cols-2 gap-6 border-t border-primary/20 pt-5">
        <!-- Includes -->
        <div>
          <p class="text-xs font-bold text-heading-2 uppercase tracking-wide mb-3">
            {lang === "en" ? "Includes" : "Incluye"}
          </p>
          <ul class="space-y-1.5">
            {t.includes.map((item) => (
              <li class="flex items-start gap-2 text-sm text-heading-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Comparison + limits -->
        <div>
          <p class="text-xs font-bold text-heading-2 uppercase tracking-wide mb-3">
            {lang === "en" ? "How it compares" : "Comparación"}
          </p>
          <div class="space-y-2 mb-4">
            <p class="text-sm text-heading-2 leading-relaxed">
              <span class="font-semibold">Mini Card</span> — {lang === "en" ? "your business information in one managed link." : "la información de tu negocio en un enlace administrado."}
            </p>
            <p class="text-sm text-heading-2 leading-relaxed">
              <span class="font-semibold">Local Presence Starter</span> — {lang === "en" ? "the Mini Card plus initial Google and Apple business profile assistance." : "la Mini Card más asistencia inicial con tu perfil de Google y Apple."}
            </p>
          </div>
          <p class="text-xs text-heading-3 leading-relaxed italic">{t.notIncludesNote}</p>
        </div>
      </div>
    </div>
  </Container>
</section>
