---
import Container from "../../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "How It Works",
    steps: [
      { n: "1", title: "Choose a plan", desc: "Select the plan that fits your business. Use the selector above if you're unsure." },
      { n: "2", title: "Complete the Start Form", desc: "Fill out your business name, services, hours, contact info, and photos." },
      { n: "3", title: "Submit payment and business information", desc: "Pay the setup fee and first billing period. Production starts once payment and complete information are received." },
      { n: "4", title: "Review and launch", desc: "We build your site and send you a preview when your plan includes it. You confirm and we launch." },
    ],
    timelineNote: "Typical delivery is 3–5 business days after payment and complete business information are received.",
  },
  es: {
    title: "Cómo Funciona",
    steps: [
      { n: "1", title: "Elige un plan", desc: "Selecciona el plan que se adapte a tu negocio. Usa el selector de arriba si no estás seguro." },
      { n: "2", title: "Completa el formulario de inicio", desc: "Ingresa el nombre de tu negocio, servicios, horario, datos de contacto y fotos." },
      { n: "3", title: "Envía el pago y la información", desc: "Paga el costo inicial y el primer período de facturación. La producción comienza al recibir el pago y la información completa." },
      { n: "4", title: "Revisa y lanza", desc: "Construimos tu sitio y te enviamos una vista previa cuando tu plan lo incluye. Tú confirmas y lanzamos." },
    ],
    timelineNote: "El plazo típico de entrega es de 3–5 días hábiles después de recibir el pago y la información completa del negocio.",
  },
}[lang];
---

<section class="py-16" aria-labelledby="how-to-start-title">
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 id="how-to-start-title" class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">
        {t.title}
      </h2>
    </div>

    <div class="max-w-3xl mx-auto">
      <ol class="space-y-6" data-stagger>
        {
          t.steps.map((step) => (
            <li class="flex gap-5 items-start motion-card">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">
                {step.n}
              </div>
              <div class="flex-1 pt-1.5">
                <h3 class="font-semibold text-heading-1 mb-0.5">{step.title}</h3>
                <p class="text-sm text-heading-3 leading-relaxed">{step.desc}</p>
              </div>
            </li>
          ))
        }
      </ol>

      <div class="mt-8 p-4 rounded-xl bg-primary/5 border border-primary/20 text-center">
        <p class="text-sm text-heading-2 leading-relaxed">
          <strong>{t.timelineNote}</strong>
        </p>
      </div>
    </div>
  </Container>
</section>
