---
import Container from "../../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    sectionTitle: "Compare Plans",
    subtitle: "Key differences between Nexus Card, Starter, and Professional.",
    featureCol: "Feature",
    miniCol: "Nexus Card",
    starterCol: "Starter",
    proCol: "Professional",
    yes: "Yes",
    no: "—",
    rows: [
      { feature: "Product type", mini: "Digital card", starter: "1-page website", pro: "Multi-page website" },
      { feature: "Content blocks / Sections", mini: "Up to 5", starter: "Up to 8", pro: "Up to 5 pages" },
      { feature: "Published images", mini: "Logo + 1", starter: "Up to 10", pro: "Up to 25" },
      { feature: "Contact buttons", mini: true, starter: true, pro: true },
      { feature: "Contact form", mini: false, starter: "Up to 6 fields", pro: "Up to 8 fields" },
      { feature: "Web address", mini: "floresnexus.cards", starter: "Your own address", pro: "Your own address" },
      { feature: "Languages included", mini: "1", starter: "1", pro: "1" },
      { feature: "Review rounds", mini: "1 basic", starter: "1", pro: "2" },
      { feature: "Monthly small updates", mini: "0", starter: "1", pro: "3" },
      { feature: "We keep it active", mini: true, starter: true, pro: true },
      { feature: "Best for", mini: "New / solo businesses", starter: "Local service business", pro: "Established business" },
    ],
    ownershipNote: "Ownership transfer is not included and can be quoted separately.",
    bsNote: "Bookings, payments, customer accounts, and special features are available through Business System. Request a quote.",
  },
  es: {
    sectionTitle: "Comparar Planes",
    subtitle: "Diferencias clave entre Nexus Card, Starter y Professional.",
    featureCol: "Función",
    miniCol: "Nexus Card",
    starterCol: "Starter",
    proCol: "Professional",
    yes: "Sí",
    no: "—",
    rows: [
      { feature: "Tipo de producto", mini: "Tarjeta digital", starter: "Sitio de 1 página", pro: "Sitio multi-página" },
      { feature: "Bloques / Secciones", mini: "Hasta 5", starter: "Hasta 8", pro: "Hasta 5 páginas" },
      { feature: "Imágenes publicadas", mini: "Logo + 1", starter: "Hasta 10", pro: "Hasta 25" },
      { feature: "Botones de contacto", mini: true, starter: true, pro: true },
      { feature: "Formulario de contacto", mini: false, starter: "Hasta 6 campos", pro: "Hasta 8 campos" },
      { feature: "Dirección web", mini: "floresnexus.cards", starter: "Tu propia dirección", pro: "Tu propia dirección" },
      { feature: "Idiomas incluidos", mini: "1", starter: "1", pro: "1" },
      { feature: "Rondas de revisión", mini: "1 básica", starter: "1", pro: "2" },
      { feature: "Actualizaciones pequeñas al mes", mini: "0", starter: "1", pro: "3" },
      { feature: "La mantenemos activa", mini: true, starter: true, pro: true },
      { feature: "Ideal para", mini: "Negocios nuevos / independientes", starter: "Negocio de servicio local", pro: "Negocio establecido" },
    ],
    ownershipNote: "La transferencia de propiedad no está incluida y puede cotizarse por separado.",
    bsNote: "Reservas, pagos, cuentas de clientes y funciones especiales están disponibles en Business System. Solicita una cotización.",
  },
}[lang];
---

<section
  id={lang === "en" ? "compare" : "comparar"}
  class="py-16"
  aria-labelledby="compare-title"
>
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 id="compare-title" class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">
        {lang === "en"
          ? <Fragment>Compare <span class="text-primary dark:text-blue-400">Plans</span></Fragment>
          : <Fragment>Comparar <span class="text-primary dark:text-blue-400">Planes</span></Fragment>
        }
      </h2>
      <p class="text-heading-3 text-base max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-box-border motion-card" data-reveal="scale">
      <table class="w-full text-sm min-w-[600px]">
        <thead>
          <tr class="bg-box-bg border-b border-box-border">
            <th class="p-4 text-left text-heading-3 font-medium w-2/5 text-xs uppercase tracking-wide">
              {t.featureCol}
            </th>
            <th class="p-4 text-center font-semibold text-heading-2 w-1/5">{t.miniCol}</th>
            <th class="p-4 text-center font-semibold text-primary bg-primary/5 w-1/5">{t.starterCol}</th>
            <th class="p-4 text-center font-semibold text-heading-2 w-1/5">{t.proCol}</th>
          </tr>
        </thead>
        <tbody>
          {
            t.rows.map((row, i) => {
              const renderCell = (val: boolean | string) => {
                if (val === true) return <span class="text-green-500 font-bold text-base" aria-label={t.yes}>✓</span>;
                if (val === false) return <span class="text-heading-3 text-base" aria-label={t.no}>—</span>;
                return <span class="text-heading-2 text-xs">{val}</span>;
              };
              return (
                <tr class={`border-b border-box-border ${i % 2 === 0 ? "" : "bg-box-bg/50"}`}>
                  <td class="p-4 text-heading-2 font-medium text-xs md:text-sm">{row.feature}</td>
                  <td class="p-4 text-center">{renderCell(row.mini)}</td>
                  <td class="p-4 text-center bg-primary/5">{renderCell(row.starter)}</td>
                  <td class="p-4 text-center">{renderCell(row.pro)}</td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>

    <div class="mt-6 space-y-2 max-w-2xl mx-auto">
      <p class="text-xs text-heading-3 text-center italic">{t.ownershipNote}</p>
      <p class="text-xs text-heading-3 text-center italic">{t.bsNote}</p>
    </div>
  </Container>
</section>
