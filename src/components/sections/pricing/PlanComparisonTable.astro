---
import Container from "../../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    sectionTitle: "Compare Plans",
    subtitle: "Key differences between Nexus Card, Starter, and Professional.",
    featureCol: "Feature",
    miniCol: "Nexus Card",
    starterCol: "Starter",
    proCol: "Professional",
    yes: "Yes",
    no: "—",
    rows: [
      { feature: "Product type", mini: "Managed business link", starter: "One-page website", pro: "Multi-page website" },
      { feature: "Pages", mini: "—", starter: "1", pro: "Up to 5" },
      { feature: "Published images", mini: "1", starter: "Up to 10", pro: "Up to 25" },
      { feature: "Contact buttons (call / text / WhatsApp)", mini: true, starter: true, pro: true },
      { feature: "Contact form", mini: false, starter: "Optional / basic", pro: true },
      { feature: "Service area or location", mini: true, starter: true, pro: true },
      { feature: "Embedded map", mini: false, starter: "Optional", pro: true },
      { feature: "Pre-launch revisions", mini: "Setup correction only", starter: "1", pro: "Within project scope" },
      { feature: "Monthly small updates", mini: "0", starter: "1", pro: "3" },
      { feature: "Hosting", mini: "Managed Flores Nexus link", starter: "Managed website hosting", pro: "Managed website hosting" },
      { feature: "Best for", mini: "Basic contact presence", starter: "Small service business", pro: "Established business with more content" },
    ],
    ownershipNote: "Ownership transfer is not included and can be quoted separately.",
    bsNote: "Booking, payments, CRM, and automations are available through Business System. Request a quote.",
  },
  es: {
    sectionTitle: "Comparar Planes",
    subtitle: "Diferencias clave entre Nexus Card, Starter y Professional.",
    featureCol: "Función",
    miniCol: "Nexus Card",
    starterCol: "Starter",
    proCol: "Professional",
    yes: "Sí",
    no: "—",
    rows: [
      { feature: "Tipo de producto", mini: "Enlace de negocio administrado", starter: "Sitio de una página", pro: "Sitio multi-página" },
      { feature: "Páginas", mini: "—", starter: "1", pro: "Hasta 5" },
      { feature: "Imágenes publicadas", mini: "1", starter: "Hasta 10", pro: "Hasta 25" },
      { feature: "Botones de contacto (llamada / texto / WhatsApp)", mini: true, starter: true, pro: true },
      { feature: "Formulario de contacto", mini: false, starter: "Opcional / básico", pro: true },
      { feature: "Área de servicio o ubicación", mini: true, starter: true, pro: true },
      { feature: "Mapa integrado", mini: false, starter: "Opcional", pro: true },
      { feature: "Revisiones antes del lanzamiento", mini: "Solo corrección inicial", starter: "1", pro: "Dentro del alcance" },
      { feature: "Actualizaciones pequeñas al mes", mini: "0", starter: "1", pro: "3" },
      { feature: "Hosting", mini: "Enlace Flores Nexus administrado", starter: "Hosting web administrado", pro: "Hosting web administrado" },
      { feature: "Ideal para", mini: "Presencia básica de contacto", starter: "Negocio de servicio pequeño", pro: "Negocio establecido con más contenido" },
    ],
    ownershipNote: "La transferencia de propiedad no está incluida y puede cotizarse por separado.",
    bsNote: "Reservas, pagos, CRM y automatizaciones están disponibles en Business System. Solicita una cotización.",
  },
}[lang];
---

<section
  id={lang === "en" ? "compare" : "comparar"}
  class="py-16"
  aria-labelledby="compare-title"
>
  <Container>
    <div class="text-center mb-10" data-reveal>
      <h2 id="compare-title" class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">
        {t.sectionTitle}
      </h2>
      <p class="text-heading-3 text-base max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-box-border motion-card" data-reveal="scale">
      <table class="w-full text-sm min-w-[600px]">
        <thead>
          <tr class="bg-box-bg border-b border-box-border">
            <th class="p-4 text-left text-heading-3 font-medium w-2/5 text-xs uppercase tracking-wide">
              {t.featureCol}
            </th>
            <th class="p-4 text-center font-semibold text-heading-2 w-1/5">{t.miniCol}</th>
            <th class="p-4 text-center font-semibold text-primary bg-primary/5 w-1/5">{t.starterCol}</th>
            <th class="p-4 text-center font-semibold text-heading-2 w-1/5">{t.proCol}</th>
          </tr>
        </thead>
        <tbody>
          {
            t.rows.map((row, i) => {
              const renderCell = (val: boolean | string) => {
                if (val === true) return <span class="text-green-500 font-bold text-base" aria-label={t.yes}>✓</span>;
                if (val === false) return <span class="text-heading-3 text-base" aria-label={t.no}>—</span>;
                return <span class="text-heading-2 text-xs">{val}</span>;
              };
              return (
                <tr class={`border-b border-box-border ${i % 2 === 0 ? "" : "bg-box-bg/50"}`}>
                  <td class="p-4 text-heading-2 font-medium text-xs md:text-sm">{row.feature}</td>
                  <td class="p-4 text-center">{renderCell(row.mini)}</td>
                  <td class="p-4 text-center bg-primary/5">{renderCell(row.starter)}</td>
                  <td class="p-4 text-center">{renderCell(row.pro)}</td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>

    <div class="mt-6 space-y-2 max-w-2xl mx-auto">
      <p class="text-xs text-heading-3 text-center italic">{t.ownershipNote}</p>
      <p class="text-xs text-heading-3 text-center italic">{t.bsNote}</p>
    </div>
  </Container>
</section>
