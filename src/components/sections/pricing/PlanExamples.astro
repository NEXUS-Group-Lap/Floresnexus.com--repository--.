---
import Container from "../../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

function mshot(url: string) {
  return `https://s.wordpress.com/mshots/v1/${encodeURIComponent(url)}?w=640&h=400`;
}

const planStyle: Record<string, string> = {
  "Nexus Mini Card":      "bg-pink-500/15 text-pink-500",
  "Starter Website":      "bg-lime-500/15 text-lime-600 dark:text-lime-400",
  "Professional Website": "bg-primary/15 text-primary",
};

const typeStyle = {
  real: "bg-green-500/15 text-green-600 dark:text-green-400",
  demo: "bg-amber-500/15 text-amber-600 dark:text-amber-400",
};

const t = {
  en: {
    sectionTitle: "Website Examples by Plan",
    sectionSubtitle: "Select a plan to see what that level looks like.",
    tabMini: "Mini Card",
    tabStarter: "Starter",
    tabProfessional: "Professional",
    visitLabel: "Website",
    realLabel: "Real Project",
    demoLabel: "Demo Concept",
    demoNote: "Visual example to show possible styles and structures.",
    wantThis: "I Want Something Like This",
  },
  es: {
    sectionTitle: "Ejemplos de Sitios por Plan",
    sectionSubtitle: "Selecciona un plan para ver cómo se ve ese nivel.",
    tabMini: "Mini Card",
    tabStarter: "Starter",
    tabProfessional: "Professional",
    visitLabel: "Website",
    realLabel: "Proyecto Real",
    demoLabel: "Concepto Demo",
    demoNote: "Ejemplo visual para mostrar estilos y estructuras posibles.",
    wantThis: "Quiero Algo Así",
  },
}[lang];

const startBase = { en: "/en/start", es: "/es/empezar" }[lang];

type Example = {
  industry: string;
  plan: string;
  planId: string;
  type: "real" | "demo";
  desc: string;
  liveHref: string;
};

const panels: { id: string; label: string; examples: Example[] }[] = [
  {
    id: "mini-card",
    label: t.tabMini,
    examples: [
      {
        industry: lang === "en" ? "Grocery Store / Pulpería" : "Pulpería / Tienda Local",
        plan: "Nexus Mini Card",
        planId: "mini-card",
        type: "real",
        desc: lang === "en"
          ? "Link card with essential info, hours, and contact for a local grocery store."
          : "Link card con información esencial, horario y contacto para una tienda local de abarrotes.",
        liveHref: "https://floresnexus.cards/lamorenita/",
      },
      {
        industry: lang === "en" ? "Resale / Boutique" : "Ropa / Boutique",
        plan: "Nexus Mini Card",
        planId: "mini-card",
        type: "real",
        desc: lang === "en"
          ? "Curated link card connecting Instagram, Poshmark, eBay, and Mercari in one place."
          : "Link card con acceso directo a Instagram, Poshmark, eBay y Mercari en un solo lugar.",
        liveHref: "https://nexus-group-lap.github.io/alma/",
      },
    ],
  },
  {
    id: "starter",
    label: t.tabStarter,
    examples: [
      {
        industry: lang === "en" ? "Lawn Care" : "Jardinería",
        plan: "Starter Website",
        planId: "starter",
        type: "real",
        desc: lang === "en"
          ? "Service list, pricing preview, seasonal schedule info, and contact form."
          : "Lista de servicios, vista previa de precios, info de temporada y formulario de contacto.",
        liveHref: "https://nexus-group-lap.github.io/floreslawncare/",
      },
      {
        industry: lang === "en" ? "Architecture / Design" : "Arquitectura / Diseño",
        plan: "Starter Website",
        planId: "starter",
        type: "demo",
        desc: lang === "en"
          ? "Project portfolio, services overview, about section, and contact form."
          : "Portafolio de proyectos, servicios, sección de equipo y formulario de contacto.",
        liveHref: "https://3dinterior.mail-nearmelab.workers.dev/projects/",
      },
    ],
  },
  {
    id: "professional",
    label: t.tabProfessional,
    examples: [
      {
        industry: lang === "en" ? "Photography" : "Fotografía",
        plan: "Professional Website",
        planId: "professional",
        type: "demo",
        desc: lang === "en"
          ? "Elegant gallery, service packages, booking CTA, and branded layout."
          : "Galería elegante, paquetes de servicios, CTA de reserva y diseño de marca.",
        liveHref: "https://horizon.cosmicthemes.com",
      },
      {
        industry: lang === "en" ? "Fintech / Payments" : "Fintech / Pagos",
        plan: "Professional Website",
        planId: "professional",
        type: "demo",
        desc: lang === "en"
          ? "Send & receive money, pay bills, and manage transactions — clean, trustworthy design."
          : "Envía y recibe dinero, paga facturas y administra transacciones — diseño limpio y confiable.",
        liveHref: "https://zeepay-lyart.vercel.app",
      },
    ],
  },
];
---

<section
  id={lang === "en" ? "examples" : "ejemplos"}
  class="pt-16 pb-8"
  aria-labelledby="examples-title"
>
  <Container>
    <div class="text-center mb-8" data-reveal>
      <h2 id="examples-title" class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">
        {t.sectionTitle}
      </h2>
      <p class="text-heading-3 text-base max-w-2xl mx-auto">{t.sectionSubtitle}</p>
    </div>

    <!-- Tabs -->
    <div
      class="flex border-b border-box-border mb-8 overflow-x-auto"
      role="tablist"
      aria-label={lang === "en" ? "Plan examples" : "Ejemplos por plan"}
    >
      {panels.map(({ id, label }) => (
        <button
          data-examples-tab={id}
          role="tab"
          aria-selected={id === "starter" ? "true" : "false"}
          aria-controls={`examples-panel-${id}`}
          class={`px-6 py-3 text-sm font-semibold whitespace-nowrap border-b-2 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset ${id === "starter" ? "border-primary text-primary" : "border-transparent text-heading-3 hover:text-heading-2"}`}
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    {panels.map(({ id, examples }) => (
      <div
        id={`examples-panel-${id}`}
        data-examples-panel={id}
        role="tabpanel"
        class={id !== "starter" ? "hidden" : ""}
      >
        <div class="grid sm:grid-cols-2 gap-6 mb-6" data-stagger>
          {examples.map((ex) => (
            <div class="group rounded-2xl border border-box-border bg-box-bg overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 motion-card flex flex-col">
              <!-- Screenshot thumbnail -->
              <div class="relative overflow-hidden h-48 bg-gray-100 dark:bg-gray-800 example-thumb">
                <img
                  src={mshot(ex.liveHref)}
                  alt={ex.industry}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="thumb-fallback absolute inset-0 hidden items-center justify-center bg-gradient-to-br from-primary/10 to-primary/5">
                  <svg class="w-10 h-10 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
                  </svg>
                </div>
                <!-- Website badge -->
                <div class="absolute top-3 right-3">
                  <a
                    href={ex.liveHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 bg-black/65 hover:bg-black/85 text-white text-xs font-semibold px-3 py-1.5 rounded-full backdrop-blur-sm transition-colors"
                  >
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
                    </svg>
                    {t.visitLabel}
                  </a>
                </div>
              </div>

              <!-- Card content -->
              <div class="p-5 flex flex-col gap-3 flex-1">
                <div class="flex items-start justify-between gap-3">
                  <a
                    href={ex.liveHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-bold text-lg text-heading-1 hover:text-primary transition-colors leading-snug"
                  >
                    {ex.industry}
                    <span class="text-heading-3 text-base ml-0.5">↗</span>
                  </a>
                  <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${planStyle[ex.plan]}`}>
                    {ex.plan}
                  </span>
                </div>
                <div>
                  <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${typeStyle[ex.type]}`}>
                    {ex.type === "real" ? t.realLabel : t.demoLabel}
                  </span>
                </div>
                <p class="text-sm text-heading-3 leading-relaxed">{ex.desc}</p>
                {ex.type === "demo" && (
                  <p class="text-xs text-heading-3 italic leading-relaxed">{t.demoNote}</p>
                )}
                <div class="mt-auto pt-2">
                  <a
                    href={`${startBase}?plan=${ex.planId}&style=${ex.planId}`}
                    class="text-xs px-4 py-2 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-colors"
                  >
                    {t.wantThis}
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </Container>
</section>

<script>
  document.querySelectorAll(".example-thumb img").forEach((img) => {
    const el = img as HTMLImageElement;
    const fallback = el.nextElementSibling as HTMLElement;
    const showFallback = () => {
      el.style.display = "none";
      if (fallback) fallback.style.display = "flex";
    };
    el.addEventListener("error", showFallback);
    el.addEventListener("load", () => {
      if (el.naturalWidth < 10) showFallback();
    });
  });
</script>
