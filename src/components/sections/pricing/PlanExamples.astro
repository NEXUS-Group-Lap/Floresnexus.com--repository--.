---
import Container from "../../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    sectionTitle: "Website Examples by Plan",
    sectionSubtitle: "Select a plan to see what that level looks like.",
    tabMini: "Mini Card",
    tabStarter: "Starter",
    tabProfessional: "Professional",
    badgeMini: "Mini Card",
    badgeStarter: "Starter",
    badgeProfessional: "Professional",
    demoLabel: "Conceptual Demo",
    viewExample: "View Example",
    wantThis: "I Want Something Like This",
    viewAll: "View all website examples",
    demoNote: "Examples marked \"Conceptual Demo\" represent the style and structure available at this plan level.",
  },
  es: {
    sectionTitle: "Ejemplos de Sitios por Plan",
    sectionSubtitle: "Selecciona un plan para ver cómo se ve ese nivel.",
    tabMini: "Mini Card",
    tabStarter: "Starter",
    tabProfessional: "Professional",
    badgeMini: "Mini Card",
    badgeStarter: "Starter",
    badgeProfessional: "Professional",
    demoLabel: "Demo Conceptual",
    viewExample: "Ver Ejemplo",
    wantThis: "Quiero Algo Así",
    viewAll: "Ver todos los ejemplos de sitios",
    demoNote: "Los ejemplos marcados como \"Demo Conceptual\" representan el estilo y estructura disponible en ese nivel de plan.",
  },
}[lang];

const startBase = { en: "/en/start", es: "/es/empezar" }[lang];
const examplesHref = { en: "/en/examples", es: "/es/ejemplos" }[lang];

const miniCardExamples = [
  {
    industry: lang === "en" ? "Food Truck" : "Food Truck",
    style: "food-truck",
    desc: lang === "en"
      ? "Name, hours, menu items, call/WhatsApp buttons, social links."
      : "Nombre, horario, artículos del menú, botones de llamada/WhatsApp, redes sociales.",
    color: "from-orange-400 to-red-500",
    initial: "FT",
  },
  {
    industry: lang === "en" ? "Hair Stylist" : "Estilista",
    style: "hair-stylist",
    desc: lang === "en"
      ? "Services, phone and WhatsApp contact, hours, Instagram link, service area."
      : "Servicios, contacto por teléfono y WhatsApp, horario, Instagram, área de servicio.",
    color: "from-pink-400 to-purple-500",
    initial: "ES",
  },
];

const starterExamples = [
  {
    industry: lang === "en" ? "Lawn Care" : "Lawn Care",
    style: "lawn-care",
    desc: lang === "en"
      ? "Professional page with services, images, service area, and contact buttons."
      : "Página profesional con servicios, imágenes, área de servicio y botones de contacto.",
    color: "from-green-500 to-emerald-600",
    initial: "LC",
  },
  {
    industry: lang === "en" ? "Barbershop" : "Barbería",
    style: "barbershop",
    desc: lang === "en"
      ? "Services, gallery, hours, location, and contact."
      : "Servicios, galería, horario, ubicación y contacto.",
    color: "from-slate-600 to-gray-800",
    initial: "BB",
  },
];

const professionalExamples = [
  {
    industry: lang === "en" ? "General Contractor" : "Contratista General",
    style: "contractor",
    desc: lang === "en"
      ? "Home, Services, Gallery, About, Contact — 5 pages with project photos and form."
      : "Home, Servicios, Galería, About, Contacto — 5 páginas con fotos y formulario.",
    pages: 5,
    color: "from-stone-500 to-gray-700",
    initial: "GC",
  },
  {
    industry: lang === "en" ? "Windows & Doors" : "Ventanas y Puertas",
    style: "windows-doors",
    desc: lang === "en"
      ? "Product pages, gallery, service areas, contact form, and quote request."
      : "Páginas de productos, galería, áreas de servicio, formulario y solicitud de cotización.",
    pages: 5,
    color: "from-cyan-500 to-blue-600",
    initial: "VP",
  },
];

type ExampleType = { industry: string; style: string; desc: string; color: string; initial: string; pages?: number };

const panels: { id: string; badge: string; examples: ExampleType[] }[] = [
  { id: "mini-card", badge: t.badgeMini, examples: miniCardExamples },
  { id: "starter", badge: t.badgeStarter, examples: starterExamples },
  { id: "professional", badge: t.badgeProfessional, examples: professionalExamples },
];
---

<section
  id={lang === "en" ? "examples" : "ejemplos"}
  class="pt-16 pb-8"
  aria-labelledby="examples-title"
>
  <Container>
    <div class="text-center mb-8" data-reveal>
      <h2 id="examples-title" class="text-3xl md:text-4xl font-bold text-heading-1 mb-3">
        {t.sectionTitle}
      </h2>
      <p class="text-heading-3 text-base max-w-2xl mx-auto">{t.sectionSubtitle}</p>
    </div>

    <!-- Tabs -->
    <div
      class="flex border-b border-box-border mb-8 overflow-x-auto"
      role="tablist"
      aria-label={lang === "en" ? "Plan examples" : "Ejemplos por plan"}
    >
      {
        [
          { id: "mini-card", label: t.tabMini },
          { id: "starter", label: t.tabStarter },
          { id: "professional", label: t.tabProfessional },
        ].map(({ id, label }) => (
          <button
            data-examples-tab={id}
            role="tab"
            aria-selected={id === "starter" ? "true" : "false"}
            aria-controls={`examples-panel-${id}`}
            class={`px-6 py-3 text-sm font-semibold whitespace-nowrap border-b-2 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset ${id === "starter" ? "border-primary text-primary" : "border-transparent text-heading-3 hover:text-heading-2"}`}
          >
            {label}
          </button>
        ))
      }
    </div>

    <!-- Panels -->
    {
      panels.map(({ id, badge, examples }) => (
        <div
          id={`examples-panel-${id}`}
          data-examples-panel={id}
          role="tabpanel"
          class={id !== "starter" ? "hidden" : ""}
        >
          <div class="grid sm:grid-cols-2 gap-5 mb-6" data-stagger>
            {examples.map((ex) => (
              <div class="rounded-xl border border-box-border bg-box-bg overflow-hidden motion-card">
                <!-- Placeholder image -->
                <div class={`relative aspect-video bg-gradient-to-br ${ex.color} flex items-center justify-center`}>
                  <span class="text-white text-3xl font-black opacity-40 select-none">{ex.initial}</span>
                  <span class="absolute top-2 left-2 text-xs font-bold text-white/90 bg-black/30 px-2 py-0.5 rounded-full">
                    {t.demoLabel}
                  </span>
                  <span class="absolute top-2 right-2 text-xs font-semibold text-white bg-primary/80 px-2 py-0.5 rounded-full">
                    {badge}
                  </span>
                  {ex.pages && (
                    <span class="absolute bottom-2 right-2 text-xs text-white/80 bg-black/30 px-2 py-0.5 rounded-full">
                      {ex.pages} {lang === "en" ? "pages" : "páginas"}
                    </span>
                  )}
                </div>

                <div class="p-4">
                  <p class="text-xs font-bold text-primary uppercase tracking-wide mb-0.5">{ex.industry}</p>
                  <p class="text-xs text-heading-3 leading-relaxed mb-3">{ex.desc}</p>
                  <div class="flex gap-2 flex-wrap">
                    <a
                      href="#"
                      class="text-xs px-3 py-1.5 rounded-full border border-box-border text-heading-3 cursor-not-allowed opacity-60"
                      aria-disabled="true"
                      title={lang === "en" ? "Live demo coming soon" : "Demo en vivo próximamente"}
                    >
                      {t.viewExample}
                    </a>
                    <a
                      href={`${startBase}?plan=${id}&style=${ex.style}`}
                      class="text-xs px-3 py-1.5 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-colors"
                    >
                      {t.wantThis}
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }

    <!-- View all link + footnote -->
    <div class="text-center mt-4">
      <a
        href={examplesHref}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline"
      >
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <p class="text-center text-xs text-heading-3 italic mt-4 max-w-xl mx-auto">{t.demoNote}</p>
  </Container>
</section>
