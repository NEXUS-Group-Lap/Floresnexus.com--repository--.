---
import Container from "../../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    sectionTitle: "Important Service Information",
    blocks: [
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
        title: "Managed service",
        body: "Your website remains hosted and managed while your subscription is active. Canceling the subscription ends hosting and administration.",
      },
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>`,
        title: "Small updates",
        body: "Starter includes 1 small update per month. Professional includes 3. Updates do not accumulate month to month.",
        accordion: {
          label: "What counts as a small update?",
          includes: [
            "Replace one image",
            "Correct short text (hours, phone number, address)",
            "Update one link",
            "Minor wording change",
          ],
          excludes: [
            "New pages",
            "Redesigns or new sections",
            "Booking or payment systems",
            "Automations or integrations",
            "Advanced SEO",
            "Social media management",
          ],
          includesLabel: "Counts as a small update:",
          excludesLabel: "Does not count:",
        },
      },
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
        title: "Domain and ownership",
        body: "Standard domain management is included when applicable. Exact domains are not guaranteed. Premium domains and ownership transfers are quoted separately.",
      },
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>`,
        title: "Delivery",
        body: "Typical delivery is 3–5 business days after payment and complete business information are received. Incomplete information delays the start.",
      },
    ],
  },
  es: {
    sectionTitle: "Información Importante del Servicio",
    blocks: [
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
        title: "Servicio administrado",
        body: "Tu sitio web permanece hospedado y administrado mientras la suscripción esté activa. Cancelar la suscripción termina el hosting y la administración.",
      },
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>`,
        title: "Actualizaciones pequeñas",
        body: "Starter incluye 1 actualización pequeña al mes. Professional incluye 3. Las actualizaciones no se acumulan de un mes a otro.",
        accordion: {
          label: "¿Qué cuenta como una actualización pequeña?",
          includes: [
            "Reemplazar una imagen",
            "Corregir texto corto (horario, teléfono, dirección)",
            "Actualizar un enlace",
            "Cambio menor de redacción",
          ],
          excludes: [
            "Páginas nuevas",
            "Rediseños o secciones nuevas",
            "Sistemas de reservas o pagos",
            "Automatizaciones o integraciones",
            "SEO avanzado",
            "Manejo de redes sociales",
          ],
          includesLabel: "Cuenta como actualización pequeña:",
          excludesLabel: "No cuenta:",
        },
      },
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>`,
        title: "Dominio y propiedad",
        body: "La administración estándar del dominio está incluida cuando aplica. Los dominios exactos no están garantizados. Dominios premium y transferencias de propiedad se cotizan por separado.",
      },
      {
        icon: `<svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>`,
        title: "Entrega",
        body: "El plazo típico de entrega es de 3–5 días hábiles después de recibir el pago y la información completa del negocio. La información incompleta retrasa el inicio.",
      },
    ],
  },
}[lang];
---

<section class="py-12" aria-labelledby="critical-info-title">
  <Container>
    <div class="text-center mb-8" data-reveal>
      <h2 id="critical-info-title" class="text-2xl md:text-3xl font-bold text-heading-1">
        {t.sectionTitle}
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-5 max-w-4xl mx-auto" data-stagger>
      {t.blocks.map((block) => (
        <div class="rounded-xl border border-box-border bg-box-bg p-5 motion-card">
          <div class="flex items-start gap-3 mb-2">
            <span class="flex-shrink-0" aria-hidden="true"><Fragment set:html={block.icon} /></span>
            <h3 class="font-semibold text-heading-1 text-sm">{block.title}</h3>
          </div>
          <p class="text-sm text-heading-3 leading-relaxed ml-8">{block.body}</p>

          {block.accordion && (
            <details class="mt-3 ml-8">
              <summary class="text-xs font-semibold text-primary cursor-pointer hover:underline select-none list-none flex items-center gap-1">
                <svg class="w-3 h-3 shrink-0 transition-transform details-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M9 5l7 7-7 7" />
                </svg>
                {block.accordion.label}
              </summary>
              <div class="mt-2 grid sm:grid-cols-2 gap-3">
                <div>
                  <p class="text-xs font-semibold text-green-600 dark:text-green-400 mb-1">{block.accordion.includesLabel}</p>
                  <ul class="space-y-0.5">
                    {block.accordion.includes.map((item) => (
                      <li class="text-xs text-heading-2 flex items-center gap-1.5">
                        <svg class="w-3 h-3 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <p class="text-xs font-semibold text-red-500 dark:text-red-400 mb-1">{block.accordion.excludesLabel}</p>
                  <ul class="space-y-0.5">
                    {block.accordion.excludes.map((item) => (
                      <li class="text-xs text-heading-3 flex items-center gap-1.5">
                        <svg class="w-3 h-3 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </details>
          )}
        </div>
      ))}
    </div>
  </Container>
</section>

<style>
  details[open] .details-arrow {
    transform: rotate(90deg);
  }
</style>
