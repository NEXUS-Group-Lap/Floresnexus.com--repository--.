---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}

const { lang } = Astro.props;

const t = {
  en: {
    title: "What we review before launch",
    subtitle: "No fake testimonials. These are the practical checks we use before a site goes live.",
    items: [
      {
        title: "Business details",
        desc: "We review the business name, contact details, hours, location or service area, and selected plan information.",
      },
      {
        title: "Service presentation",
        desc: "We check that services are clear, organized, and easy for visitors to understand on mobile devices.",
      },
      {
        title: "Contact visibility",
        desc: "We review call, text, WhatsApp, form, and map or service area elements based on the selected plan.",
      },
    ],
  },
  es: {
    title: "Lo que revisamos antes del lanzamiento",
    subtitle: "Sin testimonios falsos. Estas son revisiones prácticas antes de publicar una página.",
    items: [
      {
        title: "Datos del negocio",
        desc: "Revisamos nombre del negocio, contacto, horarios, ubicación o área de servicio, y el plan seleccionado.",
      },
      {
        title: "Presentación de servicios",
        desc: "Verificamos que los servicios sean claros, organizados y fáciles de entender en dispositivos móviles.",
      },
      {
        title: "Visibilidad de contacto",
        desc: "Revisamos llamada, texto, WhatsApp, formulario, mapa o área de servicio según el plan seleccionado.",
      },
    ],
  },
}[lang];
---

<section class="py-16 bg-gradient-to-b from-transparent to-box-bg/50">
  <Container>
    <div class="text-center mb-12" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
      {t.items.map((item, i) => (
        <div class="relative p-6 rounded-2xl border border-box-border bg-box-bg hover:border-primary/40 hover:shadow-md transition-all duration-300 motion-card">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
            <span class="text-primary font-bold text-sm">0{i + 1}</span>
          </div>
          <h3 class="font-bold text-heading-1 text-lg mb-2">{item.title}</h3>
          <p class="text-heading-3 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
