---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Ready to get your business online?",
    subtitle: "Start your website today. Fill out the form, select your plan, and we handle the rest.",
    cta: "Start My Website",
    ctaHref: "/en/start",
    ctaSecondary: "View Plans",
    ctaSecondaryHref: "/en/pricing",
  },
  es: {
    title: "¿Listo para poner tu negocio en línea?",
    subtitle: "Empieza tu página hoy. Llena el formulario, selecciona tu plan y nosotros hacemos el resto.",
    cta: "Empezar Mi Página",
    ctaHref: "/es/empezar",
    ctaSecondary: "Ver Planes",
    ctaSecondaryHref: "/es/precios",
  },
}[lang];
---

<section class="py-16">
  <Container>
    <div class="relative rounded-3xl bg-gradient-to-br from-primary to-blue-700 p-10 md:p-16 text-center overflow-hidden motion-card" data-reveal="scale">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <span class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-white/5 blur-2xl float-medium"></span>
        <span class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-white/5 blur-2xl float-slow"></span>
      </div>
      <div class="relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{t.title}</h2>
        <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">{t.subtitle}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center" data-stagger>
          <a
            href={t.ctaHref}
            class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-white text-primary font-semibold hover:bg-blue-50 transition-all duration-300 motion-button"
          >
            {t.cta}
          </a>
          <a
            href={t.ctaSecondaryHref}
            class="inline-flex items-center justify-center px-8 py-3 rounded-full border-2 border-white/40 text-white font-semibold hover:bg-white/10 transition-all duration-300 motion-button"
          >
            {t.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
