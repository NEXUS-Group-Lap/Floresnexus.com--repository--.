---
import Container from "../shared/Container.astro";
import { plans } from "../../data/plans";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;
const plan = plans["business-system"];
const copy = plan[lang];

const t = {
  en: {
    title: "Need more than a standard website?",
    text: "Business System is for businesses that need booking, online payments, CRM connections, automation, multiple locations, custom workflows, or advanced integrations.",
    priceLabel: "Starting at $2,500 setup and $399/month",
    proposalNote: "Final scope and pricing are defined in a written proposal.",
    cta: "Request a Custom Quote",
  },
  es: {
    title: "¿Necesitas más que un sitio web estándar?",
    text: "Business System es para negocios que necesitan reservas, pagos en línea, conexiones CRM, automatizaciones, múltiples ubicaciones, flujos personalizados o integraciones avanzadas.",
    priceLabel: "Desde $2,500 de configuración y $399/mes",
    proposalNote: "El alcance final y el precio se definen en una propuesta escrita.",
    cta: "Solicitar Cotización Personalizada",
  },
}[lang];
---

<section class="py-16" id="business-system">
  <Container>
    <div class="rounded-2xl border border-box-border bg-gradient-to-r from-box-bg to-primary/5 max-w-4xl mx-auto p-8 motion-card" data-reveal="scale">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div class="flex-1">
          <h3 class="text-xl font-bold text-heading-1 mb-2">{t.title}</h3>
          <p class="text-sm text-heading-3 leading-relaxed max-w-xl mb-3">{t.text}</p>
          <p class="text-sm font-semibold text-primary">{t.priceLabel}</p>
          <p class="text-xs text-heading-3 mt-1 italic">{t.proposalNote}</p>
        </div>
        <div class="flex flex-col gap-2 w-full md:w-auto">
          <a
            href={plan.startForm[lang]}
            class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-primary text-white font-semibold hover:bg-blue-800 transition-all duration-300 text-sm motion-button whitespace-nowrap"
          >
            {t.cta}
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
