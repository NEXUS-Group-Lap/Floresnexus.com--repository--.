        type: "real" as const,
        liveHref: "https://nexus-group-lap.github.io/alma/",
        imgUrl: "",
      },
      {
        industry: "Architecture / Design",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "https://3dinterior.mail-nearmelab.workers.dev/projects/",
        imgUrl: "",
      },
      {
        industry: "Photography",
        plan: "Professional Website",
        type: "demo" as const,
        liveHref: "https://horizon.cosmicthemes.com",
        imgUrl: "",
      },
      {
        industry: "Fintech / Payments",
        plan: "Professional Website",
        type: "demo" as const,
        liveHref: "https://zeepay-lyart.vercel.app",
        imgUrl: "",
      },
      {
        industry: "Restaurant / Café",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=640&h=960&fit=crop",
      },
      {
        industry: "Barbershop",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=640&h=960&fit=crop",
      },
      {
        industry: "Gym / Personal Trainer",
        plan: "Professional Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=640&h=960&fit=crop",
      },
      {
        industry: "Cleaning Service",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=640&h=960&fit=crop",
      },
    ],
  },
  es: {
    title: "Proyectos Reales y Estilos Que Podemos Construir",
    subtitle: "Algunos son proyectos reales en producción. Otros son conceptos de demostración que muestran los estilos y estructuras que podemos construir para tu negocio.",
    examples: [
      {
        industry: "Jardinería",
        plan: "Starter Website",
        type: "real" as const,
        liveHref: "https://nexus-group-lap.github.io/floreslawncare/",
        imgUrl: "",
      },
      {
        industry: "Pulpería / Tienda Local",
        plan: "Nexus Card",
        type: "real" as const,
        liveHref: "https://floresnexus.cards/lamorenita/",
        imgUrl: "",
      },
      {
