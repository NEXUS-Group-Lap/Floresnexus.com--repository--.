---
import Container from "../shared/Container.astro";

export interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const t = {
  en: {
    title: "Website Examples by Industry",
    subtitle: "See the type of clean, professional websites we build for local service businesses.",
    disclaimer: "These are sample layouts representing the style and structure we deliver.",
    ctaLabel: "Start with this style →",
    ctaHref: "/en/start?plan=professional",
    examples: [
      {
        industry: "Photographers",
        color: "from-amber-500/20 to-orange-500/10",
        border: "border-amber-500/30",
        accent: "bg-amber-500",
        desc: "Clean before/after gallery, services list, contact form, service area map.",
      },
      {
        industry: "Roofing",
        color: "from-blue-500/20 to-sky-500/10",
        border: "border-blue-500/30",
        accent: "bg-blue-500",
        desc: "Free estimate CTA, photo gallery, financing info, call button.",
      },
      {
        industry: "Cleaning",
        color: "from-green-500/20 to-emerald-500/10",
        border: "border-green-500/30",
        accent: "bg-green-500",
        desc: "Booking-ready layout, service packages, before/after photos, reviews area.",
      },
      {
        industry: "Lawn Care",
        color: "from-lime-500/20 to-green-500/10",
        border: "border-lime-500/30",
        accent: "bg-lime-500",
        desc: "Service list, pricing preview, seasonal schedule info, contact form.",
      },
      {
        industry: "Food Truck",
        color: "from-red-500/20 to-orange-500/10",
        border: "border-red-500/30",
        accent: "bg-red-500",
        desc: "Menu highlights, schedule/location info, social links, order CTA.",
      },
      {
        industry: "Barber Shop",
        color: "from-purple-500/20 to-violet-500/10",
        border: "border-purple-500/30",
        accent: "bg-purple-500",
        desc: "Portfolio gallery, services & pricing, booking link, hours & location.",
      },
      {
        industry: "Handyman",
        color: "from-yellow-500/20 to-amber-500/10",
        border: "border-yellow-500/30",
        accent: "bg-yellow-500",
        desc: "Service list, fast response CTA, WhatsApp button, service area.",
      },
      {
        industry: "Mobile Mechanic",
        color: "from-gray-500/20 to-slate-500/10",
        border: "border-gray-500/30",
        accent: "bg-gray-500",
        desc: "Services offered, service area, call/text button, emergency CTA.",
      },
    ],
  },
  es: {
    title: "Ejemplos de Páginas por Industria",
    subtitle: "Ve el tipo de páginas profesionales y limpias que construimos para negocios locales.",
    disclaimer: "Estos son diseños de muestra que representan el estilo y estructura que entregamos.",
    ctaLabel: "Empezar con este estilo →",
    ctaHref: "/es/empezar?plan=professional",
    examples: [
      {
        industry: "Fotografos",
        color: "from-amber-500/20 to-orange-500/10",
        border: "border-amber-500/30",
        accent: "bg-amber-500",
        desc: "Galeria antes/despues, lista de servicios, formulario de contacto, mapa de area.",
      },
      {
        industry: "Roofing",
        preview:true,
        color: "from-blue-500/20 to-sky-500/10",
        border: "border-blue-500/30",
        accent: "bg-blue-500",
        desc: "CTA de estimado gratis, galeria de fotos, informacion de financiamiento, boton de llamada.",
      },
      {
        industry: "Limpieza",
        color: "from-green-500/20 to-emerald-500/10",
        border: "border-green-500/30",
        accent: "bg-green-500",
        desc: "Diseno listo para reservas, paquetes de servicio, fotos, area de resenas.",
      },
      {
        industry: "Jardineria",
        color: "from-lime-500/20 to-green-500/10",
        border: "border-lime-500/30",
        accent: "bg-lime-500",
        desc: "Lista de servicios, vista previa de precios, info de temporada, formulario.",
      },
      {
        industry: "Food Truck",
        color: "from-red-500/20 to-orange-500/10",
        border: "border-red-500/30",
        accent: "bg-red-500",
        desc: "Highlights del menu, horario/ubicacion, redes sociales, CTA de pedido.",
      },
      {
        industry: "Barberia",
        color: "from-purple-500/20 to-violet-500/10",
        border: "border-purple-500/30",
        accent: "bg-purple-500",
        desc: "Galeria de portfolios, servicios y precios, link de reserva, horarios.",
      },
      {
        industry: "Handyman",
        color: "from-yellow-500/20 to-amber-500/10",
        border: "border-yellow-500/30",
        accent: "bg-yellow-500",
        desc: "Lista de servicios, CTA de respuesta rapida, boton WhatsApp, area de servicio.",
      },
      {
        industry: "Mecanico Movil",
        color: "from-gray-500/20 to-slate-500/10",
        border: "border-gray-500/30",
        accent: "bg-gray-500",
        desc: "Servicios ofrecidos, area de servicio, boton de llamada/texto, CTA de emergencia.",
      },
    ],
  },
}[lang];
---

<section class="py-16" id={lang === "en" ? "examples" : "ejemplos"}>
  <Container>
    <div class="text-center mb-4" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">{t.title}</h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto mb-2">{t.subtitle}</p>
      <p class="text-sm text-heading-3 italic">{t.disclaimer}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-10" data-stagger>
      {t.examples.map((ex) => (
        <div class={`rounded-2xl border ${ex.border} overflow-hidden hover:shadow-lg transition-all duration-300 group motion-card`}>
          <!-- Mock browser chrome -->
          <div class={`bg-gradient-to-br ${ex.color} p-5 h-36 flex flex-col items-center justify-center relative`}>
            <div class="absolute top-3 left-3 flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span>
            </div>
            <div class="w-14 h-14 rounded-2xl bg-white/25 flex items-center justify-center group-hover:scale-105 transition-transform">
              <span class="text-xl font-black text-white tracking-tight">{ex.industry.slice(0, 2).toUpperCase()}</span>
            </div>
            <div class="absolute bottom-3 left-3 right-3 h-1 bg-white/20 rounded-full">
              <div class="h-full w-2/3 bg-white/40 rounded-full draw-line"></div>
            </div>
          </div>
          <div class="p-4 bg-box-bg flex flex-col gap-3">
            <div>
              <h3 class="font-bold text-heading-1 mb-1">{ex.industry} Website</h3>
              <p class="text-sm text-heading-3 leading-relaxed">{ex.desc}</p>
            </div>
            <a
              href={t.ctaHref}
              class="text-xs font-semibold text-primary hover:underline transition-colors mt-auto"
            >
              {t.ctaLabel}
            </a>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
