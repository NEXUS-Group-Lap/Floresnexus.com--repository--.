        plan: "Nexus Card",
        type: "real" as const,
        liveHref: "https://nexus-group-lap.github.io/alma/",
        imgUrl: "",
      },
      {
        industry: "Arquitectura / Diseño",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "https://3dinterior.mail-nearmelab.workers.dev/projects/",
        imgUrl: "",
      },
      {
        industry: "Fotografía",
        plan: "Professional Website",
        type: "demo" as const,
        liveHref: "https://horizon.cosmicthemes.com",
        imgUrl: "",
      },
      {
        industry: "Fintech / Pagos",
        plan: "Professional Website",
        type: "demo" as const,
        liveHref: "https://zeepay-lyart.vercel.app",
        imgUrl: "",
      },
      {
        industry: "Restaurante / Café",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=640&h=960&fit=crop",
      },
      {
        industry: "Barbería",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=640&h=960&fit=crop",
      },
      {
        industry: "Gimnasio / Entrenador",
        plan: "Professional Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=640&h=960&fit=crop",
      },
      {
        industry: "Servicio de Limpieza",
        plan: "Starter Website",
        type: "demo" as const,
        liveHref: "",
        imgUrl: "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=640&h=960&fit=crop",
      },
    ],
  },
}[lang];

const badgeClasses: Record<string, string> = {
  "Nexus Card": "bg-pink-500/30 text-pink-100",
  "Starter Website": "bg-lime-500/30 text-lime-100",
  "Professional Website": "bg-blue-500/30 text-blue-100",
};

const fanCards = t.examples.map((ex) => ({
  imgUrl: ex.imgUrl || mshot(ex.liveHref),
  alt: ex.industry,
  linkUrl: ex.liveHref || undefined,
  label: ex.industry,
  badge: ex.plan,
  badgeClass: badgeClasses[ex.plan] || "bg-white/20 text-white",
}));
---

<section class="py-16" id={lang === "en" ? "examples" : "ejemplos"}>
  <Container>
    <div class="text-center mb-6" data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-heading-1 mb-4">
        {lang === "en"
          ? <Fragment>Real Projects and Styles <span class="text-primary dark:text-blue-400">We Can Build</span></Fragment>
          : <Fragment>Proyectos Reales y Estilos <span class="text-primary dark:text-blue-400">Que Podemos Construir</span></Fragment>
        }
      </h2>
      <p class="text-heading-3 text-lg max-w-2xl mx-auto">{t.subtitle}</p>
    </div>
  </Container>

  <CardFanCarousel client:visible cards={fanCards} />
</section>
