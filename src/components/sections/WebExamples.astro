    title: "Real Projects and Styles We Can Build",
    subtitle: "Some are real projects in production. Others are demo concepts showing the styles and structures we can build for your business.",
    examples: [
      {
        industry: "Lawn Care",
        plan: "Starter Website",
        type: "real" as const,
        liveHref: "https://nexus-group-lap.github.io/floreslawncare/",
        imgUrl: "",
      },
      {
        industry: "Grocery Store / Pulpería",
        plan: "Nexus Card",
        type: "real" as const,
        liveHref: "https://floresnexus.cards/lamorenita/",
        imgUrl: "",
      },
      {
        industry: "Resale / Boutique",
