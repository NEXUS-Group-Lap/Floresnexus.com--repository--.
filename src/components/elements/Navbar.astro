---
import Container from "../shared/Container.astro";
import Navitem from "../shared/Navitem.astro";
import { TubelightNav } from "../ui/tubelight-navbar";

export interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const navItems =
  lang === "en"
    ? [
        { href: "/en", text: "Home" },
        { href: "/en#what-you-get", text: "Services" },
        { href: "/en#examples", text: "Examples" },
        { href: "/en#how-it-works", text: "How It Works" },
        { href: "/en#faq", text: "FAQ" },
        { href: "/en/pricing", text: "Compare" },
        { href: "/en/start", text: "Start" },
      ]
    : [
        { href: "/es", text: "Inicio" },
        { href: "/es#que-recibes", text: "Servicios" },
        { href: "/es#ejemplos", text: "Ejemplos" },
        { href: "/es#como-funciona", text: "Cómo Funciona" },
        { href: "/es#preguntas", text: "Preguntas" },
        { href: "/es/precios", text: "Comparar" },
        { href: "/es/empezar", text: "Empezar" },
      ];

const homeHref = lang === "en" ? "/en/" : "/es/";
---

<header class="fixed inset-x-0 top-0 z-50 bg-[rgb(var(--color-bg))] shadow-sm">
  <div class="w-full border-b border-box-border/50 bg-box-bg/80 backdrop-blur-sm">
    <div class="flex justify-end items-center gap-4 sm:gap-5 px-6 text-xs font-semibold tracking-wide max-w-7xl mx-auto">
      <a
        href={lang === "en" ? "/en/client-portal" : "/es/portal-cliente"}
        class="text-heading-3 hover:text-primary transition-colors duration-200 inline-flex items-center min-h-11"
      >
        {lang === "en" ? "Client Login" : "Portal del Cliente"}
      </a>
      <span class="text-heading-3 opacity-30">|</span>
      <a
        href="/en/"
        class={`transition-colors duration-200 inline-flex items-center min-h-11 ${lang === "en" ? "text-primary" : "text-heading-3 hover:text-primary"}`}
      >
        English
      </a>
      <span class="text-heading-3 opacity-30">|</span>
      <a
        href="/es/"
        class={`transition-colors duration-200 inline-flex items-center min-h-11 ${lang === "es" ? "text-primary" : "text-heading-3 hover:text-primary"}`}
      >
        Español
      </a>
    </div>
  </div>

  <Container>
    <nav class="w-full flex justify-between gap-6 relative py-5">
      <div class="min-w-max inline-flex relative">
        <a href={homeHref} class="relative flex items-center gap-3">
          <div class="relative w-8 h-8 flex items-center justify-center">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8">
              <path d="M16 2L28 10L28 22L16 30L4 22L4 10Z" fill="#cfdcfd" fill-opacity="0.35" stroke="#8aabfc" stroke-width="0.5" stroke-opacity="0.5"></path>
              <path d="M16 6L24 12L24 20L16 26L8 20L8 12Z" fill="#92b4fd" fill-opacity="0.45" stroke="#4a82f8" stroke-width="0.5" stroke-opacity="0.5"></path>
              <path d="M16 10L21 14L21 18L16 22L11 18L11 14Z" fill="#1055f4"></path>
            </svg>
          </div>
          <div class="inline-flex flex-col leading-none">
            <span class="text-sm font-bold text-heading-1 tracking-wide">FLORES NEXUS</span>
            <span class="text-xs font-medium text-heading-3 tracking-widest uppercase">GROUP</span>
          </div>
        </a>
      </div>

      <div
        data-nav-overlay
        aria-hidden="true"
        class="fixed hidden inset-0 lg:!hidden bg-box-bg bg-opacity-50 backdrop-filter backdrop-blur-xl"
      ></div>

      <!-- Desktop: Tubelight animated nav -->
      <TubelightNav client:load lang={lang} />

      <!-- Mobile: Dropdown nav (hidden on desktop) -->
      <div
        data-navbar
        class="flex h-0 overflow-hidden duration-300 ease-linear flex-col gap-y-6 gap-x-4 w-full absolute top-full bg-box-bg border-x border-x-box-border lg:hidden"
      >
        <ul
          class="border-t border-box-border px-6 pt-6 pb-6 flex flex-col gap-y-4 gap-x-3 text-lg text-heading-2 w-full"
        >
          {navItems.map((item) => <Navitem {...item} />)}
        </ul>
      </div>

      <div class="min-w-max flex items-center gap-x-3">
        <button
          data-switch-theme
          class="outline-none flex relative text-heading-2 rounded-full p-2 lg:p-3 border border-box-border focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-6 h-6 dark:flex hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
            ></path>
          </svg>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-6 h-6 dark:hidden"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
            ></path>
          </svg>
          <span class="sr-only">switch theme</span>
        </button>

        <button
          data-toggle-nav
          data-open-nav="false"
          aria-label="Menu"
          aria-expanded="false"
          class="lg:hidden lg:invisible outline-none w-11 h-11 flex flex-col items-center justify-center relative gap-y-1.5 focus-visible:ring-2 focus-visible:ring-primary rounded"
        >
          <span id="line1" class="w-6 h-0.5 rounded-full bg-heading-2 transition-all duration-300 ease-linear"></span>
          <span id="line2" class="w-6 origin-center h-0.5 rounded-full bg-heading-2 transition-all duration-300 ease-linear"></span>
          <span id="line3" class="w-6 h-0.5 rounded-full bg-heading-2 transition-all duration-300 ease-linear"></span>
          <span class="sr-only">toggle nav</span>
        </button>
      </div>
    </nav>
  </Container>
</header>
