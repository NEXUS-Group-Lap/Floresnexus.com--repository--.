---
import Container from "../shared/Container.astro";

export interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    tagline: "Websites for local businesses. Built for you. Managed for you. Without agency prices.",
    services: "Services",
    company: "Company",
    support: "Support",
    legal: "Legal",
    copyright: "Flores Nexus Group LLC. All rights reserved.",
    serviceLinks: [
      { text: "Nexus Card", href: "/en/plans/mini-card" },
      { text: "Starter Website", href: "/en/plans/starter" },
      { text: "Professional Website", href: "/en/plans/professional" },
      { text: "Business System", href: "/en/business-system" },
    ],
    companyLinks: [
      { text: "Home", href: "/en" },
      { text: "Pricing", href: "/en/pricing" },
      { text: "Examples", href: "/en#examples" },
      { text: "Careers", href: "/en/careers" },
    ],
    supportLinks: [
      { text: "FAQ", href: "/en/faq" },
      { text: "Start My Website", href: "/en/start" },
      { text: "How It Works", href: "/en#how-it-works" },
      { text: "Contact", href: "mailto:info@floresnexus.com" },
    ],
    legalLinks: [
      { text: "Privacy Policy", href: "/en/privacy-policy" },
      { text: "Terms of Service", href: "/en/terms-of-service" },
      { text: "Refund Policy", href: "/en/refund-policy" },
      { text: "Service Scope", href: "/en/service-scope" },
      { text: "Acceptable Use", href: "/en/acceptable-use-policy" },
      { text: "Ownership", href: "/en/service-scope#add-ons" },
    ],
  },
  es: {
    tagline: "Sitios web para negocios locales. Hechos por nosotros. Administrados por nosotros. Sin precios de agencia.",
    services: "Servicios",
    company: "Empresa",
    support: "Soporte",
    legal: "Legal",
    copyright: "Flores Nexus Group LLC. Todos los derechos reservados.",
    serviceLinks: [
      { text: "Nexus Card", href: "/es/planes/mini-card" },
      { text: "Starter Website", href: "/es/planes/starter" },
      { text: "Professional Website", href: "/es/planes/professional" },
      { text: "Business System", href: "/es/business-system" },
    ],
    companyLinks: [
      { text: "Inicio", href: "/es" },
      { text: "Planes", href: "/es/precios" },
      { text: "Ejemplos", href: "/es#ejemplos" },
      { text: "Carreras", href: "/es/carreras" },
    ],
    supportLinks: [
      { text: "Preguntas Frecuentes", href: "/es/preguntas" },
      { text: "Empezar Mi Página", href: "/es/empezar" },
      { text: "Cómo Funciona", href: "/es#como-funciona" },
      { text: "Contacto", href: "mailto:info@floresnexus.com" },
    ],
    legalLinks: [
      { text: "Política de Privacidad", href: "/es/politica-de-privacidad" },
      { text: "Términos de Servicio", href: "/es/terminos-de-servicio" },
      { text: "Política de Reembolsos", href: "/es/politica-de-reembolsos" },
      { text: "Alcance del Servicio", href: "/es/alcance-del-servicio" },
      { text: "Uso Aceptable", href: "/es/uso-aceptable" },
      { text: "Propiedad", href: "/es/alcance-del-servicio#add-ons" },
    ],
  },
}[lang];
---

<div class="mt-16"></div>
<footer
  class="relative bg-gradient-to-tr from-gray-100 to-gray-200 dark:from-gray-900 dark:to-transparent pt-16 rounded-t-3xl"
>
  <div class="absolute right-0 top-0 h-full w-full flex justify-end overflow-hidden rounded-t-3xl">
    <div class="w-28 h-28 overflow-hidden flex rounded-xl relative blur-2xl opacity-60">
      <span class="absolute w-16 h-16 -top-1 -right-1 bg-primary rounded-md rotate-45"></span>
      <span class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary/40 rounded-md rotate-45"></span>
    </div>
  </div>

  <Container className="pb-8 relative">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href={lang === "en" ? "/en" : "/es"} class="flex items-center gap-2 mb-4">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7">
            <path d="M16 2L28 10L28 22L16 30L4 22L4 10Z" fill="#cfdcfd" fill-opacity="0.35" stroke="#8aabfc" stroke-width="0.5" stroke-opacity="0.5"></path>
            <path d="M16 6L24 12L24 20L16 26L8 20L8 12Z" fill="#92b4fd" fill-opacity="0.45" stroke="#4a82f8" stroke-width="0.5" stroke-opacity="0.5"></path>
            <path d="M16 10L21 14L21 18L16 22L11 18L11 14Z" fill="#1055f4"></path>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-xs font-bold text-heading-1 tracking-wide">FLORES NEXUS</span>
            <span class="text-xs font-medium text-heading-3 tracking-widest uppercase" style="font-size:0.6rem">GROUP</span>
          </div>
        </a>
        <!-- Social media icons -->
        <div class="flex gap-3">
          <a href="https://www.instagram.com/floresnexus/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-8 h-8 rounded-full border border-box-border flex items-center justify-center text-heading-3 hover:text-primary hover:border-primary transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/people/Flores-Nexus-Group/61590790191362/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-8 h-8 rounded-full border border-box-border flex items-center justify-center text-heading-3 hover:text-primary hover:border-primary transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
          <a href="https://nextdoor.com/page/flores-nexus-group" target="_blank" rel="noopener noreferrer" aria-label="Nextdoor" class="w-8 h-8 rounded-full border border-box-border flex items-center justify-center text-heading-3 hover:text-primary hover:border-primary transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 3L2 12h3v8h5v-5h4v5h5v-8h3L12 3zm0 2.5l6 5.5v7h-3v-5H9v5H6v-7l6-5.5z"/>
            </svg>
          </a>
          <a href="https://x.com/floresnexusgp" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="w-8 h-8 rounded-full border border-box-border flex items-center justify-center text-heading-3 hover:text-primary hover:border-primary transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/floresnexusgroup/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-8 h-8 rounded-full border border-box-border flex items-center justify-center text-heading-3 hover:text-primary hover:border-primary transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold text-heading-1 mb-4">{t.services}</h4>
        <ul class="space-y-2">
          {t.serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold text-heading-1 mb-4">{t.company}</h4>
        <ul class="space-y-2">
          {t.companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support + Legal -->
      <div>
        <h4 class="font-semibold text-heading-1 mb-4">{t.support}</h4>
        <ul class="space-y-2">
          {t.supportLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
        <h4 class="font-semibold text-heading-1 mt-6 mb-4">{t.legal}</h4>
        <ul class="space-y-2">
          {t.legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>

  <div class="bg-gradient-to-tl from-box-bg py-4">
    <Container>
      <div class="flex justify-between items-center gap-4 flex-wrap">
        <p class="text-sm text-heading-3">
          &copy; <span id="footer-year"></span>
          {" "}{t.copyright}
        </p>
        <div class="flex gap-4">
          <a href="/en" class="text-xs text-heading-3 hover:text-primary transition">EN</a>
          <span class="text-heading-3 text-xs">|</span>
          <a href="/es" class="text-xs text-heading-3 hover:text-primary transition">ES</a>
        </div>
      </div>
    </Container>
  </div>
</footer>

<script>
  const yearEl = document.getElementById("footer-year");
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
