---
import Container from "../shared/Container.astro";

export interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    tagline: "Simple monthly websites for local businesses. Built for you. Managed for you. Without agency prices.",
    services: "Services",
    company: "Company",
    support: "Support",
    legal: "Legal",
    copyright: "Flores Nexus Group LLC. All rights reserved.",
    serviceLinks: [
      { text: "Starter Website", href: "/en/pricing" },
      { text: "Professional Website", href: "/en/pricing" },
      { text: "Nexus Mini Card", href: "/en/pricing" },
      { text: "Business System", href: "/en/pricing" },
    ],
    companyLinks: [
      { text: "Home", href: "/en" },
      { text: "Pricing", href: "/en/pricing" },
      { text: "Careers", href: "/en/careers" },
      { text: "Seller Hub", href: "/seller-hub" },
    ],
    supportLinks: [
      { text: "FAQ", href: "/en/faq" },
      { text: "Start My Website", href: "/en/start" },
      { text: "How It Works", href: "/en#how-it-works" },
    ],
    legalLinks: [
      { text: "Privacy Policy", href: "/en/privacy-policy" },
      { text: "Terms of Service", href: "/en/terms-of-service" },
      { text: "Refund Policy", href: "/en/refund-policy" },
      { text: "Service Scope", href: "/en/service-scope" },
      { text: "Acceptable Use", href: "/en/acceptable-use-policy" },
    ],
  },
  es: {
    tagline: "Páginas web mensuales para negocios locales. Hechas por nosotros. Administradas por nosotros. Sin precios de agencia.",
    services: "Servicios",
    company: "Empresa",
    support: "Soporte",
    legal: "Legal",
    copyright: "Flores Nexus Group LLC. Todos los derechos reservados.",
    serviceLinks: [
      { text: "Starter Website", href: "/es/precios" },
      { text: "Professional Website", href: "/es/precios" },
      { text: "Nexus Mini Card", href: "/es/precios" },
      { text: "Business System", href: "/es/precios" },
    ],
    companyLinks: [
      { text: "Inicio", href: "/es" },
      { text: "Planes", href: "/es/precios" },
      { text: "Carreras", href: "/es/carreras" },
      { text: "Portal de Vendedores", href: "/seller-hub" },
    ],
    supportLinks: [
      { text: "Preguntas Frecuentes", href: "/es/preguntas" },
      { text: "Empezar Mi Página", href: "/es/empezar" },
      { text: "Cómo Funciona", href: "/es#como-funciona" },
    ],
    legalLinks: [
      { text: "Política de Privacidad", href: "/es/politica-de-privacidad" },
      { text: "Términos de Servicio", href: "/es/terminos-de-servicio" },
      { text: "Política de Reembolsos", href: "/es/politica-de-reembolsos" },
      { text: "Alcance del Servicio", href: "/es/alcance-del-servicio" },
      { text: "Uso Aceptable", href: "/es/uso-aceptable" },
    ],
  },
}[lang];
---

<div class="mt-16"></div>
<footer
  class="relative bg-gradient-to-tr from-gray-100 to-gray-200 dark:from-gray-900 dark:to-transparent pt-16 rounded-t-3xl"
>
  <div class="absolute right-0 top-0 h-full w-full flex justify-end overflow-hidden rounded-t-3xl">
    <div class="w-28 h-28 overflow-hidden flex rounded-xl relative blur-2xl opacity-60">
      <span class="absolute w-16 h-16 -top-1 -right-1 bg-primary rounded-md rotate-45"></span>
      <span class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary/40 rounded-md rotate-45"></span>
    </div>
  </div>

  <Container className="pb-8 relative">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href={lang === "en" ? "/en" : "/es"} class="flex items-center gap-2 mb-4">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7">
            <path d="M16 2L28 10L28 22L16 30L4 22L4 10Z" class="fill-primary" fill-opacity="0.15"></path>
            <path d="M16 6L24 12L24 20L16 26L8 20L8 12Z" class="fill-primary" fill-opacity="0.3"></path>
            <path d="M16 10L21 14L21 18L16 22L11 18L11 14Z" class="fill-primary"></path>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-xs font-bold text-heading-1 tracking-wide">FLORES NEXUS</span>
            <span class="text-xs font-medium text-heading-3 tracking-widest uppercase" style="font-size:0.6rem">GROUP</span>
          </div>
        </a>
        <p class="text-sm text-heading-3 leading-relaxed">{t.tagline}</p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold text-heading-1 mb-4">{t.services}</h4>
        <ul class="space-y-2">
          {t.serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold text-heading-1 mb-4">{t.company}</h4>
        <ul class="space-y-2">
          {t.companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support + Legal -->
      <div>
        <h4 class="font-semibold text-heading-1 mb-4">{t.support}</h4>
        <ul class="space-y-2">
          {t.supportLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
        <h4 class="font-semibold text-heading-1 mt-6 mb-4">{t.legal}</h4>
        <ul class="space-y-2">
          {t.legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-heading-3 hover:text-primary transition">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>

  <div class="bg-gradient-to-tl from-box-bg py-4">
    <Container>
      <div class="flex justify-between items-center gap-4 flex-wrap">
        <p class="text-sm text-heading-3">
          &copy; <span id="footer-year"></span>
          {" "}{t.copyright}
        </p>
        <div class="flex gap-4">
          <a href="/en" class="text-xs text-heading-3 hover:text-primary transition">EN</a>
          <span class="text-heading-3 text-xs">|</span>
          <a href="/es" class="text-xs text-heading-3 hover:text-primary transition">ES</a>
        </div>
      </div>
    </Container>
  </div>
</footer>

<script>
  const yearEl = document.getElementById("footer-year");
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
