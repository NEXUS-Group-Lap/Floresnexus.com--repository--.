---
export interface Props{
    href:string,
    text:string,
    className?:string,
    variant:"primary"|"secondary"
}

const {href, text, className, variant} = Astro.props

const base = "px-6 py-3 rounded-full outline-none border duration-[var(--motion-base)] font-medium";
const styles = {
  primary: `${base} bg-primary border-primary text-white hover:bg-blue-800 hover:border-blue-800`,
  secondary: `${base} border-box-border text-primary hover:border-primary hover:bg-primary/5`,
};
---

<a href={href} class={`${styles[variant]} ${className}`}>
    {text}
</a>
